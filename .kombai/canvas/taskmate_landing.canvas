      "html": "\n<div class=\"bg-[#0F0A1A] text-[#F0EEF8] font-sans selection:bg-[#8B65C8]/30\" data-kid=\"0\">\n    <style data-kid=\"1\">\n        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap');\n        @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n        :root {\n            --orange: #F5A87B;\n            --pink: #F0607A;\n            --purple: #8B65C8;\n            --teal: #4ABFB8;\n            --lavender: #C4C8E8;\n            --dark: #0F0A1A;\n            --dark2: #1A1228;\n            --dark3: #241B35;\n            --text: #F0EEF8;\n            --text2: #B8B0D4;\n            --text3: #7A7090;\n        }\n\n        .font-sans { font-family: 'Inter', sans-serif; }\n\n        .gradient-primary {\n            background: linear-gradient(135deg, #F5A87B, #F0607A, #8B65C8, #4ABFB8);\n        }\n\n        .gradient-cta {\n            background: linear-gradient(135deg, #F0607A, #8B65C8);\n        }\n\n        .gradient-text {\n            background: linear-gradient(135deg, #F5A87B, #F0607A, #8B65C8, #4ABFB8);\n            -webkit-background-clip: text;\n            -webkit-text-fill-color: transparent;\n        }\n\n        .glass {\n            background: rgba(26, 18, 40, 0.4);\n            backdrop-filter: blur(12px);\n            -webkit-backdrop-filter: blur(12px);\n            border: 1px solid rgba(255, 255, 255, 0.08);\n        }\n\n        .glass-card {\n            background: rgba(26, 18, 40, 0.5);\n            backdrop-filter: blur(8px);\n            -webkit-backdrop-filter: blur(8px);\n            border: 1px solid rgba(255, 255, 255, 0.05);\n            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);\n        }\n\n        .glass-card:hover {\n            border-color: rgba(139, 101, 200, 0.3);\n            background: rgba(30, 22, 45, 0.6);\n            transform: translateY(-4px);\n        }\n\n        .hero-glow {\n            position: absolute;\n            width: 1000px;\n            height: 1000px;\n            background: radial-gradient(circle, rgba(139,101,200,0.12) 0%, rgba(15,10,26,0) 75%);\n            filter: blur(120px);\n            pointer-events: none;\n            z-index: 0;\n        }\n\n        .animate-pulse-teal {\n            animation: pulse-teal 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;\n        }\n\n        @keyframes pulse-teal {\n            0%, 100% { opacity: 1; transform: scale(1); }\n            50% { opacity: .5; transform: scale(1.1); }\n        }\n\n        .ticker-scroll {\n            display: flex;\n            animation: ticker 30s linear infinite;\n            width: max-content;\n        }\n\n        @keyframes ticker {\n            0% { transform: translateX(0); }\n            100% { transform: translateX(-50%); }\n        }\n\n        .accordion-content {\n            max-height: 0;\n            overflow: hidden;\n            transition: max-height 0.3s ease-out, padding 0.3s ease;\n        }\n\n        .accordion-item.active .accordion-content {\n            max-height: 200px;\n            padding-top: 1rem;\n        }\n\n        .accordion-item.active .ti-plus {\n            transform: rotate(45deg);\n        }\n\n        /* Custom Scrollbar */\n        ::-webkit-scrollbar {\n            width: 6px;\n        }\n        ::-webkit-scrollbar-track {\n            background: #0F0A1A;\n        }\n        ::-webkit-scrollbar-thumb {\n            background: #241B35;\n            border-radius: 10px;\n        }\n        ::-webkit-scrollbar-thumb:hover {\n            background: #8B65C8;\n        }\n\n        .voice-bar {\n            width: 4px;\n            background: #8B65C8;\n            border-radius: 99px;\n            animation: voice-wave 1.2s infinite ease-in-out;\n        }\n        @keyframes voice-wave {\n            0%, 100% { height: 12px; }\n            50% { height: 48px; }\n        }\n    </style>\n\n    \n    <nav class=\"absolute top-0 left-0 right-0 z-[100] glass px-6 py-4\" data-kid=\"2\">\n        <div class=\"max-w-[1280px] mx-auto flex items-center justify-between\" data-kid=\"3\">\n            <div class=\"flex items-center gap-2\" data-kid=\"4\">\n                <div class=\"w-8 h-8 rounded-lg overflow-hidden flex items-center justify-center bg-gradient-to-br from-[#F5A87B] via-[#F0607A] to-[#8B65C8]\" data-kid=\"5\">\n                     <img src=\"/api/local/images/assets/logo.png\" alt=\"TaskMate AI Logo\" class=\"w-6 h-6 invert brightness-200\" decoding=\"async\" loading=\"lazy\" data-kid=\"6\">\n                </div>\n                <span class=\"text-[18px] font-bold tracking-tight\" data-kid=\"7\">TaskMate AI</span>\n            </div>\n\n            <div class=\"hidden md:flex items-center gap-8 text-[14px] font-medium text-[#B8B0D4]\" data-kid=\"8\">\n                <a href=\"#\" class=\"hover:text-[#F0EEF8] transition-colors\" data-kid=\"9\">Features</a>\n                <a href=\"#\" class=\"hover:text-[#F0EEF8] transition-colors\" data-kid=\"10\">How it works</a>\n                <a href=\"#\" class=\"hover:text-[#F0EEF8] transition-colors\" data-kid=\"11\">Pricing</a>\n                <a href=\"#\" class=\"hover:text-[#F0EEF8] transition-colors\" data-kid=\"12\">FAQ</a>\n            </div>\n\n            <div class=\"flex items-center gap-4\" data-kid=\"13\">\n                <button class=\"text-[14px] font-semibold text-[#B8B0D4] hover:text-[#F0EEF8] transition-colors\" data-kid=\"14\">Sign in</button>\n                <button class=\"px-5 py-2.5 rounded-full bg-gradient-to-r from-[#F0607A] to-[#8B65C8] text-[14px] font-semibold text-white shadow-[0_0_20px_-5px_rgba(240,96,122,0.4)] hover:scale-[1.05] transition-all\" data-kid=\"15\">\n                    Download Free →\n                </button>\n            </div>\n        </div>\n    </nav>\n\n    \n    <section class=\"min-h-[900px] pt-40 pb-20 relative flex flex-col items-center justify-center px-6 overflow-hidden\" data-kid=\"16\">\n        <div class=\"hero-glow top-[-10%] left-[-10%] bg-[#8B65C8]/20!\" data-kid=\"17\"></div>\n        <div class=\"hero-glow bottom-[10%] right-[-10%] bg-[#4ABFB8]/15!\" data-kid=\"18\"></div>\n        <div class=\"hero-glow top-[40%] right-[-20%] bg-[#F0607A]/10! w-[400px] h-[400px]\" data-kid=\"19\"></div>\n        \n        <div class=\"relative z-10 flex flex-col items-center text-center max-w-4xl mx-auto mb-16 opacity-100 transition-all duration-700\" data-kid=\"20\">\n            <div class=\"inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-[#1A1228] border border-white/10 mb-10\" data-kid=\"21\">\n                <span class=\"w-2 h-2 rounded-full bg-[#4ABFB8] animate-pulse-teal\" data-kid=\"22\"></span>\n                <span class=\"text-[12px] font-semibold uppercase tracking-widest text-[#4ABFB8]\" data-kid=\"23\">AI-Powered Task Intelligence · v1.7.0</span>\n            </div>\n\n            <h1 class=\"text-[72px] leading-[1.1] font-[800] tracking-[-0.03em] mb-8 select-none\" data-kid=\"24\">\n                Plan smarter.<br data-kid=\"25\">\n                <span class=\"gradient-text\" data-kid=\"26\">Live better.</span>\n            </h1>\n\n            <p class=\"text-[#B8B0D4] text-[18px] leading-[1.7] max-w-2xl mb-12\" data-kid=\"27\">\n                TaskMate AI turns your scattered to-dos into a focused, intelligent workflow. Voice input, smart reminders, and AI suggestions — all in one beautiful app.\n            </p>\n\n            <div class=\"flex flex-col sm:flex-row items-center gap-6 mb-20\" data-kid=\"28\">\n                <button class=\"w-full sm:w-auto px-12 py-5 rounded-full bg-gradient-to-r from-[#F0607A] to-[#8B65C8] font-bold text-white shadow-[0_20px_50px_-15px_rgba(240,96,122,0.6)] hover:scale-[1.05] active:scale-[0.98] transition-all cursor-pointer\" data-kid=\"29\">\n                    Get Started Free\n                </button>\n                <button class=\"w-full sm:w-auto px-12 py-5 rounded-full border border-white/10 bg-white/5 font-bold hover:bg-white/10 active:scale-[0.98] transition-all flex items-center justify-center gap-2 cursor-pointer\" data-kid=\"30\">\n                    <i class=\"ti ti-player-play-filled\" data-kid=\"31\"></i> Watch Demo\n                </button>\n            </div>\n\n            <div class=\"flex items-center gap-8 opacity-60 grayscale hover:grayscale-0 transition-all\" data-kid=\"32\">\n                <img src=\"https://upload.wikimedia.org/wikipedia/commons/7/78/Google_Play_Store_badge_EN.svg\" alt=\"Google Play\" class=\"h-10\" decoding=\"async\" loading=\"lazy\" data-kid=\"33\">\n                <span class=\"text-xs font-semibold tracking-wider text-[#7A7090] uppercase\" data-kid=\"34\">App Store Coming Soon</span>\n            </div>\n        </div>\n\n        \n        <div class=\"w-full max-w-[1100px] mx-auto relative perspective-[2000px]\" data-kid=\"35\">\n            <div class=\"rounded-2xl overflow-hidden border border-white/10 shadow-2xl bg-[#1A1228] transform rotate-x-[5deg] transition-all duration-1000 hover:rotate-x-0\" data-kid=\"36\">\n                <div class=\"bg-[#241B35] px-6 py-3 flex items-center justify-between border-b border-white/5\" data-kid=\"37\">\n                    <div class=\"flex gap-2\" data-kid=\"38\">\n                        <div class=\"w-3 h-3 rounded-full bg-[#F0607A]\" data-kid=\"39\"></div>\n                        <div class=\"w-3 h-3 rounded-full bg-[#F5A87B]\" data-kid=\"40\"></div>\n                        <div class=\"w-3 h-3 rounded-full bg-[#4ABFB8]\" data-kid=\"41\"></div>\n                    </div>\n                    <div class=\"bg-[#0F0A1A] px-4 py-1 rounded-lg text-[11px] text-[#7A7090] border border-white/5\" data-kid=\"42\">taskmate.ai/dashboard</div>\n                    <div class=\"w-16\" data-kid=\"43\"></div>\n                </div>\n                <img src=\"/api/local/images/assets/dashboardDark.png\" alt=\"TaskMate Dashboard\" class=\"w-full h-auto\" decoding=\"async\" loading=\"lazy\" data-kid=\"44\">\n            </div>\n        </div>\n    </section>\n\n    \n    <div class=\"py-12 border-y border-white/5 bg-[#1A1228]/30 overflow-hidden\" data-kid=\"45\">\n        <div class=\"ticker-scroll\" data-kid=\"46\">\n            \n            <div class=\"flex items-center gap-24 px-12\" data-kid=\"47\">\n                <div class=\"flex flex-col\" data-kid=\"48\">\n                    <span class=\"text-[32px] font-bold gradient-text\" data-kid=\"49\">1.2K+</span>\n                    <span class=\"text-[13px] font-medium text-[#7A7090] uppercase tracking-widest\" data-kid=\"50\">Active Users</span>\n                </div>\n                <div class=\"flex flex-col\" data-kid=\"51\">\n                    <span class=\"text-[32px] font-bold gradient-text\" data-kid=\"52\">4.8★</span>\n                    <span class=\"text-[13px] font-medium text-[#7A7090] uppercase tracking-widest\" data-kid=\"53\">Play Store</span>\n                </div>\n                <div class=\"flex flex-col\" data-kid=\"54\">\n                    <span class=\"text-[32px] font-bold gradient-text\" data-kid=\"55\">6</span>\n                    <span class=\"text-[13px] font-medium text-[#7A7090] uppercase tracking-widest\" data-kid=\"56\">Languages</span>\n                </div>\n                <div class=\"flex flex-col\" data-kid=\"57\">\n                    <span class=\"text-[32px] font-bold gradient-text\" data-kid=\"58\">Free</span>\n                    <span class=\"text-[13px] font-medium text-[#7A7090] uppercase tracking-widest\" data-kid=\"59\">No Hidden Costs</span>\n                </div>\n            </div>\n            <div class=\"flex items-center gap-24 px-12\" data-kid=\"60\">\n                <div class=\"flex flex-col\" data-kid=\"61\">\n                    <span class=\"text-[32px] font-bold gradient-text\" data-kid=\"62\">1.2K+</span>\n                    <span class=\"text-[13px] font-medium text-[#7A7090] uppercase tracking-widest\" data-kid=\"63\">Active Users</span>\n                </div>\n                <div class=\"flex flex-col\" data-kid=\"64\">\n                    <span class=\"text-[32px] font-bold gradient-text\" data-kid=\"65\">4.8★</span>\n                    <span class=\"text-[13px] font-medium text-[#7A7090] uppercase tracking-widest\" data-kid=\"66\">Play Store</span>\n                </div>\n                <div class=\"flex flex-col\" data-kid=\"67\">\n                    <span class=\"text-[32px] font-bold gradient-text\" data-kid=\"68\">6</span>\n                    <span class=\"text-[13px] font-medium text-[#7A7090] uppercase tracking-widest\" data-kid=\"69\">Languages</span>\n                </div>\n                <div class=\"flex flex-col\" data-kid=\"70\">\n                    <span class=\"text-[32px] font-bold gradient-text\" data-kid=\"71\">Free</span>\n                    <span class=\"text-[13px] font-medium text-[#7A7090] uppercase tracking-widest\" data-kid=\"72\">No Hidden Costs</span>\n                </div>\n            </div>\n        </div>\n    </div>\n\n    \n    <section id=\"features\" class=\"py-32 px-6\" data-kid=\"73\">\n        <div class=\"max-w-[1100px] mx-auto\" data-kid=\"74\">\n            <div class=\"text-center mb-20\" data-kid=\"75\">\n                <span class=\"text-[12px] font-semibold tracking-[0.2em] text-[#4ABFB8] uppercase mb-4 block\" data-kid=\"76\">Core Features</span>\n                <h2 class=\"text-[44px] leading-[1.2] font-[700] tracking-tight\" data-kid=\"77\">Everything you need to stay ahead</h2>\n            </div>\n\n            <div class=\"grid grid-cols-1 md:grid-cols-3 gap-px bg-white/10 p-px rounded-[32px] overflow-hidden shadow-2xl\" data-kid=\"78\">\n                \n                <div class=\"bg-[#1A1228] p-10 hover:bg-[#1f162e] transition-all group relative overflow-hidden\" data-kid=\"79\">\n                    <div class=\"absolute -top-10 -right-10 w-32 h-32 bg-[#8B65C8]/5 blur-3xl group-hover:bg-[#8B65C8]/10 transition-all\" data-kid=\"80\"></div>\n                    <div class=\"w-14 h-14 rounded-2xl bg-[#8B65C8]/10 flex items-center justify-center mb-8 group-hover:bg-[#8B65C8]/20 transition-all\" data-kid=\"81\">\n                        <i class=\"ti ti-microphone text-[28px] text-[#8B65C8]\" data-kid=\"82\"></i>\n                    </div>\n                    <h3 class=\"text-[22px] font-bold mb-4\" data-kid=\"83\">Voice to Task</h3>\n                    <p class=\"text-[#B8B0D4] leading-relaxed text-[15px]\" data-kid=\"84\">Convert speech to structured, prioritized tasks instantly with neural natural language processing.</p>\n                </div>\n                \n                <div class=\"bg-[#1A1228] p-10 hover:bg-[#1f162e] transition-all group relative overflow-hidden\" data-kid=\"85\">\n                    <div class=\"absolute -top-10 -right-10 w-32 h-32 bg-[#F0607A]/5 blur-3xl group-hover:bg-[#F0607A]/10 transition-all\" data-kid=\"86\"></div>\n                    <div class=\"w-14 h-14 rounded-2xl bg-[#F0607A]/10 flex items-center justify-center mb-8 group-hover:bg-[#F0607A]/20 transition-all\" data-kid=\"87\">\n                        <i class=\"ti ti-sparkles text-[28px] text-[#F0607A]\" data-kid=\"88\"></i>\n                    </div>\n                    <h3 class=\"text-[22px] font-bold mb-4\" data-kid=\"89\">AI Smart Suggestions</h3>\n                    <p class=\"text-[#B8B0D4] leading-relaxed text-[15px]\" data-kid=\"90\">TaskMate learns your routines and surfaces forgotten tasks exactly when you need them.</p>\n                </div>\n                \n                <div class=\"bg-[#1A1228] p-10 hover:bg-[#1f162e] transition-all group\" data-kid=\"91\">\n                    <div class=\"w-14 h-14 rounded-2xl bg-[#4ABFB8]/10 flex items-center justify-center mb-8 group-hover:bg-[#4ABFB8]/20 transition-all\" data-kid=\"92\">\n                        <i class=\"ti ti-bell-ringing text-[28px] text-[#4ABFB8]\" data-kid=\"93\"></i>\n                    </div>\n                    <h3 class=\"text-[22px] font-bold mb-4\" data-kid=\"94\">Smart Reminders</h3>\n                    <p class=\"text-[#B8B0D4] leading-relaxed text-[15px]\" data-kid=\"95\">Context-aware notifications that adapt to your location and current device activity.</p>\n                </div>\n                \n                <div class=\"bg-[#1A1228] p-10 hover:bg-[#1f162e] transition-all group\" data-kid=\"96\">\n                    <div class=\"w-14 h-14 rounded-2xl bg-[#F5A87B]/10 flex items-center justify-center mb-8 group-hover:bg-[#F5A87B]/20 transition-all\" data-kid=\"97\">\n                        <i class=\"ti ti-calendar-event text-[28px] text-[#F5A87B]\" data-kid=\"98\"></i>\n                    </div>\n                    <h3 class=\"text-[22px] font-bold mb-4\" data-kid=\"99\">Calendar Sync</h3>\n                    <p class=\"text-[#B8B0D4] leading-relaxed text-[15px]\" data-kid=\"100\">Seamless two-way sync with Google Calendar. Changes reflect everywhere instantly.</p>\n                </div>\n                \n                <div class=\"bg-[#1A1228] p-10 hover:bg-[#1f162e] transition-all group\" data-kid=\"101\">\n                    <div class=\"w-14 h-14 rounded-2xl bg-[#8B65C8]/10 flex items-center justify-center mb-8 group-hover:bg-[#8B65C8]/20 transition-all\" data-kid=\"102\">\n                        <i class=\"ti ti-target text-[28px] text-[#8B65C8]\" data-kid=\"103\"></i>\n                    </div>\n                    <h3 class=\"text-[22px] font-bold mb-4\" data-kid=\"104\">Focus Mode</h3>\n                    <p class=\"text-[#B8B0D4] leading-relaxed text-[15px]\" data-kid=\"105\">Three customizable Pomodoro modes with ambient soundscapes to keep you in flow.</p>\n                </div>\n                \n                <div class=\"bg-[#1A1228] p-10 hover:bg-[#1f162e] transition-all group\" data-kid=\"106\">\n                    <div class=\"w-14 h-14 rounded-2xl bg-[#4ABFB8]/10 flex items-center justify-center mb-8 group-hover:bg-[#4ABFB8]/20 transition-all\" data-kid=\"107\">\n                        <i class=\"ti ti-layout-grid text-[28px] text-[#4ABFB8]\" data-kid=\"108\"></i>\n                    </div>\n                    <h3 class=\"text-[22px] font-bold mb-4\" data-kid=\"109\">Home Screen Widgets</h3>\n                    <p class=\"text-[#B8B0D4] leading-relaxed text-[15px]\" data-kid=\"110\">Modern Android 14 widgets that let you manage tasks without even opening the app.</p>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    \n    <section id=\"how\" class=\"py-32 px-6 bg-[#1A1228]/20 relative overflow-hidden\" data-kid=\"111\">\n        <div class=\"max-w-[1100px] mx-auto grid grid-cols-1 lg:grid-cols-2 gap-20 items-center\" data-kid=\"112\">\n            <div data-kid=\"113\">\n                <span class=\"text-[12px] font-semibold tracking-[0.2em] text-[#F0607A] uppercase mb-4 block\" data-kid=\"114\">Process</span>\n                <h2 class=\"text-[44px] font-bold mb-10 leading-tight\" data-kid=\"115\">Your intelligent workflow, automated.</h2>\n                \n                <div class=\"space-y-8\" data-kid=\"116\">\n                    <div class=\"flex gap-6 p-6 rounded-2xl glass-card border-[#8B65C8]/30 bg-[#8B65C8]/5!\" data-kid=\"117\">\n                        <div class=\"shrink-0 w-12 h-12 rounded-full bg-gradient-to-r from-[#F0607A] to-[#8B65C8] flex items-center justify-center text-white font-bold text-lg shadow-lg\" data-kid=\"118\">1</div>\n                        <div data-kid=\"119\">\n                            <h3 class=\"text-[20px] font-semibold mb-2 text-white\" data-kid=\"120\">Add tasks by voice or type</h3>\n                            <p class=\"text-[#B8B0D4] leading-relaxed\" data-kid=\"121\">Just speak. Our AI understands \"Remind me to buy groceries after work tomorrow\" and sets it up perfectly.</p>\n                        </div>\n                    </div>\n                    <div class=\"flex gap-6 p-6 rounded-2xl glass-card opacity-60 hover:opacity-100!\" data-kid=\"122\">\n                        <div class=\"shrink-0 w-12 h-12 rounded-full bg-[#241B35] border border-white/10 flex items-center justify-center text-[#B8B0D4] font-bold text-lg\" data-kid=\"123\">2</div>\n                        <div data-kid=\"124\">\n                            <h3 class=\"text-[20px] font-semibold mb-2\" data-kid=\"125\">AI organizes your day</h3>\n                            <p class=\"text-[#B8B0D4] leading-relaxed\" data-kid=\"126\">TaskMate analyzes your priorities and deadlines to suggest the most efficient sequence of tasks.</p>\n                        </div>\n                    </div>\n                    <div class=\"flex gap-6 p-6 rounded-2xl glass-card opacity-60 hover:opacity-100!\" data-kid=\"127\">\n                        <div class=\"shrink-0 w-12 h-12 rounded-full bg-[#241B35] border border-white/10 flex items-center justify-center text-[#B8B0D4] font-bold text-lg\" data-kid=\"128\">3</div>\n                        <div data-kid=\"129\">\n                            <h3 class=\"text-[20px] font-semibold mb-2\" data-kid=\"130\">Focus, execute, track</h3>\n                            <p class=\"text-[#B8B0D4] leading-relaxed\" data-kid=\"131\">Use Focus Mode to eliminate distractions and watch your productivity streaks grow every day.</p>\n                        </div>\n                    </div>\n                </div>\n            </div>\n\n            \n            <div class=\"relative bg-[#1A1228] rounded-[40px] border border-white/10 p-12 overflow-hidden shadow-2xl\" data-kid=\"132\">\n                <div class=\"absolute inset-0 bg-gradient-to-br from-[#8B65C8]/5 via-transparent to-[#4ABFB8]/5\" data-kid=\"133\"></div>\n                \n                <div class=\"relative z-10 flex flex-col items-center\" data-kid=\"134\">\n                    \n                    <div class=\"flex items-center gap-2 mb-12 h-16\" data-kid=\"135\">\n                        <div class=\"voice-bar\" style=\"animation-delay: 0.1s\" data-kid=\"136\"></div>\n                        <div class=\"voice-bar\" style=\"animation-delay: 0.3s\" data-kid=\"137\"></div>\n                        <div class=\"voice-bar\" style=\"animation-delay: 0.5s\" data-kid=\"138\"></div>\n                        <div class=\"voice-bar\" style=\"animation-delay: 0.2s\" data-kid=\"139\"></div>\n                        <div class=\"voice-bar\" style=\"animation-delay: 0.4s\" data-kid=\"140\"></div>\n                        <div class=\"voice-bar\" style=\"animation-delay: 0.1s\" data-kid=\"141\"></div>\n                        <div class=\"voice-bar\" style=\"animation-delay: 0.3s\" data-kid=\"142\"></div>\n                    </div>\n\n                    <div class=\"w-full bg-[#241B35] rounded-3xl p-8 border border-white/5 shadow-xl\" data-kid=\"143\">\n                        <div class=\"flex items-center gap-3 mb-6\" data-kid=\"144\">\n                            <div class=\"w-2 h-2 rounded-full bg-[#F0607A] animate-pulse\" data-kid=\"145\"></div>\n                            <span class=\"text-[11px] font-bold uppercase tracking-widest text-[#B8B0D4]\" data-kid=\"146\">AI Listening...</span>\n                        </div>\n                        <p class=\"text-[19px] leading-relaxed font-medium italic text-white mb-8\" data-kid=\"147\">\n                            \"Remind me to finish the quarterly report by Friday 3 PM.\"\n                        </p>\n                        <div class=\"flex flex-wrap gap-2\" data-kid=\"148\">\n                            <span class=\"px-4 py-1.5 rounded-full bg-[#4ABFB8]/10 text-[#4ABFB8] text-[12px] font-semibold flex items-center gap-2\" data-kid=\"149\">\n                                <i class=\"ti ti-calendar-time\" data-kid=\"150\"></i> Friday 3:00 PM\n                            </span>\n                            <span class=\"px-4 py-1.5 rounded-full bg-[#F0607A]/10 text-[#F0607A] text-[12px] font-semibold flex items-center gap-2\" data-kid=\"151\">\n                                <i class=\"ti ti-alert-triangle\" data-kid=\"152\"></i> High Priority\n                            </span>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    \n    <section id=\"pricing\" class=\"py-32 px-6\" data-kid=\"153\">\n        <div class=\"max-w-[1100px] mx-auto\" data-kid=\"154\">\n            <div class=\"text-center mb-20\" data-kid=\"155\">\n                <span class=\"text-[12px] font-semibold tracking-[0.2em] text-[#8B65C8] uppercase mb-4 block\" data-kid=\"156\">Pricing</span>\n                <h2 class=\"text-[44px] font-bold\" data-kid=\"157\">Simple, transparent pricing</h2>\n            </div>\n\n            <div class=\"grid grid-cols-1 md:grid-cols-3 gap-8 items-end\" data-kid=\"158\">\n                \n                <div class=\"bg-[#1A1228] p-10 rounded-[32px] border border-white/5 hover:border-white/10 transition-all\" data-kid=\"159\">\n                    <h3 class=\"text-[20px] font-bold mb-2\" data-kid=\"160\">Free</h3>\n                    <div class=\"flex items-baseline gap-1 mb-8\" data-kid=\"161\">\n                        <span class=\"text-[40px] font-extrabold text-white\" data-kid=\"162\">₹0</span>\n                        <span class=\"text-[#7A7090]\" data-kid=\"163\">/ forever</span>\n                    </div>\n                    <ul class=\"space-y-4 mb-10 text-[15px] text-[#B8B0D4]\" data-kid=\"164\">\n                        <li class=\"flex items-center gap-3\" data-kid=\"165\"><i class=\"ti ti-check text-[#4ABFB8]\" data-kid=\"166\"></i> Unlimited tasks</li>\n                        <li class=\"flex items-center gap-3\" data-kid=\"167\"><i class=\"ti ti-check text-[#4ABFB8]\" data-kid=\"168\"></i> Voice input (basic)</li>\n                        <li class=\"flex items-center gap-3\" data-kid=\"169\"><i class=\"ti ti-check text-[#4ABFB8]\" data-kid=\"170\"></i> Smart reminders</li>\n                        <li class=\"flex items-center gap-3\" data-kid=\"171\"><i class=\"ti ti-check text-[#4ABFB8]\" data-kid=\"172\"></i> Android widgets</li>\n                        <li class=\"flex items-center gap-3 opacity-30\" data-kid=\"173\"><i class=\"ti ti-x text-[#7A7090]\" data-kid=\"174\"></i> AI suggestions</li>\n                        <li class=\"flex items-center gap-3 opacity-30\" data-kid=\"175\"><i class=\"ti ti-x text-[#7A7090]\" data-kid=\"176\"></i> Focus Pro</li>\n                    </ul>\n                    <button class=\"w-full py-4 rounded-full border border-white/10 font-bold hover:bg-white/5 transition-all\" data-kid=\"177\">Get Started</button>\n                </div>\n\n                \n                <div class=\"relative bg-[#1A1228] p-10 rounded-[32px] border-2 border-[#8B65C8] shadow-[0_0_50px_-10px_rgba(139,101,200,0.4)] transform md:scale-105 z-10\" data-kid=\"178\">\n                    <div class=\"absolute -top-4 left-1/2 -translate-x-1/2 px-4 py-1 rounded-full bg-[#8B65C8] text-white text-[11px] font-bold uppercase tracking-widest\" data-kid=\"179\">⭐ Most Popular</div>\n                    <h3 class=\"text-[20px] font-bold mb-2\" data-kid=\"180\">Pro</h3>\n                    <div class=\"flex items-baseline gap-1 mb-8\" data-kid=\"181\">\n                        <span class=\"text-[40px] font-extrabold text-white\" data-kid=\"182\">₹199</span>\n                        <span class=\"text-[#7A7090]\" data-kid=\"183\">/ month</span>\n                    </div>\n                    <ul class=\"space-y-4 mb-10 text-[15px] text-[#B8B0D4]\" data-kid=\"184\">\n                        <li class=\"flex items-center gap-3 font-medium text-white\" data-kid=\"185\"><i class=\"ti ti-check text-[#4ABFB8]\" data-kid=\"186\"></i> Everything in Free</li>\n                        <li class=\"flex items-center gap-3\" data-kid=\"187\"><i class=\"ti ti-check text-[#4ABFB8]\" data-kid=\"188\"></i> Full AI Suggestions</li>\n                        <li class=\"flex items-center gap-3\" data-kid=\"189\"><i class=\"ti ti-check text-[#4ABFB8]\" data-kid=\"190\"></i> Focus Mode Pro</li>\n                        <li class=\"flex items-center gap-3\" data-kid=\"191\"><i class=\"ti ti-check text-[#4ABFB8]\" data-kid=\"192\"></i> Advanced Analytics</li>\n                        <li class=\"flex items-center gap-3\" data-kid=\"193\"><i class=\"ti ti-check text-[#4ABFB8]\" data-kid=\"194\"></i> Calendar 2-way sync</li>\n                        <li class=\"flex items-center gap-3\" data-kid=\"195\"><i class=\"ti ti-check text-[#4ABFB8]\" data-kid=\"196\"></i> Multi-language support</li>\n                    </ul>\n                    <button class=\"w-full py-4 rounded-full bg-gradient-to-r from-[#F0607A] to-[#8B65C8] font-bold text-white shadow-xl hover:scale-[1.03] transition-all\" data-kid=\"197\">Get Pro →</button>\n                </div>\n\n                \n                <div class=\"bg-[#1A1228] p-10 rounded-[32px] border border-white/5 hover:border-white/10 transition-all\" data-kid=\"198\">\n                    <h3 class=\"text-[20px] font-bold mb-2\" data-kid=\"199\">Team</h3>\n                    <div class=\"flex items-baseline gap-1 mb-8\" data-kid=\"200\">\n                        <span class=\"text-[40px] font-extrabold text-white\" data-kid=\"201\">₹499</span>\n                        <span class=\"text-[#7A7090]\" data-kid=\"202\">/ user / month</span>\n                    </div>\n                    <ul class=\"space-y-4 mb-10 text-[15px] text-[#B8B0D4]\" data-kid=\"203\">\n                        <li class=\"flex items-center gap-3 font-medium text-white\" data-kid=\"204\"><i class=\"ti ti-check text-[#4ABFB8]\" data-kid=\"205\"></i> Everything in Pro</li>\n                        <li class=\"flex items-center gap-3\" data-kid=\"206\"><i class=\"ti ti-check text-[#4ABFB8]\" data-kid=\"207\"></i> Shared workspaces</li>\n                        <li class=\"flex items-center gap-3\" data-kid=\"208\"><i class=\"ti ti-check text-[#4ABFB8]\" data-kid=\"209\"></i> Team collaboration</li>\n                        <li class=\"flex items-center gap-3\" data-kid=\"210\"><i class=\"ti ti-check text-[#4ABFB8]\" data-kid=\"211\"></i> Admin controls</li>\n                        <li class=\"flex items-center gap-3\" data-kid=\"212\"><i class=\"ti ti-check text-[#4ABFB8]\" data-kid=\"213\"></i> Custom integrations</li>\n                    </ul>\n                    <button class=\"w-full py-4 rounded-full border border-white/10 font-bold hover:bg-white/5 transition-all\" data-kid=\"214\">Contact Sales</button>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    \n    <section class=\"py-32 px-6 bg-[#1A1228]/10\" data-kid=\"215\">\n        <div class=\"max-w-[1100px] mx-auto\" data-kid=\"216\">\n            <div class=\"text-center mb-20\" data-kid=\"217\">\n                <h2 class=\"text-[44px] font-bold\" data-kid=\"218\">Loved by productivity experts</h2>\n            </div>\n\n            <div class=\"columns-1 md:columns-2 lg:columns-3 gap-6 space-y-6\" data-kid=\"219\">\n                \n                <div class=\"break-inside-avoid bg-[#1A1228] p-8 rounded-2xl border border-white/5 hover:translate-y-[-4px] transition-all duration-300\" data-kid=\"220\">\n                    <div class=\"flex gap-1 text-[#F5A87B] mb-6\" data-kid=\"221\">\n                        <i class=\"ti ti-star-filled\" data-kid=\"222\"></i><i class=\"ti ti-star-filled\" data-kid=\"223\"></i><i class=\"ti ti-star-filled\" data-kid=\"224\"></i><i class=\"ti ti-star-filled\" data-kid=\"225\"></i><i class=\"ti ti-star-filled\" data-kid=\"226\"></i>\n                    </div>\n                    <p class=\"text-[#F0EEF8] leading-relaxed mb-8 italic\" data-kid=\"227\">\"TaskMate AI has completely changed how I manage my freelance projects. The voice input is scary accurate — it feels like having a real assistant.\"</p>\n                    <div class=\"flex items-center gap-4\" data-kid=\"228\">\n                        <div class=\"w-12 h-12 rounded-full bg-gradient-to-br from-[#F5A87B] to-[#F0607A] flex items-center justify-center font-bold text-white text-sm\" data-kid=\"229\">RS</div>\n                        <div data-kid=\"230\">\n                            <h4 class=\"font-bold\" data-kid=\"231\">Rahul Sharma</h4>\n                            <p class=\"text-[13px] text-[#7A7090]\" data-kid=\"232\">Product Designer, Bangalore</p>\n                        </div>\n                    </div>\n                </div>\n                \n                <div class=\"break-inside-avoid bg-[#1A1228] p-8 rounded-2xl border border-white/5 hover:translate-y-[-4px] transition-all duration-300\" data-kid=\"233\">\n                    <div class=\"flex gap-1 text-[#F5A87B] mb-6\" data-kid=\"234\">\n                        <i class=\"ti ti-star-filled\" data-kid=\"235\"></i><i class=\"ti ti-star-filled\" data-kid=\"236\"></i><i class=\"ti ti-star-filled\" data-kid=\"237\"></i><i class=\"ti ti-star-filled\" data-kid=\"238\"></i><i class=\"ti ti-star-filled\" data-kid=\"239\"></i>\n                    </div>\n                    <p class=\"text-[#F0EEF8] leading-relaxed mb-8 italic\" data-kid=\"240\">\"As a PM, my day is scattered. TaskMate's AI suggestions surface exactly what I need to focus on next. No more scrolling through endless lists.\"</p>\n                    <div class=\"flex items-center gap-4\" data-kid=\"241\">\n                        <div class=\"w-12 h-12 rounded-full bg-gradient-to-br from-[#8B65C8] to-[#4ABFB8] flex items-center justify-center font-bold text-white text-sm\" data-kid=\"242\">AM</div>\n                        <div data-kid=\"243\">\n                            <h4 class=\"font-bold\" data-kid=\"244\">Ananya Misra</h4>\n                            <p class=\"text-[13px] text-[#7A7090]\" data-kid=\"245\">Project Manager, Mumbai</p>\n                        </div>\n                    </div>\n                </div>\n                \n                <div class=\"break-inside-avoid bg-[#1A1228] p-8 rounded-2xl border border-white/5 hover:translate-y-[-4px] transition-all duration-300\" data-kid=\"246\">\n                    <div class=\"flex gap-1 text-[#F5A87B] mb-6\" data-kid=\"247\">\n                        <i class=\"ti ti-star-filled\" data-kid=\"248\"></i><i class=\"ti ti-star-filled\" data-kid=\"249\"></i><i class=\"ti ti-star-filled\" data-kid=\"250\"></i><i class=\"ti ti-star-filled\" data-kid=\"251\"></i><i class=\"ti ti-star-filled\" data-kid=\"252\"></i>\n                    </div>\n                    <p class=\"text-[#F0EEF8] leading-relaxed mb-8 italic\" data-kid=\"253\">\"Finally, a task manager that understands Android design language. The widgets are beautiful and actually functional.\"</p>\n                    <div class=\"flex items-center gap-4\" data-kid=\"254\">\n                        <div class=\"w-12 h-12 rounded-full bg-gradient-to-br from-[#F0607A] to-[#8B65C8] flex items-center justify-center font-bold text-white text-sm\" data-kid=\"255\">VK</div>\n                        <div data-kid=\"256\">\n                            <h4 class=\"font-bold\" data-kid=\"257\">Vikram Kapoor</h4>\n                            <p class=\"text-[13px] text-[#7A7090]\" data-kid=\"258\">Android Developer, Gurgaon</p>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    \n    <section id=\"faq\" class=\"py-32 px-6\" data-kid=\"259\">\n        <div class=\"max-w-[720px] mx-auto\" data-kid=\"260\">\n            <h2 class=\"text-[44px] font-bold text-center mb-16\" data-kid=\"261\">Frequently Asked Questions</h2>\n            \n            <div class=\"space-y-4\" data-kid=\"262\">\n                <div class=\"accordion-item border-b border-white/10 pb-4\" data-kid=\"263\">\n                    <button class=\"w-full flex items-center justify-between text-left py-4 focus:outline-hidden\" onclick=\"this.parentElement.classList.toggle('active')\" data-kid=\"264\">\n                        <span class=\"text-[18px] font-semibold\" data-kid=\"265\">Is TaskMate AI really free?</span>\n                        <i class=\"ti ti-plus transition-transform\" data-kid=\"266\"></i>\n                    </button>\n                    <div class=\"accordion-content\" data-kid=\"267\">\n                        <p class=\"text-[#B8B0D4] leading-relaxed\" data-kid=\"268\">Yes! Our basic plan is free forever and includes unlimited tasks, voice input, and reminders. We only charge for premium AI features and team collaboration.</p>\n                    </div>\n                </div>\n                <div class=\"accordion-item border-b border-white/10 pb-4\" data-kid=\"269\">\n                    <button class=\"w-full flex items-center justify-between text-left py-4 focus:outline-hidden\" onclick=\"this.parentElement.classList.toggle('active')\" data-kid=\"270\">\n                        <span class=\"text-[18px] font-semibold\" data-kid=\"271\">Which platforms is it available on?</span>\n                        <i class=\"ti ti-plus transition-transform\" data-kid=\"272\"></i>\n                    </button>\n                    <div class=\"accordion-content\" data-kid=\"273\">\n                        <p class=\"text-[#B8B0D4] leading-relaxed\" data-kid=\"274\">Currently, we are natively available on Android. iOS and Web versions are in active development and will be launching soon.</p>\n                    </div>\n                </div>\n                <div class=\"accordion-item border-b border-white/10 pb-4\" data-kid=\"275\">\n                    <button class=\"w-full flex items-center justify-between text-left py-4 focus:outline-hidden\" onclick=\"this.parentElement.classList.toggle('active')\" data-kid=\"276\">\n                        <span class=\"text-[18px] font-semibold\" data-kid=\"277\">How does the AI suggestion engine work?</span>\n                        <i class=\"ti ti-plus transition-transform\" data-kid=\"278\"></i>\n                    </button>\n                    <div class=\"accordion-content\" data-kid=\"279\">\n                        <p class=\"text-[#B8B0D4] leading-relaxed\" data-kid=\"280\">TaskMate uses local neural models to analyze your historical task completion patterns, deadlines, and current focus hours to surface the most relevant tasks.</p>\n                    </div>\n                </div>\n                <div class=\"accordion-item border-b border-white/10 pb-4\" data-kid=\"281\">\n                    <button class=\"w-full flex items-center justify-between text-left py-4 focus:outline-hidden\" onclick=\"this.parentElement.classList.toggle('active')\" data-kid=\"282\">\n                        <span class=\"text-[18px] font-semibold\" data-kid=\"283\">Can I use TaskMate offline?</span>\n                        <i class=\"ti ti-plus transition-transform\" data-kid=\"284\"></i>\n                    </button>\n                    <div class=\"accordion-content\" data-kid=\"285\">\n                        <p class=\"text-[#B8B0D4] leading-relaxed\" data-kid=\"286\">Absolutely. All your tasks are stored locally first. Changes will sync to the cloud automatically once you're back online.</p>\n                    </div>\n                </div>\n                <div class=\"accordion-item border-b border-white/10 pb-4\" data-kid=\"287\">\n                    <button class=\"w-full flex items-center justify-between text-left py-4 focus:outline-hidden\" onclick=\"this.parentElement.classList.toggle('active')\" data-kid=\"288\">\n                        <span class=\"text-[18px] font-semibold\" data-kid=\"289\">Is team collaboration available now?</span>\n                        <i class=\"ti ti-plus transition-transform\" data-kid=\"290\"></i>\n                    </button>\n                    <div class=\"accordion-content\" data-kid=\"291\">\n                        <p class=\"text-[#B8B0D4] leading-relaxed\" data-kid=\"292\">Yes, Team workspaces are available under the Team plan. You can share projects, assign tasks, and track group progress in real-time.</p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    \n    <section class=\"py-40 px-6 relative overflow-hidden\" data-kid=\"293\">\n        <div class=\"absolute inset-0 bg-gradient-to-tr from-[#8B65C8]/30 via-[#F0607A]/10 to-[#4ABFB8]/10!\" data-kid=\"294\"></div>\n        <div class=\"absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-transparent via-white/10 to-transparent\" data-kid=\"295\"></div>\n        <div class=\"max-w-[1100px] mx-auto text-center relative z-10\" data-kid=\"296\">\n            <h2 class=\"text-[56px] font-extrabold mb-8 leading-tight\" data-kid=\"297\">Ready to plan smarter?</h2>\n            <p class=\"text-[20px] text-[#B8B0D4] max-w-2xl mx-auto mb-12\" data-kid=\"298\">\n                Join 1,200+ users who transformed their productivity with TaskMate AI. Download now and take back control of your time.\n            </p>\n            <div class=\"flex flex-col sm:flex-row items-center justify-center gap-6\" data-kid=\"299\">\n                <button class=\"px-10 py-5 rounded-full bg-gradient-to-r from-[#F0607A] to-[#8B65C8] font-bold text-white shadow-2xl hover:scale-[1.05] transition-all flex items-center gap-3\" data-kid=\"300\">\n                    Download Free on Android <i class=\"ti ti-brand-android text-2xl\" data-kid=\"301\"></i>\n                </button>\n                <button class=\"px-10 py-5 rounded-full border border-white/10 bg-white/5 font-bold hover:bg-white/10 transition-all flex items-center gap-3\" data-kid=\"302\">\n                    View on Product Hunt <i class=\"ti ti-brand-producthunt text-2xl\" data-kid=\"303\"></i>\n                </button>\n            </div>\n        </div>\n    </section>\n\n    \n    <footer class=\"py-20 px-6 border-t border-white/5\" data-kid=\"304\">\n        <div class=\"max-w-[1100px] mx-auto\" data-kid=\"305\">\n            <div class=\"grid grid-cols-1 md:grid-cols-4 gap-12 mb-20\" data-kid=\"306\">\n                <div class=\"col-span-1 md:col-span-1\" data-kid=\"307\">\n                    <div class=\"flex items-center gap-3 mb-6\" data-kid=\"308\">\n                        <div class=\"w-10 h-10 rounded-xl bg-gradient-to-br from-[#F5A87B] via-[#F0607A] to-[#8B65C8] flex items-center justify-center p-1.5 shadow-lg\" data-kid=\"309\">\n                            <img src=\"/api/local/images/assets/logo.png\" alt=\"TaskMate AI Logo\" class=\"w-full h-full invert brightness-200\" decoding=\"async\" loading=\"lazy\" data-kid=\"310\">\n                        </div>\n                        <span class=\"text-[22px] font-bold tracking-tight\" data-kid=\"311\">TaskMate AI</span>\n                    </div>\n                    <p class=\"text-[#7A7090] text-[14px] leading-relaxed mb-6\" data-kid=\"312\">\n                        Plan smarter. Live better. The next generation of task management powered by AI.\n                    </p>\n                    <p class=\"text-[#7A7090] text-[13px] flex items-center gap-1\" data-kid=\"313\">\n                        Made with <i class=\"ti ti-heart-filled text-[#F0607A]\" data-kid=\"314\"></i> in Ahmedabad 🇮🇳\n                    </p>\n                </div>\n                \n                <div data-kid=\"315\">\n                    <h5 class=\"text-white font-bold mb-6\" data-kid=\"316\">Product</h5>\n                    <ul class=\"space-y-4 text-[14px] text-[#7A7090]\" data-kid=\"317\">\n                        <li data-kid=\"318\"><a href=\"#\" class=\"hover:text-[#4ABFB8] transition-colors\" data-kid=\"319\">Features</a></li>\n                        <li data-kid=\"320\"><a href=\"#\" class=\"hover:text-[#4ABFB8] transition-colors\" data-kid=\"321\">How it works</a></li>\n                        <li data-kid=\"322\"><a href=\"#\" class=\"hover:text-[#4ABFB8] transition-colors\" data-kid=\"323\">Pricing</a></li>\n                        <li data-kid=\"324\"><a href=\"#\" class=\"hover:text-[#4ABFB8] transition-colors\" data-kid=\"325\">Release Notes</a></li>\n                    </ul>\n                </div>\n\n                <div data-kid=\"326\">\n                    <h5 class=\"text-white font-bold mb-6\" data-kid=\"327\">Company</h5>\n                    <ul class=\"space-y-4 text-[14px] text-[#7A7090]\" data-kid=\"328\">\n                        <li data-kid=\"329\"><a href=\"#\" class=\"hover:text-[#4ABFB8] transition-colors\" data-kid=\"330\">About Us</a></li>\n                        <li data-kid=\"331\"><a href=\"#\" class=\"hover:text-[#4ABFB8] transition-colors\" data-kid=\"332\">Careers</a></li>\n                        <li data-kid=\"333\"><a href=\"#\" class=\"hover:text-[#4ABFB8] transition-colors\" data-kid=\"334\">Press Kit</a></li>\n                        <li data-kid=\"335\"><a href=\"#\" class=\"hover:text-[#4ABFB8] transition-colors\" data-kid=\"336\">Contact</a></li>\n                    </ul>\n                </div>\n\n                <div data-kid=\"337\">\n                    <h5 class=\"text-white font-bold mb-6\" data-kid=\"338\">Legal</h5>\n                    <ul class=\"space-y-4 text-[14px] text-[#7A7090]\" data-kid=\"339\">\n                        <li data-kid=\"340\"><a href=\"#\" class=\"hover:text-[#4ABFB8] transition-colors\" data-kid=\"341\">Privacy Policy</a></li>\n                        <li data-kid=\"342\"><a href=\"#\" class=\"hover:text-[#4ABFB8] transition-colors\" data-kid=\"343\">Terms of Service</a></li>\n                        <li data-kid=\"344\"><a href=\"#\" class=\"hover:text-[#4ABFB8] transition-colors\" data-kid=\"345\">Cookie Policy</a></li>\n                    </ul>\n                </div>\n            </div>\n\n            <div class=\"pt-8 border-t border-white/5 flex flex-col md:flex-row justify-between items-center gap-6\" data-kid=\"346\">\n                <p class=\"text-[13px] text-[#7A7090]\" data-kid=\"347\">© 2024 TaskMate AI. Built by CK Future Tech.</p>\n                <div class=\"flex gap-6\" data-kid=\"348\">\n                    <a href=\"#\" class=\"text-[#7A7090] hover:text-white transition-colors\" data-kid=\"349\"><i class=\"ti ti-brand-twitter text-xl\" data-kid=\"350\"></i></a>\n                    <a href=\"#\" class=\"text-[#7A7090] hover:text-white transition-colors\" data-kid=\"351\"><i class=\"ti ti-brand-linkedin text-xl\" data-kid=\"352\"></i></a>\n                    <a href=\"#\" class=\"text-[#7A7090] hover:text-white transition-colors\" data-kid=\"353\"><i class=\"ti ti-brand-github text-xl\" data-kid=\"354\"></i></a>\n                </div>\n            </div>\n        </div>\n    </footer>\n\n</div>\n",
