      "html": "\n<style data-kid=\"0\">\n    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Instrument+Sans:wght@400;500;600;700&display=swap');\n\n    :root {\n        --obsidian: #05050A;\n        --charcoal: #111116;\n        --violet: #8A2BE2;\n        --violet-glow: rgba(138, 43, 226, 0.4);\n    }\n\n    body {\n        background-color: var(--obsidian);\n        color: #FFFFFF;\n        font-family: 'Inter', sans-serif;\n        overflow-x: clip;\n    }\n\n    .font-heading {\n        font-family: 'Instrument Sans', sans-serif;\n        letter-spacing: -0.04em;\n    }\n\n    .glass {\n        background: rgba(255, 255, 255, 0.03);\n        backdrop-filter: blur(12px);\n        border: 1px solid rgba(255, 255, 255, 0.1);\n    }\n\n    .glass-violet {\n        background: rgba(138, 43, 226, 0.05);\n        backdrop-filter: blur(12px);\n        border: 1px solid rgba(138, 43, 226, 0.2);\n    }\n\n    .aurora-blur {\n        filter: blur(120px);\n        opacity: 0.6;\n        pointer-events: none;\n    }\n\n    .neon-border {\n        border: 1.5px solid var(--violet);\n        box-shadow: 0 0 20px var(--violet-glow), inset 0 0 10px var(--violet-glow);\n    }\n\n    .aurora-text {\n        background: linear-gradient(135deg, #fff 0%, var(--violet) 50%, #4f46e5 100%);\n        -webkit-background-clip: text;\n        -webkit-text-fill-color: transparent;\n        background-size: 200% auto;\n    }\n\n    /* SplitType initial state to prevent flash */\n    .split-text {\n        opacity: 1;\n    }\n    \n    .char {\n        display: inline-block;\n    }\n\n    /* Lenis required CSS */\n    html.lenis {\n        height: auto;\n    }\n    .lenis.lenis-smooth {\n        scroll-behavior: auto !important;\n    }\n    .lenis.lenis-smooth [data-lenis-prevent] {\n        overscroll-behavior: contain;\n    }\n    .lenis.lenis-stopped {\n        overflow: hidden;\n    }\n\n    .cursor-glow {\n        position: fixed;\n        top: 0;\n        left: 0;\n        width: 400px;\n        height: 400px;\n        background: radial-gradient(circle, rgba(138, 43, 226, 0.15) 0%, transparent 70%);\n        pointer-events: none;\n        z-index: 9999;\n        transform: translate(-50%, -50%);\n        border-radius: 50%;\n    }\n</style>\n<link rel=\"stylesheet\" href=\"https://unpkg.com/lenis@1/dist/lenis.css\" data-kid=\"1\">\n<link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css\" data-kid=\"2\">\n\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"3\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"4\"></script>\n<script src=\"https://unpkg.com/split-type\" data-kid=\"5\"></script>\n<script type=\"module\" data-kid=\"6\">\n    import Lenis from \"https://esm.sh/lenis@1\"\n    const lenis = new Lenis()\n    function raf(time) {\n        lenis.raf(time)\n        requestAnimationFrame(raf)\n    }\n    requestAnimationFrame(raf)\n    window.lenis = lenis;\n</script>\n\n<div class=\"relative w-full overflow-x-clip\" data-kid=\"7\">\n    <div class=\"cursor-glow\" id=\"cursor-glow\" data-kid=\"8\"></div>\n    \n    \n    <section id=\"hero\" class=\"relative min-h-[120vh] flex flex-col items-center justify-center text-center px-6 overflow-hidden\" data-kid=\"9\">\n        \n        <div class=\"absolute inset-0 z-0\" data-kid=\"10\">\n            <video src=\"https://videos.pexels.com/video-files/15432034/15432034-uhd_3840_2160_50fps.mp4\" poster=\"https://images.pexels.com/videos/15432034/abstract-acrylic-art-artist-15432034.jpeg?auto=compress&cs=tinysrgb&fit=crop&h=630&w=1200\" autoplay muted loop playsinline class=\"w-full h-full object-cover opacity-30 scale-110 blur-3xl\" data-kid=\"11\"></video>\n            <div class=\"absolute inset-0 bg-gradient-to-b from-transparent via-[var(--obsidian)]/80 to-[var(--obsidian)]\" data-kid=\"12\"></div>\n        </div>\n\n        \n        <div class=\"absolute top-1/4 -left-1/4 w-[600px] h-[600px] bg-[var(--violet)] rounded-full aurora-blur animate-pulse\" data-kid=\"13\"></div>\n        <div class=\"absolute bottom-1/4 -right-1/4 w-[500px] h-[500px] bg-blue-600 rounded-full aurora-blur\" style=\"animation-delay: 2s;\" data-kid=\"14\"></div>\n\n        <div class=\"relative z-10 max-w-5xl\" data-kid=\"15\">\n            <div id=\"hero-logo\" class=\"mb-12 inline-flex items-center justify-center w-20 h-20 rounded-2xl bg-gradient-to-tr from-[var(--violet)] to-purple-400 p-[2px]\" data-kid=\"16\">\n                <div class=\"w-full h-full rounded-2xl bg-[var(--obsidian)] flex items-center justify-center\" data-kid=\"17\">\n                    <i class=\"ti ti-sparkles text-4xl text-[var(--violet)]\" data-kid=\"18\"></i>\n                </div>\n            </div>\n            \n            <h1 class=\"font-heading text-6xl md:text-[10rem] font-bold tracking-tighter mb-8 leading-none\" id=\"hero-title\" data-kid=\"19\">\n                Turn Chaos <br class=\"hidden md:block\" data-kid=\"20\"> Into <span class=\"aurora-text\" data-kid=\"21\">Clarity</span>\n            </h1>\n            \n            <p class=\"text-lg md:text-xl text-gray-500 mb-12 max-w-xl mx-auto font-medium tracking-tight\" id=\"hero-subtitle\" data-kid=\"22\">\n                The next evolution of task management. <br data-kid=\"23\"> Powered by AI that understands your world.\n            </p>\n\n            <div class=\"flex flex-col sm:flex-row items-center justify-center gap-6\" id=\"hero-ctas\" data-kid=\"24\">\n                <button class=\"group relative px-10 py-5 bg-[var(--violet)] rounded-2xl font-bold text-lg overflow-hidden\" data-kid=\"25\">\n                    <span class=\"relative z-10 flex items-center gap-2\" data-kid=\"26\">\n                        Reserve Access <i class=\"ti ti-arrow-right\" data-kid=\"27\"></i>\n                    </span>\n                </button>\n                <button class=\"px-10 py-5 rounded-2xl border border-white/10 bg-white/5 font-bold text-lg flex items-center gap-2\" data-kid=\"28\">\n                    <i class=\"ti ti-brand-apple\" data-kid=\"29\"></i> Download App\n                </button>\n            </div>\n\n            <div class=\"mt-20 flex flex-wrap justify-center gap-12 text-center\" id=\"hero-stats\" data-kid=\"30\">\n                <div data-kid=\"31\">\n                    <div class=\"text-3xl font-bold text-white mb-1\" data-kid=\"32\">50K+</div>\n                    <div class=\"text-sm text-gray-500 uppercase tracking-widest\" data-kid=\"33\">Active Users</div>\n                </div>\n                <div data-kid=\"34\">\n                    <div class=\"text-3xl font-bold text-white mb-1\" data-kid=\"35\">4.8★</div>\n                    <div class=\"text-sm text-gray-500 uppercase tracking-widest\" data-kid=\"36\">App Rating</div>\n                </div>\n                <div data-kid=\"37\">\n                    <div class=\"text-3xl font-bold text-white mb-1\" data-kid=\"38\">2M+</div>\n                    <div class=\"text-sm text-gray-500 uppercase tracking-widest\" data-kid=\"39\">Tasks Optimized</div>\n                </div>\n            </div>\n        </div>\n\n        <div class=\"absolute bottom-10 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 animate-bounce opacity-50\" data-kid=\"40\">\n            <span class=\"text-xs uppercase tracking-widest font-medium\" data-kid=\"41\">Scroll to explore</span>\n            <i class=\"ti ti-chevron-down\" data-kid=\"42\"></i>\n        </div>\n    </section>\n\n    \n    <section id=\"dashboard\" class=\"relative py-20 bg-[var(--obsidian)] overflow-hidden\" data-kid=\"43\">\n        <div class=\"max-w-6xl mx-auto px-6\" data-kid=\"44\">\n            <div id=\"dashboard-container\" class=\"relative [perspective:1500px]\" data-kid=\"45\">\n                <div id=\"dashboard-mockup\" class=\"glass-violet rounded-[40px] p-4 md:p-10 border border-white/10 shadow-[0_40px_100px_rgba(0,0,0,0.5)] overflow-hidden\" data-kid=\"46\">\n                    <div class=\"flex items-center gap-8 mb-10 border-b border-white/5 pb-6\" data-kid=\"47\">\n                        <div class=\"flex items-center gap-2\" data-kid=\"48\">\n                            <i class=\"ti ti-circle-filled text-xs text-red-500/50\" data-kid=\"49\"></i>\n                            <i class=\"ti ti-circle-filled text-xs text-yellow-500/50\" data-kid=\"50\"></i>\n                            <i class=\"ti ti-circle-filled text-xs text-green-500/50\" data-kid=\"51\"></i>\n                        </div>\n                        <div class=\"flex-grow\" data-kid=\"52\"></div>\n                        <div class=\"flex items-center gap-4\" data-kid=\"53\">\n                            <div class=\"w-8 h-8 rounded-full bg-white/5 border border-white/10\" data-kid=\"54\"></div>\n                        </div>\n                    </div>\n                    \n                    <div class=\"grid grid-cols-12 gap-8\" data-kid=\"55\">\n                        <div class=\"col-span-3 space-y-6\" data-kid=\"56\">\n                            <div class=\"space-y-1\" data-kid=\"57\">\n                                <div class=\"px-3 py-2 bg-[var(--violet)]/20 text-[var(--violet)] rounded-lg text-sm font-bold flex items-center gap-2\" data-kid=\"58\">\n                                    <i class=\"ti ti-layout-dashboard\" data-kid=\"59\"></i> Inbox\n                                </div>\n                                <div class=\"px-3 py-2 hover:bg-white/5 rounded-lg text-sm text-gray-500 flex items-center gap-2\" data-kid=\"60\">\n                                    <i class=\"ti ti-calendar\" data-kid=\"61\"></i> Today\n                                </div>\n                            </div>\n                        </div>\n                        <div class=\"col-span-9\" data-kid=\"62\">\n                            <div class=\"flex items-center justify-between mb-8\" data-kid=\"63\">\n                                <h4 class=\"text-xl font-bold\" data-kid=\"64\">Priority View</h4>\n                                <button class=\"px-4 py-1.5 bg-white/5 rounded-lg text-xs font-bold border border-white/10\" data-kid=\"65\">Sort by AI</button>\n                            </div>\n                            <div class=\"space-y-3\" data-kid=\"66\">\n                                <div class=\"glass p-4 rounded-xl flex items-center justify-between border-white/5\" data-kid=\"67\">\n                                    <div class=\"flex items-center gap-4\" data-kid=\"68\">\n                                        <div class=\"w-5 h-5 rounded border border-white/20\" data-kid=\"69\"></div>\n                                        <span class=\"text-sm\" data-kid=\"70\">Finalize Q3 Marketing Strategy</span>\n                                    </div>\n                                    <span class=\"text-[10px] uppercase font-bold text-red-400 bg-red-400/10 px-2 py-1 rounded\" data-kid=\"71\">High</span>\n                                </div>\n                                <div class=\"glass p-4 rounded-xl flex items-center justify-between border-white/5\" data-kid=\"72\">\n                                    <div class=\"flex items-center gap-4\" data-kid=\"73\">\n                                        <div class=\"w-5 h-5 rounded border border-white/20\" data-kid=\"74\"></div>\n                                        <span class=\"text-sm\" data-kid=\"75\">Schedule Team Retro</span>\n                                    </div>\n                                    <span class=\"text-[10px] uppercase font-bold text-[var(--violet)] bg-[var(--violet)]/10 px-2 py-1 rounded\" data-kid=\"76\">Normal</span>\n                                </div>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    \n    <section id=\"chaos-section\" class=\"relative h-[250vh] bg-[var(--obsidian)]\" data-kid=\"77\">\n        <div class=\"sticky top-0 h-screen w-full flex items-center justify-center overflow-hidden\" data-kid=\"78\">\n            <div id=\"chaos-content\" class=\"relative w-full h-full flex items-center justify-center\" data-kid=\"79\">\n                \n                <div class=\"chaos-item absolute top-[5%] left-[10%] glass p-4 rounded-xl rotate-3\" data-kid=\"80\">\n                    <div class=\"flex items-center gap-3\" data-kid=\"81\"><span class=\"w-2 h-2 rounded-full bg-red-500\" data-kid=\"82\"></span><span class=\"text-sm\" data-kid=\"83\">Overdue Marketing Specs</span></div>\n                </div>\n                <div class=\"chaos-item absolute top-[20%] right-[15%] glass p-4 rounded-xl -rotate-6\" data-kid=\"84\">\n                    <div class=\"flex items-center gap-3\" data-kid=\"85\"><i class=\"ti ti-mail-off text-yellow-500\" data-kid=\"86\"></i><span class=\"text-sm\" data-kid=\"87\">42 Unread Emails</span></div>\n                </div>\n                <div class=\"chaos-item absolute bottom-[15%] left-[5%] glass p-4 rounded-xl rotate-12\" data-kid=\"88\">\n                    <div class=\"flex items-center gap-3\" data-kid=\"89\"><i class=\"ti ti-alert-triangle text-red-500\" data-kid=\"90\"></i><span class=\"text-sm\" data-kid=\"91\">Deadline Missed: v1.2</span></div>\n                </div>\n                <div class=\"chaos-item absolute top-1/2 right-[5%] glass p-4 rounded-xl -rotate-12\" data-kid=\"92\">\n                    <div class=\"flex items-center gap-3\" data-kid=\"93\"><i class=\"ti ti-clock-pause text-blue-400\" data-kid=\"94\"></i><span class=\"text-sm\" data-kid=\"95\">Team sync is pending</span></div>\n                </div>\n                <div class=\"chaos-item absolute top-[40%] left-[20%] glass p-4 rounded-xl rotate-6\" data-kid=\"96\">\n                    <div class=\"flex items-center gap-3\" data-kid=\"97\"><span class=\"text-[10px] font-black text-red-500\" data-kid=\"98\">MISSING</span><span class=\"text-sm\" data-kid=\"99\">Asset export #11</span></div>\n                </div>\n                <div class=\"chaos-item absolute bottom-[20%] right-[30%] glass p-4 rounded-xl -rotate-3\" data-kid=\"100\">\n                    <div class=\"flex items-center gap-3\" data-kid=\"101\"><i class=\"ti ti-bell-ringing text-white\" data-kid=\"102\"></i><span class=\"text-sm\" data-kid=\"103\">Reminder: Call client</span></div>\n                </div>\n                <div class=\"chaos-item absolute top-[10%] left-[45%] glass p-3 rounded-lg rotate-45 opacity-40\" data-kid=\"104\">\n                    <div class=\"text-[10px]\" data-kid=\"105\">Background noise task...</div>\n                </div>\n                <div class=\"chaos-item absolute bottom-[10%] left-[60%] glass p-3 rounded-lg -rotate-12 opacity-30\" data-kid=\"106\">\n                    <div class=\"text-[10px]\" data-kid=\"107\">Slack ping #241</div>\n                </div>\n\n                <div class=\"text-center z-10 px-6\" data-kid=\"108\">\n                    <h2 class=\"font-heading text-6xl md:text-9xl font-bold mb-6 tracking-tighter\" data-kid=\"109\">STOP THE <br data-kid=\"110\"><span class=\"text-red-500\" data-kid=\"111\">NOISE.</span></h2>\n                    <p class=\"text-lg md:text-2xl text-gray-500 max-w-xl mx-auto font-medium\" data-kid=\"112\">The digital world is a storm of distractions. <br data-kid=\"113\"> TaskMate is your calm.</p>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    \n    <section id=\"understand-section\" class=\"relative h-[200vh]\" data-kid=\"114\">\n        <div class=\"sticky top-0 h-screen w-full bg-[var(--charcoal)] flex items-center justify-center overflow-hidden\" data-kid=\"115\">\n            \n            <div class=\"absolute inset-0 opacity-20 pointer-events-none\" data-kid=\"116\">\n    