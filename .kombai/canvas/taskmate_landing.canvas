      "html": "\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  :root {\n    --orange: #F5A87B;\n    --pink: #F0607A;\n    --purple: #8B65C8;\n    --teal: #4ABFB8;\n    --lavender: #C4C8E8;\n    --dark: #0F0A1A;\n    --dark2: #1A1228;\n    --dark3: #241B35;\n    --text: #F0EEF8;\n    --text2: #B8B0D4;\n    --text3: #7A7090;\n    --border: rgba(255, 255, 255, 0.05);\n    --primary-gradient: linear-gradient(135deg, #F5A87B, #F0607A, #8B65C8, #4ABFB8);\n    --cta-gradient: linear-gradient(135deg, #F0607A, #8B65C8);\n  }\n\n  body {\n    -webkit-font-smoothing: antialiased;\n    -moz-osx-font-smoothing: grayscale;\n    background-color: var(--dark);\n    color: var(--text);\n    font-family: 'Inter', sans-serif;\n    line-height: 1.7;\n    margin: 0;\n    padding: 0;\n    overflow-x: hidden;\n  }\n\n  .text-gradient {\n    background: var(--primary-gradient);\n    -webkit-background-clip: text;\n    -webkit-text-fill-color: transparent;\n  }\n\n  .bento-border {\n    border: 1px solid var(--border);\n  }\n\n  .glass-nav {\n    background: rgba(15, 10, 26, 0.8);\n    backdrop-filter: blur(20px);\n    border-bottom: 1px solid var(--border);\n  }\n\n  .cta-pill {\n    background: var(--cta-gradient);\n    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);\n    border: 1px solid rgba(255, 255, 255, 0.1);\n  }\n  .cta-pill:hover {\n    box-shadow: 0 0 25px rgba(240, 96, 122, 0.4);\n    transform: translateY(-2px);\n  }\n  .cta-pill:active {\n    transform: scale(0.98);\n  }\n\n  .pulse-dot {\n    animation: pulse 2s infinite;\n  }\n  @keyframes pulse {\n    0% { opacity: 0.4; transform: scale(0.8); }\n    50% { opacity: 1; transform: scale(1.2); }\n    100% { opacity: 0.4; transform: scale(0.8); }\n  }\n\n  .hover-lift {\n    transition: transform 0.3s ease, background-color 0.3s ease;\n  }\n  .hover-lift:hover {\n    transform: translateY(-4px);\n    background-color: var(--dark3);\n  }\n\n  /* Custom scrollbar */\n  ::-webkit-scrollbar {\n    width: 6px;\n  }\n  ::-webkit-scrollbar-track {\n    background: var(--dark);\n  }\n  ::-webkit-scrollbar-thumb {\n    background: var(--dark3);\n    border-radius: 10px;\n  }\n  ::-webkit-scrollbar-thumb:hover {\n    background: var(--text3);\n  }\n\n  /* Animations */\n  @keyframes fadeUp {\n    from { opacity: 0; transform: translateY(20px); }\n    to { opacity: 1; transform: translateY(0); }\n  }\n  .animate-fade-up {\n    animation: fadeUp 0.6s ease-out forwards;\n  }\n\n  .stagger-1 { animation-delay: 0.1s; }\n  .stagger-2 { animation-delay: 0.2s; }\n  .stagger-3 { animation-delay: 0.3s; }\n  .stagger-4 { animation-delay: 0.4s; }\n\n  /* Testimonials Rail */\n  .rail-container {\n    mask-image: linear-gradient(to right, transparent, black 20%, black 80%, transparent);\n  }\n  \n  .glow-purple {\n    background: radial-gradient(circle at center, rgba(139, 101, 200, 0.15) 0%, transparent 70%);\n  }\n  \n  .glow-teal {\n    background: radial-gradient(circle at center, rgba(74, 191, 184, 0.1) 0%, transparent 70%);\n  }\n</style>\n\n<div class=\"relative w-full box-border\" data-kid=\"1\">\n  \n  <nav class=\"absolute top-0 left-0 right-0 z-[100] glass-nav\" data-kid=\"2\">\n    <div class=\"max-w-[1440px] mx-auto px-8 h-20 flex items-center justify-between\" data-kid=\"3\">\n      <div class=\"flex items-center gap-3\" data-kid=\"4\">\n        <div class=\"w-10 h-10 rounded-xl overflow-hidden bento-border\" data-kid=\"5\">\n          <img src=\"/api/local/images/assets/logo.png\" alt=\"TaskMate Logo\" class=\"w-full h-full object-cover\" decoding=\"async\" loading=\"lazy\" data-kid=\"6\">\n        </div>\n        <span class=\"text-xl font-bold tracking-tight\" data-kid=\"7\">TaskMate <span class=\"text-[var(--purple)]\" data-kid=\"8\">AI</span></span>\n      </div>\n      \n      <div class=\"hidden md:flex items-center gap-10\" data-kid=\"9\">\n        <a href=\"#features\" class=\"text-sm font-medium text-[var(--text2)] hover:text-white transition-colors\" data-kid=\"10\">Features</a>\n        <a href=\"#how\" class=\"text-sm font-medium text-[var(--text2)] hover:text-white transition-colors\" data-kid=\"11\">How it works</a>\n        <a href=\"#pricing\" class=\"text-sm font-medium text-[var(--text2)] hover:text-white transition-colors\" data-kid=\"12\">Pricing</a>\n        <a href=\"#faq\" class=\"text-sm font-medium text-[var(--text2)] hover:text-white transition-colors\" data-kid=\"13\">FAQ</a>\n      </div>\n      \n      <div class=\"flex items-center gap-4\" data-kid=\"14\">\n        <button class=\"px-5 py-2.5 text-sm font-semibold text-[var(--text2)] hover:text-white transition-colors cursor-pointer\" data-kid=\"15\">Sign in</button>\n        <button class=\"cta-pill px-6 py-2.5 rounded-full text-sm font-bold text-white cursor-pointer shadow-lg\" data-kid=\"16\">\n          Download Free →\n        </button>\n      </div>\n    </div>\n  </nav>\n\n  \n  <section class=\"relative pt-48 pb-32 px-8 overflow-hidden\" data-kid=\"17\">\n    \n    <div class=\"absolute top-0 left-1/4 w-[800px] h-[800px] glow-purple blur-[120px] -translate-y-1/2 pointer-events-none\" data-kid=\"18\"></div>\n    <div class=\"absolute bottom-0 right-1/4 w-[600px] h-[600px] glow-teal blur-[100px] translate-y-1/2 pointer-events-none\" data-kid=\"19\"></div>\n\n    <div class=\"max-w-[1100px] mx-auto\" data-kid=\"20\">\n      <div class=\"grid grid-cols-1 md:grid-cols-12 gap-16 items-center\" data-kid=\"21\">\n        \n        <div class=\"md:col-span-6 animate-fade-up\" data-kid=\"22\">\n          <div class=\"inline-flex items-center gap-3 px-3 py-1.5 rounded-full bento-border bg-white/5 mb-8\" data-kid=\"23\">\n            <span class=\"w-2 h-2 rounded-full bg-[var(--teal)] pulse-dot\" data-kid=\"24\"></span>\n            <span class=\"text-[12px] font-semibold uppercase tracking-widest text-[var(--teal)]\" data-kid=\"25\">AI-Powered Task Intelligence · v1.7.0</span>\n          </div>\n          \n          <h1 class=\"text-[72px] font-extrabold leading-[1.1] tracking-tight mb-8\" data-kid=\"26\">\n            Plan smarter.<br data-kid=\"27\">\n            <span class=\"text-gradient\" data-kid=\"28\">Live better.</span>\n          </h1>\n          \n          <p class=\"text-[var(--text2)] text-lg leading-relaxed mb-10 max-w-[500px]\" data-kid=\"29\">\n            TaskMate AI turns your scattered to-dos into a focused, intelligent workflow. Voice input, smart reminders, and AI suggestions — all in one beautiful app.\n          </p>\n          \n          <div class=\"flex flex-wrap items-center gap-4 mb-12\" data-kid=\"30\">\n            <button class=\"cta-pill px-8 py-4 rounded-full font-bold text-white cursor-pointer flex items-center gap-2\" data-kid=\"31\">\n              Get Started Free →\n            </button>\n            <button class=\"px-8 py-4 rounded-full font-bold bento-border hover:bg-white/5 transition-colors cursor-pointer flex items-center gap-2 group\" data-kid=\"32\">\n              <i class=\"ti ti-player-play-filled text-white/50 group-hover:text-white transition-colors\" data-kid=\"33\"></i> Watch Demo\n            </button>\n          </div>\n          \n          <div class=\"flex items-center gap-8 opacity-60\" data-kid=\"34\">\n            <div class=\"flex items-center gap-2 text-sm font-medium\" data-kid=\"35\"><i class=\"ti ti-brand-google-play text-xl\" data-kid=\"36\"></i> Google Play</div>\n            <div class=\"flex items-center gap-2 text-sm font-medium\" data-kid=\"37\"><i class=\"ti ti-brand-apple text-xl\" data-kid=\"38\"></i> App Store <span class=\"text-[10px] bg-white/10 px-1.5 py-0.5 rounded ml-1\" data-kid=\"39\">Soon</span></div>\n            <div class=\"flex items-center gap-2 text-sm font-medium\" data-kid=\"40\"><i class=\"ti ti-world text-xl\" data-kid=\"41\"></i> Web App</div>\n          </div>\n        </div>\n\n        \n        <div class=\"md:col-span-6 animate-fade-up stagger-2\" data-kid=\"42\">\n          <div class=\"relative w-full aspect-[4/3] bg-[var(--dark3)] rounded-3xl bento-border p-6 shadow-2xl flex items-center justify-center\" data-kid=\"43\">\n            \n            <div class=\"w-full h-full bg-[var(--dark)] rounded-xl border border-white/10 overflow-hidden shadow-2xl flex flex-col\" data-kid=\"44\">\n              <div class=\"h-10 bg-white/5 border-b border-white/5 flex items-center px-4 gap-2\" data-kid=\"45\">\n                <div class=\"w-3 h-3 rounded-full bg-[#FF5F56]\" data-kid=\"46\"></div>\n                <div class=\"w-3 h-3 rounded-full bg-[#FFBD2E]\" data-kid=\"47\"></div>\n                <div class=\"w-3 h-3 rounded-full bg-[#27C93F]\" data-kid=\"48\"></div>\n              </div>\n              <div class=\"flex-1 overflow-hidden relative\" data-kid=\"49\">\n                <img src=\"/api/local/images/assets/dashboardDark.png\" alt=\"TaskMate Dashboard\" class=\"w-full h-full object-cover\" decoding=\"async\" loading=\"lazy\" data-kid=\"50\">\n                \n                <div class=\"absolute top-10 right-10 bg-[var(--dark2)]/90 backdrop-blur bento-border p-4 rounded-2xl shadow-2xl animate-bounce\" data-kid=\"51\">\n                  <div class=\"flex items-center gap-3\" data-kid=\"52\">\n                    <div class=\"w-8 h-8 rounded-full bg-[var(--purple)]/20 flex items-center justify-center\" data-kid=\"53\">\n                      <i class=\"ti ti-sparkles text-[var(--purple)]\" data-kid=\"54\"></i>\n                    </div>\n                    <div data-kid=\"55\">\n                      <div class=\"text-[10px] text-[var(--text3)] font-bold uppercase\" data-kid=\"56\">AI Suggested</div>\n                      <div class=\"text-sm font-semibold\" data-kid=\"57\">\"Meeting with Design Team\"</div>\n                    </div>\n                  </div>\n                </div>\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"px-8 mb-24\" data-kid=\"58\">\n    <div class=\"max-w-[1100px] mx-auto grid grid-cols-2 md:grid-cols-4 bento-border rounded-3xl overflow-hidden bg-[var(--dark2)] divide-x divide-y md:divide-y-0 divide-[var(--border)]\" data-kid=\"59\">\n      <div class=\"flex flex-col items-center justify-center p-8\" data-kid=\"60\">\n        <span class=\"text-3xl font-extrabold text-gradient mb-1\" data-kid=\"61\">1.2K+</span>\n        <span class=\"text-[var(--text3)] text-xs font-bold uppercase tracking-widest text-center\" data-kid=\"62\">Active Users</span>\n      </div>\n      <div class=\"flex flex-col items-center justify-center p-8\" data-kid=\"63\">\n        <span class=\"text-3xl font-extrabold text-gradient mb-1\" data-kid=\"64\">4.8★</span>\n        <span class=\"text-[var(--text3)] text-xs font-bold uppercase tracking-widest text-center\" data-kid=\"65\">Play Store</span>\n      </div>\n      <div class=\"flex flex-col items-center justify-center p-8\" data-kid=\"66\">\n        <span class=\"text-3xl font-extrabold text-gradient mb-1\" data-kid=\"67\">6+</span>\n        <span class=\"text-[var(--text3)] text-xs font-bold uppercase tracking-widest text-center\" data-kid=\"68\">Languages</span>\n      </div>\n      <div class=\"flex flex-col items-center justify-center p-8\" data-kid=\"69\">\n        <span class=\"text-3xl font-extrabold text-gradient mb-1\" data-kid=\"70\">FREE</span>\n        <span class=\"text-[var(--text3)] text-xs font-bold uppercase tracking-widest text-center\" data-kid=\"71\">No Hidden Costs</span>\n      </div>\n    </div>\n  </section>\n\n  \n  <section id=\"features\" class=\"px-8 py-24 bg-[var(--dark)] relative overflow-hidden\" data-kid=\"72\">\n    <div class=\"max-w-[1100px] mx-auto\" data-kid=\"73\">\n      <div class=\"mb-16\" data-kid=\"74\">\n        <span class=\"text-[var(--teal)] text-sm font-bold uppercase tracking-[0.2em] block mb-4\" data-kid=\"75\">Core Features</span>\n        <h2 class=\"text-[44px] font-bold tracking-tight\" data-kid=\"76\">Everything you need to stay ahead</h2>\n      </div>\n\n      <div class=\"grid grid-cols-1 md:grid-cols-3 gap-0 border border-[var(--border)] rounded-[32px] overflow-hidden\" data-kid=\"77\">\n        \n        <div class=\"p-10 bg-[var(--dark2)] border-r border-b border-[var(--border)] group transition-all duration-500 hover:bg-white/[0.03]\" data-kid=\"78\">\n          <div class=\"w-14 h-14 rounded-2xl bg-[var(--orange)]/10 flex items-center justify-center mb-8 transition-transform duration-300 group-hover:scale-110\" data-kid=\"79\">\n            <i class=\"ti ti-microphone text-[var(--orange)] text-3xl\" data-kid=\"80\"></i>\n          </div>\n          <h3 class=\"text-xl font-bold mb-4\" data-kid=\"81\">Voice to Task</h3>\n          <p class=\"text-[var(--text2)] leading-relaxed\" data-kid=\"82\">Convert speech to structured, prioritized tasks instantly with neural voice processing.</p>\n        </div>\n        \n        <div class=\"p-10 bg-[var(--dark2)] border-r border-b border-[var(--border)] group transition-all duration-500 hover:bg-white/[0.03]\" data-kid=\"83\">\n          <div class=\"w-14 h-14 rounded-2xl bg-[var(--purple)]/10 flex items-center justify-center mb-8 transition-transform duration-300 group-hover:scale-110\" data-kid=\"84\">\n            <i class=\"ti ti-sparkles text-[var(--purple)] text-3xl\" data-kid=\"85\"></i>\n          </div>\n          <h3 class=\"text-xl font-bold mb-4\" data-kid=\"86\">AI Smart Suggestions</h3>\n          <p class=\"text-[var(--text2)] leading-relaxed\" data-kid=\"87\">Learns your patterns and surfaces forgotten tasks based on context, priority, and habit.</p>\n        </div>\n        \n        <div class=\"p-10 bg-[var(--dark2)] border-b border-[var(--border)] group transition-all duration-500 hover:bg-white/[0.03]\" data-kid=\"88\">\n          <div class=\"w-14 h-14 rounded-2xl bg-[var(--pink)]/10 flex items-center justify-center mb-8 transition-transform duration-300 group-hover:scale-110\" data-kid=\"89\">\n            <i class=\"ti ti-bell-ringing text-[var(--pink)] text-3xl\" data-kid=\"90\"></i>\n          </div>\n          <h3 class=\"text-xl font-bold mb-4\" data-kid=\"91\">Smart Reminders</h3>\n          <p class=\"text-[var(--text2)] leading-relaxed\" data-kid=\"92\">Context-aware notifications that fire exactly when you need them, using location and behavior data.</p>\n        </div>\n        \n        <div class=\"p-10 bg-[var(--dark2)] border-r border-[var(--border)] group transition-all duration-500 hover:bg-white/[0.03]\" data-kid=\"93\">\n          <div class=\"w-14 h-14 rounded-2xl bg-[var(--teal)]/10 flex items-center justify-center mb-8 transition-transform duration-300 group-hover:scale-110\" data-kid=\"94\">\n            <i class=\"ti ti-calendar-event text-[var(--teal)] text-3xl\" data-kid=\"95\"></i>\n          </div>\n          <h3 class=\"text-xl font-bold mb-4\" data-kid=\"96\">Calendar Sync</h3>\n          <p class=\"text-[var(--text2)] leading-relaxed\" data-kid=\"97\">Seamless two-way Google Calendar synchronization for unified and friction-less time management.</p>\n        </div>\n        \n        <div class=\"p-10 bg-[var(--dark2)] border-r border-[var(--border)] group transition-all duration-500 hover:bg-white/[0.03]\" data-kid=\"98\">\n          <div class=\"w-14 h-14 rounded-2xl bg-[var(--orange)]/10 flex items-center justify-center mb-8 transition-transform duration-300 group-hover:scale-110\" data-kid=\"99\">\n            <i class=\"ti ti-clock-play text-[var(--orange)] text-3xl\" data-kid=\"100\"></i>\n          </div>\n          <h3 class=\"text-xl font-bold mb-4\" data-kid=\"101\">Focus Mode</h3>\n          <p class=\"text-[var(--text2)] leading-relaxed\" data-kid=\"102\">3 customizable Pomodoro-style clock modes designed to help you enter and maintain deep work sessions.</p>\n        </div>\n        \n        <div class=\"p-10 bg-[var(--dark2)] group transition-all duration-500 hover:bg-white/[0.03]\" data-kid=\"103\">\n          <div class=\"w-14 h-14 rounded-2xl bg-[var(--purple)]/10 flex items-center justify-center mb-8 transition-transform duration-300 group-hover:scale-110\" data-kid=\"104\">\n            <i class=\"ti ti-layout-grid text-[var(--purple)] text-3xl\" data-kid=\"105\"></i>\n          </div>\n          <h3 class=\"text-xl font-bold mb-4\" data-kid=\"106\">Home Screen Widgets</h3>\n          <p class=\"text-[var(--text2)] leading-relaxed\" data-kid=\"107\">Beautifully designed glanceable widgets to see your tasks at a glance without ever opening the app.</p>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section id=\"how\" class=\"px-8 py-24 bg-[var(--dark)] relative overflow-hidden\" data-kid=\"108\">\n    <div class=\"max-w-[1100px] mx-auto\" data-kid=\"109\">\n      <div class=\"grid grid-cols-1 md:grid-cols-12 gap-20 items-center\" data-kid=\"110\">\n        \n        <div class=\"md:col-span-5\" data-kid=\"111\">\n          <span class=\"text-[var(--teal)] text-sm font-bold uppercase tracking-[0.2em] block mb-4\" data-kid=\"112\">The Process</span>\n          <h2 class=\"text-[44px] font-bold tracking-tight mb-12\" data-kid=\"113\">Designed for clarity</h2>\n          \n          <div class=\"space-y-12 relative\" data-kid=\"114\">\n            <div class=\"absolute left-[11px] top-6 bottom-6 w-px bg-[var(--border)]\" data-kid=\"115\"></div>\n            \n            \n            <div class=\"relative pl-12\" data-kid=\"116\">\n              <div class=\"absolute left-0 top-1 w-6 h-6 rounded-full bg-[var(--purple)] border-4 border-[var(--dark)] z-10 ring-4 ring-[var(--purple)]/20\" data-kid=\"117\"></div>\n              <div class=\"p-8 rounded-[24px] bg-[var(--dark2)] border border-[var(--purple)]/30 hover:border-[var(--purple)] transition-all duration-300 group shadow-lg\" data-kid=\"118\">\n                <span class=\"text-[var(--purple)] font-bold text-xs uppercase tracking-widest mb-3 block\" data-kid=\"119\">Step 01</span>\n                <h3 class=\"text-xl font-bold mb-3 group-hover:text-white transition-colors\" data-kid=\"120\">Add tasks by voice or type</h3>\n                <p class=\"text-[var(--text2)] leading-relaxed\" data-kid=\"121\">Dictate naturally and our AI will auto-categorize, set deadlines, and intelligently detect priority levels.</p>\n              </div>\n            </div>\n            \n            \n            <div class=\"relative pl-12\" data-kid=\"122\">\n              <div class=\"absolute left-0 top-1 w-6 h-6 rounded-full bg-white/10 border-4 border-[var(--dark)] z-10 hover:bg-white/20 transition-colors\" data-kid=\"123\"></div>\n              <div class=\"p-8 rounded-[24px] bento-border hover:bg-[var(--dark2)] transition-all duration-300 group\" data-kid=\"124\">\n                <span class=\"text-[var(--text3)] font-bold text-xs uppercase tracking-widest mb-3 block\" data-kid=\"125\">Step 02</span>\n                <h3 class=\"text-xl font-bold mb-3 group-hover:text-white transition-colors\" data-kid=\"126\">AI organizes your day</h3>\n                <p class=\"text-[var(--text3)] leading-relaxed\" data-kid=\"127\">Smart scheduling by analyzing deadlines, context, and your productivity habits ensures you focus on the right thing.</p>\n              </div>\n            </div>\n\n            \n            <div class=\"relative pl-12\" data-kid=\"128\">\n              <div class=\"absolute left-0 top-1 w-6 h-6 rounded-full bg-white/10 border-4 border-[var(--dark)] z-10 hover:bg-white/20 transition-colors\" data-kid=\"129\"></div>\n              <div class=\"p-8 rounded-[24px] bento-border hover:bg-[var(--dark2)] transition-all duration-300 group\" data-kid=\"130\">\n                <span class=\"text-[var(--text3)] font-bold text-xs uppercase tracking-widest mb-3 block\" data-kid=\"131\">Step 03</span>\n                <h3 class=\"text-xl font-bold mb-3 group-hover:text-white transition-colors\" data-kid=\"132\">Focus, execute, track</h3>\n                <p class=\"text-[var(--text3)] leading-relaxed\" data-kid=\"133\">Launch Focus Mode to eliminate distractions and watch your productivity streaks grow with automated tracking.</p>\n              </div>\n            </div>\n          </div>\n        </div>\n        \n        \n        <div class=\"md:col-span-7\" data-kid=\"134\">\n          <div class=\"w-full aspect-square bg-[var(--dark2)] rounded-[40px] bento-border p-12 relative flex items-center justify-center overflow-hidden shadow-inner\" data-kid=\"135\">\n            \n            <div class=\"flex items-center gap-4 h-64\" data-kid=\"136\">\n              <div class=\"w-3 h-32 bg-[var(--orange)] rounded-full animate-[pulse_1.5s_infinite] opacity-80\" data-kid=\"137\"></div>\n              <div class=\"w-3 h-56 bg-[var(--pink)] rounded-full animate-[pulse_1.2s_infinite] opacity-80\" data-kid=\"138\"></div>\n              <div class=\"w-3 h-44 bg-[var(--purple)] rounded-full animate-[pulse_1.8s_infinite] opacity-80\" data-kid=\"139\"></div>\n              <div class=\"w-3 h-64 bg-[var(--teal)] rounded-full animate-[pulse_1.1s_infinite] opacity-80\" data-kid=\"140\"></div>\n              <div class=\"w-3 h-40 bg-[var(--purple)] rounded-full animate-[pulse_1.4s_infinite] opacity-80\" data-kid=\"141\"></div>\n              <div class=\"w-3 h-52 bg-[var(--pink)] rounded-full animate-[pulse_1.3s_infinite] opacity-80\" data-kid=\"142\"></div>\n            </div>\n            \n            \n            <div class=\"absolute bottom-12 left-1/2 -translate-x-1/2 bg-[var(--dark3)]/90 backdrop-blur bento-border px-6 py-4 rounded-2xl flex items-center gap-4 shadow-2xl\" data-kid=\"143\">\n              <div class=\"w-10 h-10 rounded-full bg-[var(--teal)]/20 flex items-center justify-center\" data-kid=\"144\">\n                <i class=\"ti ti-microphone text-[var(--teal)]\" data-kid=\"145\"></i>\n          