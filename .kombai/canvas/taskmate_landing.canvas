#6C3AED]/20\" data-kid=\"86\">\n                            <i class=\"ti ti-capture text-3xl text-[#6C3AED]\" data-kid=\"87\"></i>\n                        </div>\n                        <h3 class=\"text-4xl font-bold text-white mb-6\" data-kid=\"88\">Capture</h3>\n                        <p class=\"text-white/60 text-lg leading-relaxed\" data-kid=\"89\">TaskMate listens to your meetings, reads your emails, and scrapes your Slack messages to automatically create tasks.</p>\n                    </div>\n                    <div class=\"bg-[#1A1A1A] rounded-3xl p-8 border border-white/5 shadow-2xl\" data-kid=\"90\">\n                        <div class=\"flex items-center gap-3 mb-4 p-3 bg-white/5 rounded-xl border border-white/5 animate-pulse\" data-kid=\"91\">\n                            <i class=\"ti ti-mail text-[#6C3AED]\" data-kid=\"92\"></i>\n                            <span class=\"text-sm text-white/80 font-mono\" data-kid=\"93\">Found 2 tasks in recent email from Dave.</span>\n                        </div>\n                        <div class=\"space-y-3 opacity-50\" data-kid=\"94\">\n                            <div class=\"h-4 bg-white/10 rounded w-3/4\" data-kid=\"95\"></div>\n                            <div class=\"h-4 bg-white/10 rounded w-1/2\" data-kid=\"96\"></div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n\n            \n            <div class=\"execute-panel flex-none w-screen h-full flex items-center justify-center px-6\" data-kid=\"97\">\n                <div class=\"max-w-4xl grid md:grid-cols-2 gap-16 items-center\" data-kid=\"98\">\n                    <div class=\"order-2 md:order-1\" data-kid=\"99\">\n                        <div class=\"relative w-full aspect-square bg-[#1A1A1A] rounded-3xl border border-white/5 flex items-center justify-center\" data-kid=\"100\">\n                            <div class=\"w-3/4 h-3/4 rounded-full border-2 border-dashed border-[#6C3AED]/20 flex items-center justify-center\" data-kid=\"101\">\n                                <div class=\"w-1/2 h-1/2 rounded-full bg-[#6C3AED]/20 animate-ping\" data-kid=\"102\"></div>\n                                <i class=\"ti ti-rocket text-5xl text-[#6C3AED] absolute\" data-kid=\"103\"></i>\n                            </div>\n                        </div>\n                    </div>\n                    <div class=\"order-1 md:order-2\" data-kid=\"104\">\n                        <div class=\"w-16 h-16 bg-[#6C3AED]/10 rounded-2xl flex items-center justify-center mb-8 border border-[#6C3AED]/20\" data-kid=\"105\">\n                            <i class=\"ti ti-bolt text-3xl text-[#6C3AED]\" data-kid=\"106\"></i>\n                        </div>\n                        <h3 class=\"text-4xl font-bold text-white mb-6\" data-kid=\"107\">Execute</h3>\n                        <p class=\"text-white/60 text-lg leading-relaxed\" data-kid=\"108\">Once tasks are prioritized, TaskMate creates deep-work blocks in your calendar and silences notifications to ensure delivery.</p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    \n    <section id=\"assistant\" class=\"py-32 bg-[#0A0A0A] text-white overflow-hidden\" data-kid=\"109\">\n        <div class=\"max-w-7xl mx-auto px-6 flex flex-col items-center\" data-kid=\"110\">\n            <div class=\"text-center mb-16 max-w-3xl\" data-kid=\"111\">\n                <span class=\"text-[#6C3AED] font-mono text-sm uppercase tracking-widest mb-4 block\" data-kid=\"112\">Meet TaskMate</span>\n                <h2 class=\"text-4xl md:text-6xl font-extrabold mb-6\" data-kid=\"113\">Your Intelligence Partner.</h2>\n                <p class=\"text-white/50 text-xl font-['IBM_Plex_Mono']\" data-kid=\"114\">Always active, always aware of your workload.</p>\n            </div>\n            \n            <div class=\"w-full max-w-4xl bg-[#151515] border border-white/10 rounded-[2.5rem] overflow-hidden shadow-2xl perspective-1000\" data-kid=\"115\">\n                <div class=\"flex items-center justify-between p-6 border-b border-white/10\" data-kid=\"116\">\n                    <div class=\"flex items-center gap-4\" data-kid=\"117\">\n                        <div class=\"w-10 h-10 bg-[#6C3AED] rounded-full flex items-center justify-center\" data-kid=\"118\">\n                            <i class=\"ti ti-message-chatbot text-white\" data-kid=\"119\"></i>\n                        </div>\n                        <div data-kid=\"120\">\n                            <p class=\"font-bold text-sm\" data-kid=\"121\">TaskMate Assistant</p>\n                            <p class=\"text-[10px] text-emerald-500 flex items-center gap-1\" data-kid=\"122\"><span class=\"w-1.5 h-1.5 bg-emerald-500 rounded-full\" data-kid=\"123\"></span> Online</p>\n                        </div>\n                    </div>\n                    <div class=\"flex gap-2\" data-kid=\"124\">\n                        <div class=\"w-3 h-3 rounded-full bg-white/10\" data-kid=\"125\"></div>\n                        <div class=\"w-3 h-3 rounded-full bg-white/10\" data-kid=\"126\"></div>\n                    </div>\n                </div>\n                \n                <div id=\"chat-window\" class=\"p-8 h-[450px] flex flex-col gap-6 overflow-y-auto font-sans bg-[url('https://www.transparenttextures.com/patterns/carbon-fibre.png')] bg-opacity-5\" data-kid=\"127\">\n                    \n                    <div class=\"text-[10px] font-mono text-white/20 text-center uppercase tracking-widest mb-4\" data-kid=\"128\">Neural Session Initialized — 128-bit Encryption</div>\n                </div>\n\n                <div class=\"p-6 bg-black/20 border-t border-white/10\" data-kid=\"129\">\n                    <div class=\"flex items-center bg-white/5 border border-white/10 rounded-full px-6 py-4\" data-kid=\"130\">\n                        <span class=\"text-white/30 text-sm\" data-kid=\"131\">Ask