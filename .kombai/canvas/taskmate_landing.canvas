      "html": "\n<div id=\"app\" class=\"font-sans antialiased text-[var(--text-primary)] bg-[var(--bg-primary)] transition-colors duration-300\" data-kid=\"0\">\n    <style data-kid=\"1\">\n        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap');\n        @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n        :root {\n            /* Dark Mode (Default) */\n            --bg-primary: #0F0A1A;\n            --bg-secondary: #1A1228;\n            --bg-tertiary: #241B35;\n            --bg-card: rgba(26,18,40,0.8);\n            --bg-glass: rgba(26,18,40,0.5);\n            --text-primary: #F0EEF8;\n            --text-secondary: #B8B0D4;\n            --text-muted: #7A7090;\n            --border: rgba(255,255,255,0.07);\n            --border-hover: rgba(139,101,200,0.35);\n            --nav-bg: rgba(15,10,26,0.85);\n            --card-shadow: 0 20px 60px rgba(0,0,0,0.5);\n            --glow-purple: rgba(139,101,200,0.15);\n            --glow-teal: rgba(74,191,184,0.10);\n            --glow-pink: rgba(240,96,122,0.10);\n            --scrollbar-thumb: #241B35;\n            --scrollbar-thumb-hover: #8B65C8;\n\n            /* Always Same */\n            --orange: #F5A87B;\n            --pink: #F0607A;\n            --purple: #8B65C8;\n            --teal: #4ABFB8;\n            --grad-primary: linear-gradient(135deg, #F5A87B, #F0607A, #8B65C8, #4ABFB8);\n            --grad-cta: linear-gradient(135deg, #F0607A, #8B65C8);\n        }\n\n        [data-theme=\"light\"] {\n            --bg-primary: #F8F5FF;\n            --bg-secondary: #FFFFFF;\n            --bg-tertiary: #EEE7F6;\n            --bg-card: rgba(255,255,255,0.98);\n            --bg-glass: rgba(248,245,255,0.92);\n            --text-primary: #1A0F2E;\n            --text-secondary: #312A40;\n            --text-muted: #5A516E;\n            --border: rgba(139,101,200,0.15);\n            --border-hover: rgba(139,101,200,0.45);\n            --nav-bg: rgba(248,245,255,0.92);\n            --card-shadow: 0 8px 32px rgba(139,101,200,0.12);\n            --glow-purple: rgba(139,101,200,0.07);\n            --glow-teal: rgba(74,191,184,0.07);\n            --glow-pink: rgba(240,96,122,0.07);\n            --scrollbar-thumb: #C4B8E8;\n            --scrollbar-thumb-hover: #8B65C8;\n        }\n\n        *, *::before, *::after {\n            transition: background-color 0.3s ease, border-color 0.3s ease, color 0.3s ease, box-shadow 0.3s ease;\n        }\n\n        /* Static Entrance Animations */\n        @keyframes fadeUp {\n            from { opacity: 0; transform: translateY(20px); }\n            to { opacity: 1; transform: translateY(0); }\n        }\n        .reveal { animation: fadeUp 0.8s ease forwards; opacity: 0; }\n        .reveal:nth-child(1) { animation-delay: 0.1s; }\n        .reveal:nth-child(2) { animation-delay: 0.2s; }\n        .reveal:nth-child(3) { animation-delay: 0.3s; }\n\n        /* Custom Scrollbar */\n        ::-webkit-scrollbar { width: 6px; }\n        ::-webkit-scrollbar-track { background: var(--bg-primary); }\n        ::-webkit-scrollbar-thumb { background: var(--scrollbar-thumb); border-radius: 10px; }\n        ::-webkit-scrollbar-thumb:hover { background: var(--scrollbar-thumb-hover); }\n\n        /* Aurora */\n        .aurora-blob {\n            position: absolute;\n            width: 800px;\n            height: 800px;\n            filter: blur(100px);\n            opacity: 0.15;\n            border-radius: 50%;\n            animation: aurora-rotate 60s linear infinite;\n        }\n        @keyframes aurora-rotate {\n            0% { transform: translate(-50%,-50%) rotate(0deg) scale(1); }\n            50% { transform: translate(-50%,-50%) rotate(180deg) scale(1.2); }\n            100% { transform: translate(-50%,-50%) rotate(360deg) scale(1); }\n        }\n\n        /* Particles */\n        @keyframes particle-float {\n            0%, 100% { transform: translateY(0) translateX(0) opacity(0.2); }\n            33% { transform: translateY(-30px) translateX(15px); opacity: 0.5; }\n            66% { transform: translateY(20px) translateX(-10px); opacity: 0.2; }\n        }\n        .particle { position: absolute; width: 3px; height: 3px; border-radius: 50%; opacity: 0.2; animation: particle-float 15s ease-in-out infinite; }\n\n        /* Marquee */\n        @keyframes marquee {\n            0% { transform: translateX(0); }\n            100% { transform: translateX(-50%); }\n        }\n        .marquee-track { animation: marquee 40s linear infinite; }\n        .marquee-track:hover { animation-play-state: paused; }\n\n        /* Voice Waves */\n        @keyframes voice-wave {\n            0%, 100% { height: 8px; }\n            50% { height: var(--peak, 40px); }\n        }\n\n        /* Pricing Pulse */\n        @keyframes glow-pulse {\n            0%,100% { box-shadow: 0 0 20px rgba(139,101,200,0.25), 0 20px 60px rgba(0,0,0,0.4); }\n            50% { box-shadow: 0 0 45px rgba(139,101,200,0.45), 0 20px 60px rgba(0,0,0,0.4); }\n        }\n        .pro-glow { animation: glow-pulse 3s infinite; }\n\n        .perspective-1000 { perspective: 1000px; }\n        .glass { background: var(--bg-glass); backdrop-filter: blur(12px); }\n        \n        /* Nav Transition (Disabled for non-scrolling iframe) */\n        /* nav.scrolled { background: var(--nav-bg); backdrop-filter: blur(12px); border-bottom: 1px solid var(--border); padding-top: 0.75rem; padding-bottom: 0.75rem; } */\n    </style>\n\n    \n    <nav id=\"navbar\" class=\"absolute top-0 left-0 w-full z-50 py-6 px-4 md:px-8\" data-kid=\"2\">\n        <div class=\"max-w-7xl mx-auto flex items-center justify-between\" data-kid=\"3\">\n            \n            <a href=\"#\" class=\"flex items-center gap-3\" data-kid=\"4\">\n                <div class=\"w-10 h-10\" data-kid=\"5\">\n                    <svg viewBox=\"0 0 40 40\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\" data-kid=\"6\">\n                        <rect width=\"40\" height=\"40\" rx=\"10\" fill=\"url(#logoGrad)\" data-kid=\"7\"></rect>\n                        <defs data-kid=\"8\">\n                            <linearGradient id=\"logoGrad\" x1=\"0\" y1=\"40\" x2=\"40\" y2=\"0\" data-kid=\"9\">\n                                <stop offset=\"0%\" stop-color=\"#F5A87B\" data-kid=\"10\"></stop>\n                                <stop offset=\"30%\" stop-color=\"#F0607A\" data-kid=\"11\"></stop>\n                                <stop offset=\"65%\" stop-color=\"#8B65C8\" data-kid=\"12\"></stop>\n                                <stop offset=\"100%\" stop-color=\"#4ABFB8\" data-kid=\"13\"></stop>\n                            </linearGradient>\n                        </defs>\n                        <circle cx=\"20\" cy=\"20\" r=\"11\" stroke=\"white\" stroke-width=\"2.5\" fill=\"none\" data-kid=\"14\"></circle>\n                        <path d=\"M14 20.5L18 24.5L26 16\" stroke=\"white\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\" data-kid=\"15\"></path>\n                    </svg>\n                </div>\n                <span class=\"text-xl font-bold tracking-tight text-[var(--text-primary)]\" data-kid=\"16\">TaskMate AI</span>\n            </a>\n\n            \n            <div class=\"hidden md:flex items-center gap-8\" data-kid=\"17\">\n                <a href=\"#features\" class=\"text-sm font-medium text-[var(--text-secondary)] hover:text-[var(--purple)] transition-colors\" data-kid=\"18\">Features</a>\n                <a href=\"#how-it-works\" class=\"text-sm font-medium text-[var(--text-secondary)] hover:text-[var(--purple)] transition-colors\" data-kid=\"19\">How it works</a>\n                <a href=\"#pricing\" class=\"text-sm font-medium text-[var(--text-secondary)] hover:text-[var(--purple)] transition-colors\" data-kid=\"20\">Pricing</a>\n                <a href=\"#faq\" class=\"text-sm font-medium text-[var(--text-secondary)] hover:text-[var(--purple)] transition-colors\" data-kid=\"21\">FAQ</a>\n            </div>\n\n            \n            <div class=\"flex items-center gap-4\" data-kid=\"22\">\n                <button id=\"theme-toggle\" class=\"p-2.5 rounded-xl border border-[var(--border)] text-[var(--text-secondary)] hover:bg-[var(--bg-tertiary)] transition-colors\" data-kid=\"23\">\n                    <i id=\"theme-icon\" class=\"ti ti-moon-stars text-xl\" data-kid=\"24\"></i>\n                </button>\n                <a href=\"#\" class=\"hidden sm:block text-sm font-bold text-[var(--text-primary)] hover:text-[var(--purple)] transition-colors\" data-kid=\"25\">Sign in</a>\n                <a href=\"#\" class=\"px-6 py-2.5 rounded-full bg-gradient-to-r from-[var(--pink)] to-[var(--purple)] text-white text-sm font-bold shadow-lg hover:scale-105 transition-all\" data-kid=\"26\">\n                    Download Free <i class=\"ti ti-arrow-right ml-1\" data-kid=\"27\"></i>\n                </a>\n                <button id=\"mobile-menu-btn\" class=\"md:hidden p-2.5 rounded-xl border border-[var(--border)] text-[var(--text-secondary)]\" data-kid=\"28\">\n                    <i class=\"ti ti-menu-2 text-xl\" data-kid=\"29\"></i>\n                </button>\n            </div>\n        </div>\n        \n        \n        <div id=\"mobile-menu\" class=\"hidden absolute top-full left-0 w-full bg-[var(--bg-secondary)] border-b border-[var(--border)] py-8 px-4 flex-col gap-6 items-center md:hidden animate-fade-down shadow-2xl\" data-kid=\"30\">\n            <a href=\"#features\" class=\"text-lg font-bold\" data-kid=\"31\">Features</a>\n            <a href=\"#how-it-works\" class=\"text-lg font-bold\" data-kid=\"32\">How it works</a>\n            <a href=\"#pricing\" class=\"text-lg font-bold\" data-kid=\"33\">Pricing</a>\n            <a href=\"#faq\" class=\"text-lg font-bold\" data-kid=\"34\">FAQ</a>\n            <hr class=\"w-full border-[var(--border)]\" data-kid=\"35\">\n            <a href=\"#\" class=\"text-lg font-bold\" data-kid=\"36\">Sign in</a>\n        </div>\n    </nav>\n\n    \n    <header class=\"relative min-h-[850px] flex items-center pt-40 pb-20 overflow-hidden bg-[var(--bg-primary)]\" data-kid=\"37\">\n        \n        <div class=\"absolute inset-0 pointer-events-none\" data-kid=\"38\">\n            <div class=\"aurora-blob bg-[var(--purple)] top-[10%] left-[20%]\" style=\"animation-delay: 0s;\" data-kid=\"39\"></div>\n            <div class=\"aurora-blob bg-[var(--teal)] top-[60%] right-[10%]\" style=\"animation-delay: -20s;\" data-kid=\"40\"></div>\n            <div class=\"aurora-blob bg-[var(--pink)] bottom-[10%] left-[30%]\" style=\"animation-delay: -40s;\" data-kid=\"41\"></div>\n        </div>\n        \n        \n        <div id=\"particles-host\" class=\"absolute inset-0 pointer-events-none\" data-kid=\"42\"></div>\n\n        <div class=\"max-w-7xl mx-auto px-4 w-full grid grid-cols-1 lg:grid-cols-2 gap-16 items-center relative z-10\" data-kid=\"43\">\n            \n            <div class=\"reveal space-y-8\" style=\"transition-delay: 0.1s;\" data-kid=\"44\">\n                <div class=\"inline-flex items-center gap-2 px-3 py-1 rounded-full border border-[var(--teal)]/20 bg-[var(--teal)]/5 text-[var(--teal)] text-sm font-medium\" data-kid=\"45\">\n                    <span class=\"relative flex h-2 w-2\" data-kid=\"46\">\n                        <span class=\"animate-ping absolute inline-flex h-full w-full rounded-full bg-[var(--teal)] opacity-75\" data-kid=\"47\"></span>\n                        <span class=\"relative inline-flex rounded-full h-2 w-2 bg-[var(--teal)]\" data-kid=\"48\"></span>\n                    </span>\n                    AI-Powered Task Intelligence · v1.7.0\n                </div>\n                <h1 class=\"text-6xl md:text-7xl lg:text-8xl font-extrabold text-[var(--text-primary)] leading-[1.1] tracking-tight\" data-kid=\"49\">\n                    Plan smarter.<br data-kid=\"50\">\n                    <span class=\"bg-gradient-to-r from-[var(--orange)] via-[var(--pink)] via-[var(--purple)] to-[var(--teal)] bg-clip-text text-transparent\" data-kid=\"51\">Live better.</span>\n                </h1>\n                <p class=\"text-xl text-[var(--text-secondary)] max-w-xl leading-relaxed\" data-kid=\"52\">\n                    TaskMate AI uses advanced natural language processing to turn your scattered thoughts into a perfectly structured schedule. Zero friction, total clarity.\n                </p>\n                <div class=\"flex flex-wrap gap-4 pt-2\" data-kid=\"53\">\n                    <button class=\"px-10 py-5 rounded-2xl bg-gradient-to-r from-[var(--pink)] to-[var(--purple)] text-white font-bold text-lg shadow-[0_20px_40px_rgba(240,96,122,0.3)] hover:scale-105 active:scale-95 transition-all\" data-kid=\"54\">\n                        Get Started Free\n                    </button>\n                    <button class=\"px-10 py-5 rounded-2xl border-2 border-[var(--border)] text-[var(--text-primary)] font-bold text-lg hover:bg-[var(--bg-tertiary)] hover:border-[var(--purple)]/50 transition-all flex items-center gap-3\" data-kid=\"55\">\n                        <i class=\"ti ti-player-play-filled\" data-kid=\"56\"></i> Watch Demo\n                    </button>\n                </div>\n                <div class=\"flex items-center gap-8 pt-6 text-[var(--text-muted)] font-medium\" data-kid=\"57\">\n                    <div class=\"flex items-center gap-2\" data-kid=\"58\"><i class=\"ti ti-brand-android text-2xl text-[var(--teal)]\" data-kid=\"59\"></i> Android</div>\n                    <div class=\"flex items-center gap-2 opacity-40\" data-kid=\"60\"><i class=\"ti ti-brand-apple text-2xl\" data-kid=\"61\"></i> iOS (Soon)</div>\n                    <div class=\"flex items-center gap-2\" data-kid=\"62\"><i class=\"ti ti-world text-2xl\" data-kid=\"63\"></i> Web</div>\n                </div>\n            </div>\n\n            \n            <div class=\"reveal perspective-1000\" style