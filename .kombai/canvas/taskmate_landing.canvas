      "html": "\n<div id=\"page-wrapper\" class=\"bg-white text-[#0A0A0A] font-['Plus_Jakarta_Sans'] selection:bg-[#6C3AED] selection:text-white overflow-x-clip\" data-kid=\"0\">\n    \n    \n    <nav class=\"fixed top-0 left-0 w-full z-[100] px-6 py-8 flex items-center justify-between pointer-events-none\" data-kid=\"1\">\n        <div class=\"flex items-center gap-2 pointer-events-auto group cursor-pointer\" data-kid=\"2\">\n            <div class=\"w-10 h-10 bg-[#6C3AED] rounded-xl flex items-center justify-center shadow-lg shadow-[#6C3AED]/20 group-hover:scale-110 transition-transform duration-300\" data-kid=\"3\">\n                <i class=\"ti ti-atom text-white text-xl\" data-kid=\"4\"></i>\n            </div>\n            <span class=\"text-xl font-bold tracking-tight text-[#0A0A0A] dark-nav-text\" data-kid=\"5\">TaskMate AI</span>\n        </div>\n        <div class=\"hidden md:flex items-center gap-8 pointer-events-auto font-medium text-sm dark-nav-text\" data-kid=\"6\">\n            <a href=\"#\" class=\"hover:text-[#6C3AED] transition-colors\" data-kid=\"7\">Features</a>\n            <a href=\"#\" class=\"hover:text-[#6C3AED] transition-colors\" data-kid=\"8\">Enterprise</a>\n            <a href=\"#\" class=\"hover:text-[#6C3AED] transition-colors\" data-kid=\"9\">Pricing</a>\n            <button class=\"px-6 py-2.5 bg-[#0A0A0A] text-white rounded-full text-xs font-bold hover:bg-[#222] transition-colors shadow-xl\" data-kid=\"10\">Get Started</button>\n        </div>\n    </nav>\n\n    \n    <section id=\"hero\" class=\"relative w-full h-[130vh] bg-[#0A0A0A] flex items-center justify-start overflow-hidden pt-32\" data-kid=\"11\">\n        <div class=\"absolute inset-0 bg-[radial-gradient(circle_at_70%_50%,rgba(108,58,237,0.12),transparent_60%)] z-0\" data-kid=\"12\"></div>\n        <div class=\"absolute inset-0 opacity-[0.03] pointer-events-none\" style=\"background-image: radial-gradient(#6C3AED 1px, transparent 1px); background-size: 40px 40px;\" data-kid=\"13\"></div>\n        \n        <div class=\"container mx-auto px-6 relative z-10 grid lg:grid-cols-12 gap-12 items-center\" data-kid=\"14\">\n            <div class=\"lg:col-span-7\" data-kid=\"15\">\n                <div class=\"inline-flex items-center gap-3 px-3 py-1 rounded-full bg-white/5 border border-white/10 text-[#6C3AED] font-mono text-[10px] tracking-widest uppercase mb-8\" data-kid=\"16\">\n                    <span class=\"w-2 h-2 rounded-full bg-[#6C3AED] animate-pulse\" data-kid=\"17\"></span>\n                    Intelligence Engine v2.0\n                </div>\n                <h1 id=\"hero-headline\" class=\"text-7xl md:text-[8rem] xl:text-[9.5rem] font-black text-white tracking-tighter mb-8 leading-[0.8] mix-blend-screen\" data-kid=\"18\">\n                    Turn Chaos <br data-kid=\"19\"> Into Clarity\n                </h1>\n                <p id=\"hero-subheadline\" class=\"text-lg md:text-2xl text-white/50 font-medium max-w-xl mb-12 opacity-0 leading-relaxed\" data-kid=\"20\">\n                    The autonomous task platform that <span class=\"text-white\" data-kid=\"21\">thinks like you</span>, but moves 10x faster.\n                </p>\n                <div id=\"hero-actions\" class=\"flex flex-wrap gap-6 opacity-0\" data-kid=\"22\">\n                    <button class=\"px-10 py-5 bg-[#6C3AED] text-white rounded-2xl font-bold text-lg hover:bg-[#5A2DD1] shadow-[0_0_40px_rgba(108,58,237,0.3)] cursor-pointer\" data-kid=\"23\">Get Started Free</button>\n                    <button class=\"px-10 py-5 bg-white/5 border border-white/10 text-white rounded-2xl font-bold text-lg hover:bg-white/10 backdrop-blur-xl cursor-pointer\" data-kid=\"24\">View Ecosystem</button>\n                </div>\n                \n                <div id=\"hero-stats\" class=\"mt-24 grid grid-cols-3 gap-8 max-w-md opacity-0\" data-kid=\"25\">\n                    <div data-kid=\"26\">\n                        <p class=\"text-3xl font-black text-white\" data-kid=\"27\">50K+</p>\n                        <p class=\"text-[9px] uppercase tracking-widest text-white/40 font-mono mt-1\" data-kid=\"28\">Global Users</p>\n                    </div>\n                    <div data-kid=\"29\">\n                        <p class=\"text-3xl font-black text-white\" data-kid=\"30\">4.8</p>\n                        <p class=\"text-[9px] uppercase tracking-widest text-white/40 font-mono mt-1\" data-kid=\"31\">Store Rating</p>\n                    </div>\n                    <div data-kid=\"32\">\n                        <p class=\"text-3xl font-black text-white\" data-kid=\"33\">2M</p>\n                        <p class=\"text-[9px] uppercase tracking-widest text-white/40 font-mono mt-1\" data-kid=\"34\">Automations</p>\n                    </div>\n                </div>\n            </div>\n\n            <div class=\"lg:col-span-5 hidden lg:flex justify-end perspective-1000\" data-kid=\"35\">\n                <div class=\"hero-core-wrapper relative w-80 h-[500px] rounded-[3rem] border border-white/20 bg-[#111] overflow-hidden shadow-2xl rotate-y-[-10deg] rotate-x-[5deg] group\" data-kid=\"36\">\n                    <div class=\"absolute inset-0 bg-gradient-to-t from-[#6C3AED]/30 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-1000\" data-kid=\"37\"></div>\n                    <video src=\"https://videos.pexels.com/video-files/11738195/11738195-hd_1280_720_24fps.mp4\" poster=\"https://images.pexels.com/videos/11738195/pexels-photo-11738195.jpeg?auto=compress&cs=tinysrgb&fit=crop&h=630&w=1200\" autoplay muted loop playsinline class=\"absolute inset-0 w-full h-full object-cover opacity-40 mix-blend-overlay\" data-kid=\"38\"></video>\n                    \n                    <div class=\"absolute inset-0 flex flex-col p-8 justify-between\" data-kid=\"39\">\n                        <div class=\"flex justify-between items-start\" data-kid=\"40\">\n                            <div class=\"w-12 h-12 rounded-2xl bg-[#6C3AED] flex items-center justify-center shadow-lg shadow-[#6C3AED]/40\" data-kid=\"41\">\n                                <i class=\"ti ti-atom text-white text-2xl\" data-kid=\"42\"></i>\n                            </div>\n                            <div class=\"font-mono text-[10px] text-white/40 text-right uppercase leading-tight\" data-kid=\"43\">System Status<br data-kid=\"44\"><span class=\"text-emerald-500 font-bold\" data-kid=\"45\">Optimizing</span></div>\n                        </div>\n                        \n                        <div class=\"space-y-4\" data-kid=\"46\">\n                            <div class=\"p-4 bg-white/5 border border-white/10 rounded-2xl backdrop-blur-md\" data-kid=\"47\">\n                                <p class=\"text-[10px] text-white/40 font-mono mb-1 uppercase tracking-tighter\" data-kid=\"48\">AI Suggestion</p>\n                                <p class=\"text-sm font-bold text-white leading-tight\" data-kid=\"49\">Reschedule Q3 Review to Monday based on energy levels.</p>\n                            </div>\n                            <div class=\"p-4 bg-white/5 border border-white/10 rounded-2xl backdrop-blur-md opacity-40\" data-kid=\"50\">\n                                <p class=\"text-sm font-bold text-white\" data-kid=\"51\">Pay Infrastructure Bills</p>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n\n        <div class=\"absolute inset-0 pointer-events-none\" id=\"particle-drift\" data-kid=\"52\"></div>\n    </section>\n\n    \n    <section id=\"chaos\" class=\"relative w-full h-[150vh] bg-[#0A0A0A] overflow-hidden\" data-kid=\"53\">\n        <div class=\"sticky top-0 h-screen w-full flex flex-col items-center justify-center px-6\" data-kid=\"54\">\n            <h2 id=\"chaos-headline\" class=\"text-5xl md:text-8xl font-black text-white text-center z-10 max-w-4xl leading-[0.9] tracking-tighter\" data-kid=\"55\">\n                Work shouldn't <br data-kid=\"56\"> feel like this.\n            </h2>\n            \n            <div id=\"scatter-tasks\" class=\"absolute inset-0 pointer-events-none\" data-kid=\"57\"></div>\n        </div>\n    </section>\n\n    \n    <section id=\"understand\" class=\"relative w-full h-[150vh] bg-[#0A0A0A] overflow-hidden\" data-kid=\"58\">\n        <div class=\"sticky top-0 h-screen w-full flex items-center justify-center px-6\" data-kid=\"59\">\n            <div id=\"understand-core\" class=\"relative w-72 h-72 rounded-full bg-[#6C3AED] blur-[140px] opacity-0\" data-kid=\"60\"></div>\n            <div id=\"understand-core-visual\" class=\"absolute w-48 h-48 rounded-full border border-white/20 flex items-center justify-center overflow-hidden opacity-0 scale-50 shadow-[0_0_80px_rgba(108,58,237,0.5)]\" data-kid=\"61\">\n                <div class=\"absolute inset-0 bg-gradient-to-tr from-[#6C3AED]/20 to-transparent animate-spin-slow\" data-kid=\"62\"></div>\n                <i class=\"ti ti-brain text-7xl text-white relative z-10 drop-shadow-2xl\" data-kid=\"63\"></i>\n            </div>\n            \n            <div class=\"absolute top-32 text-center w-full max-w-4xl px-6\" data-kid=\"64\">\n                <h2 class=\"text-5xl md:text-8xl font-black text-white mb-6 tracking-tighter leading-[0.85]\" data-kid=\"65\">AI knows <br data-kid=\"66\"> your limits.</h2>\n                <p class=\"text-[#6C3AED] font-bold font-['IBM_Plex_Mono'] text-xs uppercase tracking-widest\" data-kid=\"67\">Context-aware priority detection.</p>\n            </div>\n\n            <svg id=\"understand-lines\" class=\"absolute inset-0 w-full h-full pointer-events-none opacity-30 z-0\" data-kid=\"68\"></svg>\n        </div>\n    </section>\n\n    \n    <section id=\"organize\" class=\"relative w-full h-[200vh] bg-white\" data-kid=\"69\">\n        <div class=\"absolute inset-0 bg-[radial-gradient(circle_at_100%_0%,rgba(108,58,237,0.03),transp