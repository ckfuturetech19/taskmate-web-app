      "html": "\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css');\n\n  :root {\n    --bg-primary: #0F0A1A;\n    --bg-secondary: #1A1228;\n    --bg-tertiary: #241B35;\n    --bg-card: rgba(26,18,40,0.8);\n    --bg-glass: rgba(26,18,40,0.5);\n    --text-primary: #F0EEF8;\n    --text-secondary: #B8B0D4;\n    --text-muted: #7A7090;\n    --border: rgba(255,255,255,0.07);\n    --border-hover: rgba(139,101,200,0.35);\n    --nav-bg: rgba(15,10,26,0.85);\n    --card-shadow: 0 20px 60px rgba(0,0,0,0.5);\n    --glow-purple: rgba(139,101,200,0.15);\n    --glow-teal: rgba(74,191,184,0.10);\n    --glow-pink: rgba(240,96,122,0.10);\n    --scrollbar-thumb: #241B35;\n    --scrollbar-thumb-hover: #8B65C8;\n    \n    --orange: #F5A87B;\n    --pink: #F0607A;\n    --purple: #8B65C8;\n    --teal: #4ABFB8;\n    --grad-primary: linear-gradient(135deg, #F5A87B, #F0607A, #8B65C8, #4ABFB8);\n    --grad-cta: linear-gradient(135deg, #F0607A, #8B65C8);\n  }\n\n  [data-theme=\"light\"] {\n    --bg-primary: #F8F5FF;\n    --bg-secondary: #FFFFFF;\n    --bg-tertiary: #F0E6FF;\n    --bg-card: #FFFFFF;\n    --bg-glass: rgba(255, 255, 255, 0.85);\n    --text-primary: #10081D;\n    --text-secondary: #3D3252;\n    --text-muted: #7E7296;\n    --border: rgba(139, 101, 200, 0.15);\n    --border-hover: rgba(139, 101, 200, 0.40);\n    --nav-bg: rgba(248, 245, 255, 0.92);\n    --card-shadow: 0 12px 40px rgba(139, 101, 200, 0.08);\n    --glow-purple: rgba(139, 101, 200, 0.1);\n    --glow-teal: rgba(74, 191, 184, 0.1);\n    --glow-pink: rgba(240, 96, 122, 0.1);\n    --scrollbar-thumb: #D8D0EA;\n    --scrollbar-thumb-hover: #8B65C8;\n  }\n\n  *, *::before, *::after {\n    transition: background-color 0.3s ease, border-color 0.3s ease, color 0.3s ease, box-shadow 0.3s ease;\n  }\n\n  body {\n    font-family: 'Inter', sans-serif;\n    background-color: var(--bg-primary);\n    color: var(--text-primary);\n    overflow-x: hidden;\n  }\n\n  /* Scrollbar */\n  ::-webkit-scrollbar { width: 6px; }\n  ::-webkit-scrollbar-track { background: var(--bg-primary); }\n  ::-webkit-scrollbar-thumb { background: var(--scrollbar-thumb); border-radius: 10px; }\n  ::-webkit-scrollbar-thumb:hover { background: var(--scrollbar-thumb-hover); }\n\n  .grad-text {\n    background: var(--grad-primary);\n    -webkit-background-clip: text;\n    -webkit-text-fill-color: transparent;\n  }\n\n  /* Animations */\n  @keyframes aurora-rotate {\n    0% { transform: translate(-50%,-50%) rotate(0deg) scale(1); }\n    50% { transform: translate(-50%,-50%) rotate(180deg) scale(1.2); }\n    100% { transform: translate(-50%,-50%) rotate(360deg) scale(1); }\n  }\n\n  @keyframes particle-float {\n    0%,100% { transform: translateY(0) translateX(0) opacity(0.2); }\n    33% { transform: translateY(-30px) translateX(15px); opacity: 0.5; }\n    66% { transform: translateY(20px) translateX(-10px); opacity: 0.2; }\n  }\n\n  @keyframes voice-wave {\n    0%,100% { height: 8px; }\n    50% { height: var(--peak, 40px); }\n  }\n\n  @keyframes glow-pulse {\n    0%,100% { box-shadow: 0 0 20px rgba(139,101,200,0.25), 0 20px 60px rgba(0,0,0,0.4); }\n    50% { box-shadow: 0 0 45px rgba(139,101,200,0.45), 0 20px 60px rgba(0,0,0,0.4); }\n  }\n\n  @keyframes chip-float {\n    0%,100% { transform: translateY(0px); }\n    50% { transform: translateY(-8px); }\n  }\n\n  .reveal { opacity: 1; transform: translateY(0); }\n\n  .aurora {\n    position: absolute;\n    border-radius: 50%;\n    filter: blur(100px);\n    z-index: 0;\n    pointer-events: none;\n    animation: aurora-rotate 60s linear infinite;\n  }\n\n  .particle {\n    position: absolute;\n    width: 4px;\n    height: 4px;\n    border-radius: 50%;\n    pointer-events: none;\n    animation: particle-float 10s ease-in-out infinite;\n  }\n\n  .perspective-container {\n    perspective: 1500px;\n  }\n\n  .mockup-3d {\n    transform: rotateX(8deg) rotateY(-6deg) rotateZ(1deg);\n    transition: transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);\n  }\n\n  .mockup-3d:hover {\n    transform: rotateX(0deg) rotateY(0deg);\n  }\n\n  /* Marquee */\n  .marquee {\n    mask-image: linear-gradient(to right, transparent, black 15%, black 85%, transparent);\n  }\n  @keyframes marquee {\n    0% { transform: translateX(0); }\n    100% { transform: translateX(-50%); }\n  }\n  .marquee-content {\n    animation: marquee 30s linear infinite;\n  }\n  .marquee-content:hover {\n    animation-play-state: paused;\n  }\n\n  /* Nav */\n  nav.scrolled {\n    background: var(--nav-bg);\n    backdrop-filter: blur(12px);\n    border-color: var(--border);\n    padding-top: 0.75rem;\n    padding-bottom: 0.75rem;\n  }\n\n  /* Pricing toggle */\n  .pricing-toggle .active {\n    background: var(--purple);\n    color: white;\n  }\n\n  /* Floating UI widgets */\n  .float-widget {\n    animation: chip-float 4s ease-in-out infinite;\n  }\n\n  /* FAQ Accordion */\n  .faq-answer {\n    max-height: 0;\n    overflow: hidden;\n    transition: max-height 0.3s cubic-bezier(0.4, 0, 0.2, 1), margin 0.3s;\n  }\n  .faq-item.active .faq-answer {\n    max-height: 200px;\n    margin-top: 1rem;\n  }\n  .faq-item.active i.ti-plus {\n    transform: rotate(45deg);\n  }\n</style>\n\n\n<nav id=\"navbar\" class=\"absolute top-0 left-0 w-full z-50 transition-all duration-300 px-6 py-4 border-b border-[var(--border)] bg-[var(--nav-bg)] backdrop-blur-xl\" data-kid=\"1\">\n  <div class=\"max-w-7xl mx-auto flex items-center justify-between\" data-kid=\"2\">\n    <div class=\"flex items-center gap-2\" data-kid=\"3\">\n      <svg class=\"w-10 h-10\" viewBox=\"0 0 40 40\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\" data-kid=\"4\">\n        <rect width=\"40\" height=\"40\" rx=\"10\" fill=\"url(#logoGrad)\" data-kid=\"5\"></rect>\n        <defs data-kid=\"6\">\n          <linearGradient id=\"logoGrad\" x1=\"0\" y1=\"40\" x2=\"40\" y2=\"0\" data-kid=\"7\">\n            <stop offset=\"0%\" stop-color=\"#F5A87B\" data-kid=\"8\"></stop>\n            <stop offset=\"30%\" stop-color=\"#F0607A\" data-kid=\"9\"></stop>\n            <stop offset=\"65%\" stop-color=\"#8B65C8\" data-kid=\"10\"></stop>\n            <stop offset=\"100%\" stop-color=\"#4ABFB8\" data-kid=\"11\"></stop>\n          </linearGradient>\n        </defs>\n        <circle cx=\"20\" cy=\"20\" r=\"11\" stroke=\"white\" stroke-width=\"2.5\" fill=\"none\" data-kid=\"12\"></circle>\n        <path d=\"M14 20.5L18 24.5L26 16\" stroke=\"white\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\" data-kid=\"13\"></path>\n      </svg>\n      <span class=\"text-xl font-bold tracking-tight\" data-kid=\"14\">TaskMate AI</span>\n    </div>\n\n    <div class=\"hidden md:flex items-center gap-8 text-sm font-medium\" data-kid=\"15\">\n      <a href=\"#features\" class=\"text-[var(--text-secondary)] hover:text-[var(--text-primary)] transition-colors\" data-kid=\"16\">Features</a>\n      <a href=\"#how-it-works\" class=\"text-[var(--text-secondary)] hover:text-[var(--text-primary)] transition-colors\" data-kid=\"17\">How it works</a>\n      <a href=\"#pricing\" class=\"text-[var(--text-secondary)] hover:text-[var(--text-primary)] transition-colors\" data-kid=\"18\">Pricing</a>\n      <a href=\"#faq\" class=\"text-[var(--text-secondary)] hover:text-[var(--text-primary)] transition-colors\" data-kid=\"19\">FAQ</a>\n    </div>\n\n    <div class=\"flex items-center gap-4\" data-kid=\"20\">\n      <button id=\"theme-toggle\" class=\"p-2 rounded-full hover:bg-[var(--bg-tertiary)] transition-colors cursor-pointer\" aria-label=\"Toggle Theme\" data-kid=\"21\">\n        <i class=\"ti ti-moon text-xl\" id=\"theme-icon\" data-kid=\"22\"></i>\n      </button>\n      <a href=\"#\" class=\"hidden sm:block text-sm font-semibold text-[var(--text-secondary)] hover:text-[var(--text-primary)]\" data-kid=\"23\">Sign in</a>\n      <a href=\"#\" class=\"px-5 py-2.5 rounded-full bg-[var(--grad-cta)] text-white text-sm font-bold shadow-lg shadow-[var(--purple)]/20 hover:scale-105 transition-transform\" data-kid=\"24\">\n        Download Free →\n      </a>\n      <button class=\"md:hidden p-2\" id=\"mobile-menu-btn\" data-kid=\"25\">\n        <i class=\"ti ti-menu-2 text-2xl\" data-kid=\"26\"></i>\n      </button>\n    </div>\n  </div>\n</nav>\n\n\n<div id=\"mobile-menu\" class=\"fixed inset-0 z-40 bg-[var(--bg-primary)] pt-24 px-6 translate-x-full transition-transform duration-300 md:hidden\" data-kid=\"27\">\n  <div class=\"flex flex-col gap-6 text-2xl font-bold\" data-kid=\"28\">\n    <a href=\"#features\" class=\"mobile-nav-link\" data-kid=\"29\">Features</a>\n    <a href=\"#how-it-works\" class=\"mobile-nav-link\" data-kid=\"30\">How it works</a>\n    <a href=\"#pricing\" class=\"mobile-nav-link\" data-kid=\"31\">Pricing</a>\n    <a href=\"#faq\" class=\"mobile-nav-link\" data-kid=\"32\">FAQ</a>\n    <hr class=\"border-[var(--border)]\" data-kid=\"33\">\n    <a href=\"#\" class=\"text-xl\" data-kid=\"34\">Sign in</a>\n  </div>\n</div>\n\n\n<section class=\"relative min-h-[1000px] flex flex-col items-center justify-center pt-32 pb-20 px-6 overflow-hidden\" data-kid=\"35\">\n  \n  <div class=\"aurora w-[800px] h-[800px] bg-[var(--purple)] top-0 left-1/4 opacity-10\" data-kid=\"36\"></div>\n  <div class=\"aurora w-[600px] h-[600px] bg-[var(--teal)] bottom-0 right-1/4 opacity-10\" style=\"animation-delay: -10s;\" data-kid=\"37\"></div>\n  \n  \n  <div id=\"particle-container\" data-kid=\"38\"></div>\n\n  <div class=\"relative z-10 text-center max-w-5xl mx-auto reveal\" data-kid=\"39\">\n    <div class=\"inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-[var(--bg-tertiary)] border border-[var(--border)] text-xs font-semibold mb-8\" data-kid=\"40\">\n      <span class=\"w-2 h-2 rounded-full bg-[var(--teal)] animate-pulse\" data-kid=\"41\"></span>\n      <span class=\"text-[var(--text-secondary)] uppercase tracking-widest\" data-kid=\"42\">AI-Powered Task Intelligence · v1.7.0</span>\n    </div>\n    \n    <h1 class=\"text-6xl md:text-8xl font-extrabold tracking-tight mb-8 leading-[1] transition-delay-100\" data-kid=\"43\">\n      Plan smarter.<br data-kid=\"44\">\n      <span class=\"grad-text\" data-kid=\"45\">Live better.</span>\n    </h1>\n    \n    <p class=\"text-lg md:text-2xl text-[var(--text-secondary)] max-w-2xl mx-auto mb-12 leading-relaxed transition-delay-200\" data-kid=\"46\">\n      TaskMate uses spatial AI to understand your workflow, block distractions, and organize your life with zero effort.\n    </p>\n\n    <div class=\"flex flex-wrap justify-center gap-6 mb-12 transition-delay-300\" data-kid=\"47\">\n      <button class=\"px-10 py-5 rounded-full bg-[var(--grad-cta)] text-white text-lg font-bold shadow-xl shadow-[var(--purple)]/30 hover:scale-105 transition-all cursor-pointer\" data-kid=\"48\">\n        Get Started Free\n      </button>\n      <button class=\"px-10 py-5 rounded-full border border-[var(--border)] bg-[var(--bg-glass)] backdrop-blur-md text-[var(--text-primary)] text-lg font-bold hover:bg-[var(--bg-tertiary)] transition-all flex items-center gap-3 cursor-pointer\" data-kid=\"49\">\n        <i class=\"ti ti-player-play-filled\" data-kid=\"50\"></i> Watch Demo\n      </button>\n    </div>\n\n    <div class=\"flex justify-center items-center gap-8 text-[var(--text-muted)] text-sm font-medium transition-delay-400\" data-kid=\"51\">\n      <div class=\"flex items-center gap-2\" data-kid=\"52\"><i class=\"ti ti-brand-android text-xl\" data-kid=\"53\"></i> Android Live</div>\n      <div class=\"flex items-center gap-2 opacity-50\" data-kid=\"54\"><i class=\"ti ti-brand-apple text-xl\" data-kid=\"55\"></i> App Store Soon</div>\n      <div class=\"flex items-center gap-2\" data-kid=\"56\"><i class=\"ti ti-world text-xl\" data-kid=\"57\"></i> Web App</div>\n    </div>\n  </div>\n\n  \n  <div class=\"relative w-full max-w-5xl mx-auto mt-32 perspective-container reveal transition-delay-500\" data-kid=\"58\">\n    <div class=\"mockup-3d rounded-3xl border border-white/10 bg-black/40 shadow-[0_40px_120px_rgba(0,0,0,0.7)] overflow-hidden backdrop-blur-xl group\" data-kid=\"59\">\n      <img src=\"/api/local/images/assets/dashboardDark.png\" alt=\"TaskMate AI Interface\" class=\"w-full h-auto opacity-80 group-hover:opacity-100 transition-opacity duration-700\" decoding=\"async\" loading=\"lazy\" data-kid=\"60\">\n    </div>\n\n    \n    <div class=\"absolute -top-12 -left-16 bg-[var(--bg-secondary)] border border-[var(--border)] p-5 rounded-2xl shadow-2xl float-widget w-56 hidden lg:block z-20\" style=\"animation-duration: 5s;\" data-kid=\"61\">\n      <div class=\"flex items-center gap-4 mb-3\" data-kid=\"62\">\n        <div class=\"w-10 h-10 rounded-full bg-[var(--purple)]/20 flex items-center justify-center\" data-kid=\"63\">\n          <i class=\"ti ti-microphone text-[var(--purple)] text-xl\" data-kid=\"64\"></i>\n        </div>\n        <div data-kid=\"65\">\n          <div class=\"text-xs font-bold\" data-kid=\"66\">Voice Active</div>\n          <div class=\"text-[10px] text-[var(--teal)] font-bold\" data-kid=\"67\">LISTENING</div>\n        </div>\n      </div>\n      <p class=\"text-[11px] text-[var(--text-muted)] italic leading-tight\" data-kid=\"68\">\"Remind me to call the design team tomorrow morning\"</p>\n    </div>\n\n    <div class=\"absolute -bottom-8 -right-20 bg-[var(--bg-secondary)] border border-[var(--border)] p-5 rounded-2xl shadow-2xl float-widget w-64 hidden lg:block z-20\" style=\"animation-duration: 6s; animation-delay: -2s;\" data-kid=\"69\">\n      <div class=\"flex items-center gap-4 mb-3\" data-kid=\"70\">\n        <div class=\"w-10 h-10 rounded-full bg-[var(--teal)]/20 flex items-center justify-center\" data-kid=\"71\">\n          <i class=\"ti ti-circle-check text-[var(--teal)] text-xl\" data-kid=\"72\"></i>\n        </div>\n        <div data-kid=\"73\">\n          <div class=\"text-xs font-bold\" data-kid=\"74\">Focus Complete</div>\n          <div class=\"text-[10px] text-[var(--purple)] font-bold\" data-kid=\"75\">3 SESSIONS</div>\n        </div>\n      </div>\n      <p class=\"text-[11px] text-[var(--text-muted)] leading-tight\" data-kid=\"76\">Deep work session: 45m finished. Your productivity score improved by 12% today.</p>\n    </div>\n  </div>\n</section>\n\n\n<section class=\"py-12 border-y border-[var(--border)] bg-[var(--bg-secondary)] overflow-hidden\" data-kid=\"77\">\n  <div class=\"max-w-7xl mx-auto grid grid-cols-2 md:grid-cols-4 gap-8 px-6\" data-kid=\"78\">\n    <div class=\"text-center reveal\" data-kid=\"79\">\n      <div class=\"text-4xl font-extrabold grad-text mb-1\" data-kid=\"80\"><span class=\"stat-count\" data-target=\"1200\" data-kid=\"81\">0</span>+</div>\n      <div class=\"text-sm font-semibold text-[var(--text-muted)] uppercase tracking-widest\" data-kid=\"82\">Global Users</div>\n    </div>\n    <div class=\"text-center reveal\" style=\"transition-delay: 100ms\" data-kid=\"83\">\n      <div class=\"text-4xl font-extrabold grad-text mb-1\" data-kid=\"84\"><span class=\"stat-count\" data-target=\"4.8\" data-decimal=\"1\" data-kid=\"85\">0</span>★</div>\n      <div class=\"text-sm font-semibold text-[var(--text-muted)] uppercase tracking-widest\" data-kid=\"86\">User Rating</div>\n    </div>\n    <div class=\"text-center reveal\" style=\"transition-delay: 200ms\" data-kid=\"87\">\n      <div class=\"text-4xl font-extrabold grad-text mb-1\" data-kid=\"88\"><span class=\"stat-count\" data-target=\"6\" data-kid=\"89\">0</span></div>\n      <div class=\"text-sm font-semibold text-[var(--text-muted)] uppercase tracking-widest\" data-kid=\"90\">Languages</div>\n    </div>\n    <div class=\"text-center reveal\" style=\"transition-delay: 300ms\" data-kid=\"91\">\n      <div class=\"text-4xl font-extrabold grad-text mb-1\" data-kid=\"92\">₹<span class=\"stat-count\" data-target=\"0\" data-kid=\"93\">0</span></div>\n      <div class=