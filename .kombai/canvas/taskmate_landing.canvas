pu text-8xl text-[var(--pink)]/20 group-hover:scale-125 transition-transform duration-700\" data-kid=\"109\"></i>\n        </div>\n      </div>\n\n      \n      <div class=\"rounded-[40px] bg-[var(--bg-secondary)] border border-[var(--border)] p-10 reveal hover:border-[var(--purple)] hover:shadow-[inset_0_0_20px_rgba(139,101,200,0.05)] transition-all group\" data-kid=\"110\">\n        <div class=\"w-14 h-14 rounded-2xl bg-[var(--purple)]/20 flex items-center justify-center mb-8 group-hover:scale-110 transition-transform\" data-kid=\"111\">\n          <i class=\"ti ti-microphone text-[var(--purple)] text-2xl\" data-kid=\"112\"></i>\n        </div>\n        <h4 class=\"text-xl font-bold mb-3\" data-kid=\"113\">Voice to Task</h4>\n        <p class=\"text-[var(--text-muted)] text-sm\" data-kid=\"114\">Just speak your mind. Our AI transcribes, parses deadlines, and categorizes tasks in one go.</p>\n      </div>\n\n      \n      <div class=\"rounded-[40px] bg-[var(--bg-secondary)] border border-[var(--border)] p-10 reveal hover:border-[var(--purple)] transition-colors group\" data-kid=\"115\">\n        <div class=\"w-14 h-14 rounded-2xl bg-[var(--teal)]/20 flex items-center justify-center mb-8 group-hover:scale-110 transition-transform\" data-kid=\"116\">\n          <i class=\"ti ti-bell-ringing text-[var(--teal)] text-2xl\" data-kid=\"117\"></i>\n        </div>\n        <h4 class=\"text-xl font-bold mb-3\" data-kid=\"118\">Smart Reminders</h4>\n        <p class=\"text-[var(--text-muted)] text-sm\" data-kid=\"119\">Context-aware alerts that ping you when you're at the right place or have the right time window.</p>\n      </div>\n\n      \n      <div class=\"rounded-[40px] bg-[var(--bg-secondary)] border border-[var(--border)] p-10 reveal hover:border-[var(--purple)] transition-colors group\" data-kid=\"120\">\n        <div class=\"w-14 h-14 rounded-2xl bg-[var(--orange)]/20 flex items-center justify-center mb-8 group-hover:scale-110 transition-transform\" data-kid=\"121\">\n          <i class=\"ti ti-calendar-event text-[var(--orange)] text-2xl\" data-kid=\"122\"></i>\n        </div>\n        <h4 class=\"text-xl font-bold mb-3\" data-kid=\"123\">Calendar Sync</h4>\n        <p class=\"text-[var(--text-muted)] text-sm\" data-kid=\"124\">Perfect harmony between your to-do list and your calendar. Two-way sync with all major platforms.</p>\n      </div>\n\n      \n      <div class=\"rounded-[40px] bg-[var(--bg-secondary)] border border-[var(--border)] p-10 reveal hover:border-[var(--purple)] transition-colors group\" data-kid=\"125\">\n        <div class=\"w-14 h-14 rounded-2xl bg-[var(--purple)]/20 flex items-center justify-center mb-8 group-hover:scale-110 transition-transform\" data-kid=\"126\">\n          <i class=\"ti ti-focus-2 text-[var(--purple)] text-2xl\" data-kid=\"127\"></i>\n        </div>\n        <h4 class=\"text-xl font-bold mb-3\" data-kid=\"128\">Focus Mode Pro</h4>\n        <p class=\"text-[var(--text-muted)] text-sm\" data-kid=\"129\">One tap to block distractions and enter a flow state with ambient sounds and focus timers.</p>\n      </div>\n\n      \n      <div class=\"rounded-[40px] bg-[var(--bg-secondary)] border border-[var(--border)] p-10 reveal hover:border-[var(--purple)] transition-colors group\" data-kid=\"130\">\n        <div class=\"w-14 h-14 rounded-2xl bg-[var(--teal)]/20 flex items-center justify-center mb-8 group-hover:scale-110 transition-transform\" data-kid=\"131\">\n          <i class=\"ti ti-layout-dashboard text-[var(--teal)] text-2xl\" data-kid=\"132\"></i>\n        </div>\n        <h4 class=\"text-xl font-bold mb-3\" data-kid=\"133\">Home Screen Widgets</h4>\n        <p class=\"text-[var(--text-muted)] text-sm\" data-kid=\"134\">Beautiful, interactive widgets for your home screen to keep your tasks front and center.</p>\n      </div>\n    </div>\n  </div>\n</section>\n\n\n<section id=\"how-it-works\" class=\"py-32 px-6 bg-[var(--bg-secondary)]\" data-kid=\"135\">\n  <div class=\"max-w-7xl mx-au