\"331\">\n                            <div class=\"w-12 h-12 rounded-full bg-gradient-to-tr from-[var(--purple)] to-[var(--teal)] flex items-center justify-center text-white font-bold\" data-kid=\"332\">MM</div>\n                            <div data-kid=\"333\">\n                                <div class=\"font-bold text-[var(--text-primary)]\" data-kid=\"334\">Meera Mishra</div>\n                                <div class=\"text-xs text-[var(--text-muted)]\" data-kid=\"335\">Content Strategist</div>\n                            </div>\n                        </div>\n                    </div>\n                    \n                    <div class=\"testimonial-card\" data-kid=\"336\">\n                        <div class=\"flex gap-1 text-[var(--orange)] mb-4\" data-kid=\"337\">\n                            <i class=\"ti ti-star-filled\" data-kid=\"338\"></i><i class=\"ti ti-star-filled\" data-kid=\"339\"></i><i class=\"ti ti-star-filled\" data-kid=\"340\"></i><i class=\"ti ti-star-filled\" data-kid=\"341\"></i><i class=\"ti ti-star-filled\" data-kid=\"342\"></i>\n                        </div>\n                        <p class=\"text-[var(--text-secondary)] italic text-lg leading-relaxed mb-8\" data-kid=\"343\">\"TaskMate AI has completely changed how I organize my day. The voice feature is like having a real assistant in my pocket.\"</p>\n                        <div class=\"flex items-center gap-4\" data-kid=\"344\">\n                            <div class=\"w-12 h-12 rounded-full bg-gradient-to-tr from-[var(--purple)] to-[var(--pink)] flex items-center justify-center text-white font-bold\" data-kid=\"345\">AS</div>\n                            <div data-kid=\"346\">\n                                <div class=\"font-bold text-[var(--text-primary)]\" data-kid=\"347\">Arjun Sharma</div>\n                                <div class=\"text-xs text-[var(--text-muted)]\" data-kid=\"348\">Product Manager @ TechFlow</div>\n                            </div>\n                        </div>\n                    </div>\n                    <div class=\"testimonial-card\" data-kid=\"349\">\n                        <div class=\"flex gap-1 text-[var(--orange)] mb-4\" data-kid=\"350\">\n                            <i class=\"ti ti-star-filled\" data-kid=\"351\"></i><i class=\"ti ti-star-filled\" data-kid=\"352\"></i><i class=\"ti ti-star-filled\" data-kid=\"353\"></i><i class=\"ti ti-star-filled\" data-kid=\"354\"></i><i class=\"ti ti-star-filled\" data-kid=\"355\"></i>\n                        </div>\n                        <p class=\"text-[var(--text-secondary)] italic text-lg leading-relaxed mb-8\" data-kid=\"356\">\"I've tried every todo app out there. Nothing comes close to the AI intelligence of TaskMate. It actually understands me.\"</p>\n                        <div class=\"flex items-center gap-4\" data-kid=\"357\">\n                            <div class=\"w-12 h-12 rounded-full bg-gradient-to-tr from-[var(--teal)] to-[var(--purple)] flex items-center justify-center text-white font-bold\" data-kid=\"358\">NP</div>\n                            <div data-kid=\"359\">\n                                <div class=\"font-bold text-[var(--text-primary)]\" data-kid=\"360\">Neha Patel</div>\n                                <div class=\"text-xs text-[var(--text-muted)]\" data-kid=\"361\">Freelance Designer</div>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    \n    <section id=\"faq\" class=\"py-32 bg-[var(--bg-primary)]\" data-kid=\"362\">\n        <div class=\"max-w-3xl mx-auto px-4\" data-kid=\"363\">\n            <div class=\"reveal text-center mb-16 space-y-4\" data-kid=\"364\">\n                <h2 class=\"text-4xl font-bold text-[var(--text-primary)]\" data-kid=\"365\">Got Questions?</h2>\n                <p class=\"text-[var(--text-secondary)]\" data-kid=\"366\">Everything you need to know about TaskMate AI.</p>\n            </div>\n\n            <div class=\"space-y-4\" data-kid=\"367\">\n                \n                <div class=\"reveal faq-item bg-[var(--bg-secondary)] border border-[var(--border)] rounded-2xl overflow-hidden\" data-kid=\"368\">\n                    <button class=\"w-full p-6 text-left flex items-center justify-between group\" onclick=\"toggleFAQ(this)\" data-kid=\"369\">\n                        <span class=\"text-lg font-bold text-[var(--text-primary)]\" data-kid=\"370\">Is TaskMate AI really free?</span>\n                        <div class=\"w-8 h-8 rounded-full bg-[var(--bg-tertiary)] flex items-center justify-center group-hover:bg-[var(--purple)] group-hover:text-white transition-all duration-300 transform\" data-kid=\"371\">\n                            <i class=\"ti ti-plus transition-transform duration-300\" data-kid=\"372\"></i>\n                        </div>\n                    </button>\n                    <div class=\"faq-content max-h-0 overflow-hidden transition-all duration-300\" data-kid=\"373\">\n                        <div class=\"p-6 pt-0 text-[var(--text-secondary)] leading-relaxed\" data-kid=\"374\">\n                            Yes! TaskMate AI offers a generous free tier that includes basic AI suggestions, unlimited tasks, and core voice transcription features. We believe everyone deserves to plan better.\n                        </div>\n                    </div>\n                </div>\n                \n                <div class=\"reveal faq-item bg-[var(--bg-secondary)] border border-[var(--border)] rounded-2xl overflow-hidden\" data-kid=\"375\">\n                    <button class=\"w-full p-6 text-left flex items-center justify-between group\" onclick=\"toggleFAQ(this)\" data-kid=\"376\">\n                        <span class=\"text-lg font-bold text-[var(--text-primary)]\" data-kid=\"377\">Which platforms is it available on?</span>\n                        <div class=\"w-8 h-8 rounded-full bg-[var(--bg-tertiary)] flex items-center justify-center group-hover:bg-[var(--purple)] group-hover:text-white transition-all duration-300 transform\" data-kid=\"378\">\n                            <i class=\"ti ti-plus transition-transform duration-300\" data-kid=\"379\"></i>\n                        </div>\n                    </button>\n                    <div class=\"faq-content max-h-0 overflow-hidden transition-all duration-300\" data-kid=\"380\">\n                        <div class=\"p-6 pt-0 text-[var(--text-secondary)] leading-relaxed\" data-kid=\"381\">\n                            Currently, we are live on Android (Play Store) and have a companion Web version. The iOS app is currently in beta and will be launching globally in late 2025.\n                        </div>\n                    </div>\n                </div>\n                \n                <div class=\"reveal faq-item bg-[var(--bg-secondary)] border border-[var(--border)] rounded-2xl overflow-hidden\" data-kid=\"382\">\n                    <button class=\"w-full p-6 text-left flex items-center justify-between group\" onclick=\"toggleFAQ(this)\" data-kid=\"383\">\n                        <span class=\"text-lg font-bold text-[var(--text-primary)]\" data-kid=\"384\">How does the AI suggestion engine work?</span>\n                        <div class=\"w-8 h-8 rounded-full bg-[var(--bg-tertiary)] flex items-center justify-center group-hover:bg-[var(--purple)] group-hover:text-white transition-all duration-300 transform\" data-kid=\"385\">\n                            <i class=\"ti ti-plus transition-transform duration-300\" data-kid=\"386\"></i>\n                        </div>\n                    </button>\n                    <div class=\"faq-content max-h-0 overflow-hidden transition-all duration-300\" data-kid=\"387\">\n                        <div class=\"p-6 pt-0 text-[var(--text-secondary)] leading-relaxed\" data-kid=\"388\">\n                            Our engine analyzes your historical completion rates, task priority, and the \"energy cost\" of activities to build an optimal schedule. It uses a private, fine-tuned LLM specifically for scheduling.\n                        </div>\n                    </div>\n                </div>\n                \n                <div class=\"reveal faq-item bg-[var(--bg-secondary)] border border-[var(--border)] rounded-2xl overflow-hidden\" data-kid=\"389\">\n                    <button class=\"w-full p-6 text-left flex items-center justify-between group\" onclick=\"toggleFAQ(this)\" data-kid=\"390\">\n                        <span class=\"text-lg font-bold text-[var(--text-primary)]\" data-kid=\"391\">Can I use TaskMate offline?</span>\n                        <div class=\"w-8 h-8 rounded-full bg-[var(--bg-tertiary)] flex items-center justify-center group-hover:bg-[var(--purple)] group-hover:text-white transition-all duration-300 transform\" data-kid=\"392\">\n                            <i class=\"ti ti-plus transition-transform duration-300\" data-kid=\"393\"></i>\n                        </div>\n                    </button>\n                    <div class=\"faq-content max-h-0 overflow-hidden transition-all duration-300\" data-kid=\"394\">\n                        <div class=\"p-6 pt-0 text-[var(--text-secondary)] leading-relaxed\" data-kid=\"395\">\n                            Yes, all core task management features work offline. AI suggestions and advanced voice transcription require an internet connection to process through our secure servers.\n                        </div>\n                    </div>\n                </div>\n                \n                <div class=\"reveal faq-item bg-[var(--bg-secondary)] border border-[var(--border)] rounded-2xl overflow-hidden\" data-kid=\"396\">\n                    <button class=\"w-full p-6 text-left flex items-center justify-between group\" onclick=\"toggleFAQ(this)\" data-kid=\"397\">\n                        <span class=\"text-lg font-bold text-[var(--text-primary)]\" data-kid=\"398\">Is team collaboration available?</span>\n                        <div class=\"w-8 h-8 rounded-full bg-[var(--bg-tertiary)] flex items-center justify-center group-hover:bg-[var(--purple)] group-hover:text-white transition-all duration-300 transform\" data-kid=\"399\">\n                            <i class=\"ti ti-plus transition-transform duration-300\" data-kid=\"400\"></i>\n                        </div>\n                    </button>\n                    <div class=\"faq-content max-h-0 overflow-hidden transition-all duration-300\" data-kid=\"401\">\n                        <div class=\"p-6 pt-0 text-[var(--text-secondary)] leading-relaxed\" data-kid=\"402\">\n                            Team collaboration is available on our Team plan, allowing shared workspaces, task delegation, and comprehensive project analytics for groups of any size.\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    \n    <section class=\"py-24 px-4 bg-[var(--bg-primary)]\" data-kid=\"403\">\n        <div class=\"reveal max-w-7xl mx-auto rounded-[3rem] bg-gradient-to-br from-[var(--bg-tertiary)] to-[var(--bg-secondary)] border border-[var(--border)] p-12 md:p-24 text-center relative overflow-hidden\" data-kid=\"404\">\n             \n             <div class=\"absolute -top-20 -left-20 w-80 h-80 bg-[var(--purple)]/10 blur-[100px] rounded-full\" data-kid=\"405\"></div>\n             <div class=\"absolute -bottom-20 -right-20 w-80 h-80 bg-[var(--teal)]/10 blur-[100px] rounded-full\" data-kid=\"406\"></div>\n             \n             <div class=\"relative z-10 space-y-8\" data-kid=\"407\">\n                 <h2 class=\"text-5xl md:text-6xl font-black text-[var(--text-primary)] tracking-tight\" data-kid=\"408\">Ready to plan smarter?</h2>\n                 <p class=\"text-xl text-[var(--text-secondary)] max-w-xl mx-auto\" data-kid=\"409\">Join 1,200+ users who have reclaimed their time with TaskMate AI.</p>\n                 <div class=\"flex flex-wrap justify-center gap-4 pt-4\" data-kid=\"410\">\n                     <button class=\"px-10 py-5 rounded-2xl bg-gradient-to-r from-[var(--pink)] to-[var(--purple)] text-white font-bold text-lg shadow-2xl hover:scale-105 active:scale-95 transition-all flex items-center gap-3\" data-kid=\"411\">\n                         <i class=\"ti ti-brand-android text-2xl\" data-kid=\"412\"></i> Get it on Play Store\n                     </button>\n                     <button class=\"px-10 py-5 rounded-2xl bg-[var(--bg-primary)] border border-[var(--border)] text-[var(--text-primary)] font-bold text-lg hover:border-[var(--purple)] transition-all flex items-center gap-3\" data-kid=\"413\">\n                         <i class=\"ti ti-brand-producthunt text-2xl text-[var(--orange)]\" data-kid=\"414\"></i> View on Product Hunt\n                     </button>\n                 </div>\n             </div>\n        </div>\n    </section>\n\n    \n    <footer class=\"py-20 bg-[var(--bg-secondary)] border-t border-[var(--border)] px-4\" data-kid=\"415\">\n        <div class=\"max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12\" data-kid=\"416\">\n            \n            <div class=\"space-y-6\" data-kid=\"417\">\n                <a href=\"#\" class=\"flex items-center gap-3\" data-kid=\"418\">\n                    <div class=\"w-10 h-10\" data-kid=\"419\">\n                        <svg viewBox=\"0 0 40 40\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\" data-kid=\"420\">\n                            <rect width=\"40\" height=\"40\" rx=\"10\" fill=\"url(#logoGrad2)\" data-kid=\"421\"></rect>\n                            <defs data-kid=\"422\">\n                                <linearGradient id=\"logoGrad2\" x1=\"0\" y1=\"40\" x2=\"40\" y2=\"0\" data-kid=\"423\">\n                                    <stop offset=\"0%\" stop-color=\"#F5A87B\" data-kid=\"424\"></stop>\n                                    <stop offset=\"30%\" stop-color=\"#F0607A\" data-kid=\"425\"></stop>\n                                    <stop offset=\"65%\" stop-color=\"#8B65C8\" data-kid=\"426\"></stop>\n                                    <stop offset=\"100%\" stop-color=\"#4ABFB8\" data-kid=\"427\"></stop>\n                                </linearGradient>\n                            </defs>\n                            <circle cx=\"20\" cy=\"20\" r=\"11\" stroke=\"white\" stroke-width=\"2.5\" fill=\"none\" data-kid=\"428\"></circle>\n                            <path d=\"M14 20.5L18 24.5L26 16\" stroke=\"white\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\" data-kid=\"429\"></path>\n                        </svg>\n                    </div>\n                    <span class=\"text-xl font-bold tracking-tight text-[var(--text-primary)]\" data-kid=\"430\">TaskMate AI</span>\n                </a>\n                <p class=\"text-[var(--text-secondary)] leading-relaxed\" data-kid=\"431\">\n                    Making world-class productivity tools accessible to everyone through the power of artificial intelligence.\n                </p>\n                <div class=\"flex items-center gap-2 text-[var(--text-muted)] text-sm\" data-kid=\"432\">\n                    <span data-kid=\"433\">Made in Ahmedabad 🇮🇳</span>\n                </div>\n                <div class=\"flex gap-4\" data-kid=\"434\">\n                    <a href=\"#\" class=\"w-10 h-10 rounded-lg bg-[var(--bg-tertiary)] flex items-center justify-center text-[var(--text-secondary)] hover:bg-[var(--purple)] hover:text-white transition-all\" data-kid=\"435\"><i class=\"ti ti-brand-twitter\" data-kid=\"436\"></i></a>\n                    <a href=\"#\" class=\"w-10 h-10 rounded-lg bg-[var(--bg-tertiary)] flex items-center justify-center text-[var(--text-secondary)] hover:bg-[var(--purple)] hover:text-white transition-all\" data-kid=\"437\"><i class=\"ti ti-brand-linkedin\" data-kid=\"438\"></i></a>\n                    <a href=\"#\" class=\"w-10 h-10 rounded-lg bg-[var(--bg-tertiary)] flex items-center justify-center text-[var(--text-secondary)] hover:bg-[var(--purple)] hover:text-white transition-all\" data-kid=\"439\"><i class=\"ti ti-brand-github\" data-kid=\"440\"></i></a>\n                    <a href=\"#\" class=\"w-10 h-10 rounded-lg bg-[var(--bg-tertiary)] flex items-center justify-center text-[var(--text-secondary)] hover:bg-[var(--purple)] hover:text-white transition-all\" data-kid=\"441\"><i class=\"ti ti-brand-instagram\" data-kid=\"442\"></i></a>\n                </div>\n            </div>\n\n            \n            <div data-kid=\"443\">\n                <h5 class=\"font-bold text-[var(--text-primary)] mb-6\" data-kid=\"444\">Product</h5>\n                <ul class=\"space-y-4 text-[var(--text-secondary)]\" data-kid=\"445\">\n                    <li data-kid=\"446\"><a href=\"#\" class=\"hover:text-[var(--purple)] transition-colors\" data-kid=\"447\">Features</a></li>\n                    <li data-kid=\"448\"><a href=\"#\" class=\"hover:text-[var(--purple)] transition-colors\" data-kid=\"449\">How it works</a></li>\n                    <li data-kid=\"450\"><a href=\"#\" class=\"hover:text-[var(--purple)] transition-colors\" data-kid=\"451\">Pricing</a></li>\n                    <li data-kid=\"452\"><a href=\"#\" class=\"hover:text-[var(--purple)] transition-colors\" data-kid=\"453\">Android App</a></li>\n                    <li data-kid=\"454\"><a href=\"#\" class=\"hover:text-[var(--purple)] transition-colors\" data-kid=\"455\">Web Dashboard</a></li>\n                </ul>\n            </div>\n            <div data-kid=\"456\">\n                <h5 class=\"font-bold text-[var(--text-primary)] mb-6\" data-kid=\"457\">Company</h5>\n                <ul class=\"space-y-4 text-[var(--text-secondary)]\" data-kid=\"458\">\n                    <li data-kid=\"459\"><a href=\"#\" class=\"hover:text-[var(--purple)] transition-colors\" data-kid=\"460\">About Us</a></li>\n                    <li data-kid=\"461\"><a href=\"#\" class=\"hover:text-[var(--purple)] transition-colors\" data-kid=\"462\">Careers</a></li>\n                    <li data-kid=\"463\"><a href=\"#\" class=\"hover:text-[var(--purple)] transition-colors\" data-kid=\"464\">Blog</a></li>\n                    <li data-kid=\"465\"><a href=\"#\" class=\"hover:text-[var(--purple)] transition-colors\" data-kid=\"466\">Media Kit</a></li>\n                    <li data-kid=\"467\"><a href=\"#\" class=\"hover:text-[var(--purple)] transition-colors\" data-kid=\"468\">Affiliate</a></li>\n                </ul>\n            </div>\n            <div data-kid=\"469\">\n                <h5 class=\"font-bold text-[var(--text-primary)] mb-6\" data-kid=\"470\">Legal</h5>\n                <ul class=\"space-y-4 text-[var(--text-secondary)]\" data-kid=\"471\">\n                    <li data-kid=\"472\"><a href=\"#\" class=\"hover:text-[var(--purple)] transition-colors\" data-kid=\"473\">Privacy Policy</a></li>\n                    <li data-kid=\"474\"><a href=\"#\" class=\"hover:text-[var(--purple)] transition-colors\" data-kid=\"475\">Terms of Service</a></li>\n                    <li data-kid=\"476\"><a href=\"#\" class=\"hover:text-[var(--purple)] transition-colors\" data-kid=\"477\">Security</a></li>\n                    <li data-kid=\"478\"><a href=\"#\" class=\"hover:text-[var(--purple)] transition-colors\" data-kid=\"479\">Cookie Policy</a></li>\n                </ul>\n            </div>\n        </div>\n        <div class=\"max-w-7xl mx-auto mt-20 pt-8 border-t border-[var(--border)] text-center text-[var(--text-muted)] text-sm\" data-kid=\"480\">\n            &copy; 2025 TaskMate AI. All rights reserved. Built with precision.\n        </div>\n    </footer>\n\n    <style data-kid=\"481\">\n        .testimonial-card {\n            width: 380px;\n            flex-shrink: 0;\n            background: var(--bg-secondary);\n            border: 1px solid var(--border);\n            padding: 2.5rem;\n            border-radius: 2rem;\n            transition: all 0.3s ease;\n        }\n        .testimonial-card:hover {\n            transform: translateY(-5px);\n            border-color: var(--purple);\n            box-shadow: 0 10px 30px rgba(0,0,0,0.2);\n        }\n    </style>\n\n    <script data-kid=\"482\">\n        // Theme Toggle Logic\n        const html = document.documentElement;\n        const themeBtn = document.getElementById('theme-toggle');\n        const themeIcon = document.getElementById('theme-icon');\n\n        const updateIcon = () => {\n            const isDark = html.dataset.theme === 'dark';\n            themeIcon.className = isDark ? 'ti ti-moon-stars text-xl' : 'ti ti-sun text-xl';\n        };\n\n        const toggleTheme = () => {\n            const isDark = html.dataset.theme === 'dark';\n            html.dataset.theme = isDark ? 'light' : 'dark';\n            localStorage.setItem('taskmate-theme', html.dataset.theme);\n            updateIcon();\n        };\n\n        themeBtn.addEventListener('click', toggleTheme);\n\n        // Load persisted theme\n        const savedTheme = localStorage.getItem('taskmate-theme') || 'dark';\n        html.dataset.theme = savedTheme;\n        updateIcon();\n\n        // Mobile Menu\n        const mobileBtn = document.getElementById('mobile-menu-btn');\n        const mobileMenu = document.getElementById('mobile-menu');\n        mobileBtn.addEventListener('click', () => {\n            mobileMenu.classList.toggle('hidden');\n            mobileMenu.classList.toggle('flex');\n        });\n\n        // Trigger animations and counters on load\n        window.addEventListener('load', () => {\n            document.querySelectorAll('.reveal').forEach(el => {\n                el.style.opacity = '1';\n                el.style.transform = 'none';\n                el.style.animation = 'none'; // Clear animation for static state after\n            });\n            document.querySelectorAll('.stat-counter').forEach(c => startCounter(c));\n        });\n\n        // Stat Counter\n        function startCounter(el) {\n            const target = parseInt(el.dataset.target);\n            const suffix = el.dataset.suffix || '';\n            let current = 0;\n            const duration = 2000;\n            const stepTime = 20;\n            const steps = duration / stepTime;\n            const increment = target / steps;\n\n            const timer = setInterval(() => {\n                current += increment;\n                if (current >= target) {\n                    el.innerText = target.toLocaleString() + suffix;\n                    clearInterval(timer);\n                } else {\n                    el.innerText = Math.floor(current).toLocaleString() + suffix;\n                }\n            }, stepTime);\n        }\n\n        // Sticky Nav\n        window.addEventListener('scroll', () => {\n            const nav = document.getElementById('navbar');\n            if (window.scrollY > 60) {\n                nav.classList.add('scrolled');\n            } else {\n                nav.classList.remove('scrolled');\n            }\n        });\n\n        // Pricing Toggle\n        const pricingToggle = document.getElementById('pricing-toggle');\n        const toggleCircle = document.getElementById('toggle-circle');\n        const pricingValues = document.querySelectorAll('.pricing-value');\n        let isAnnual = false;\n\n        pricingToggle.addEventListener('click', () => {\n            isAnnual = !isAnnual;\n            toggleCircle.style.transform = isAnnual ? 'translateX(28px)' : 'translateX(0)';\n            pricingToggle.style.background = isAnnual ? 'var(--purple)' : 'var(--bg-tertiary)';\n            \n            pricingValues.forEach(val => {\n                const targetValue = isAnnual ? val.dataset.annual : val.dataset.monthly;\n                val.innerText = '₹' + targetValue;\n            });\n        });\n\n        // How it works switcher\n        function switchStep(index) {\n            const cards = document.querySelectorAll('.step-card');\n            const panels = document.querySelectorAll('.preview-panel');\n            \n            cards.forEach((card, i) => {\n                if(i === index) {\n                    card.classList.add('active');\n                    card.classList.add('border-[var(--purple)]/50', 'bg-[var(--bg-secondary)]', 'shadow-xl');\n                    card.classList.remove('border-transparent');\n                } else {\n                    card.classList.remove('active');\n                    card.classList.remove('border-[var(--purple)]/50', 'bg-[var(--bg-secondary)]', 'shadow-xl');\n                    card.classList.add('border-transparent');\n                }\n            });\n\n            panels.forEach((panel, i) => {\n                if(i === index) {\n                    panel.classList.remove('hidden');\n                    panel.classList.add('animate-fade-up');\n                } else {\n                    panel.classList.add('hidden');\n                }\n            });\n        }\n\n        // FAQ Toggle\n        function toggleFAQ(btn) {\n            const content = btn.nextElementSibling;\n            const icon = btn.querySelector('i');\n            const isOpen = content.style.maxHeight !== '0px' && content.style.maxHeight !== '';\n            \n            // Close all\n            document.querySelectorAll('.faq-content').forEach(c => c.style.maxHeight = '0px');\n            document.querySelectorAll('.faq-item i').forEach(i => i.style.transform = 'rotate(0deg)');\n\n            if (!isOpen) {\n                content.style.maxHeight = content.scrollHeight + 'px';\n                icon.style.transform = 'rotate(45deg)';\n            }\n        }\n\n        // Generate particles\n        const host = document.getElementById('particles-host');\n        const colors = ['var(--purple)', 'var(--teal)', 'var(--pink)', 'var(--orange)'];\n        for (let i = 0; i < 12; i++) {\n            const p = document.createElement('div');\n            p.className = 'particle';\n            p.style.left = Math.random() * 100 + '%';\n            p.style.top = Math.random() * 100 + '%';\n            p.style.background = colors[Math.floor(Math.random() * colors.length)];\n            p.style.animationDelay = (Math.random() * 5) + 's';\n            p.style.animationDuration = (10 + Math.random() * 10) + 's';\n            host.appendChild(p);\n        }\n\n    </script>\n</div>\n",
