\"209\">\n      <h2 class=\"text-4xl md:text-5xl font-bold mb-6\" data-kid=\"210\">Simple, fair pricing.</h2>\n      <div class=\"pricing-toggle inline-flex items-center gap-2 p-1.5 rounded-full bg-[var(--bg-tertiary)] border border-[var(--border)] mb-4\" data-kid=\"211\">\n        <button class=\"px-6 py-2 rounded-full text-sm font-bold active transition-all cursor-pointer\" id=\"monthly-pricing\" data-kid=\"212\">Monthly</button>\n        <button class=\"px-6 py-2 rounded-full text-sm font-bold transition-all cursor-pointer\" id=\"yearly-pricing\" data-kid=\"213\">Annual <span class=\"text-[var(--teal)] font-normal ml-1\" data-kid=\"214\">(-20%)</span></button>\n      </div>\n    </div>\n\n    <div class=\"grid grid-cols-1 md:grid-cols-3 gap-8 items-stretch\" data-kid=\"215\">\n      \n      <div class=\"rounded-[40px] bg-[var(--bg-secondary)] border border-[var(--border)] p-10 flex flex-col reveal transition-delay-100\" data-kid=\"216\">\n        <h3 class=\"text-xl font-bold mb-2\" data-kid=\"217\">Basic</h3>\n        <p class=\"text-sm text-[var(--text-muted)] mb-8\" data-kid=\"218\">For individuals getting started.</p>\n        <div class=\"text-5xl font-extrabold mb-8 flex items-end gap-2\" data-kid=\"219\">₹0 <span class=\"text-base font-normal text-[var(--text-muted)] mb-2\" data-kid=\"220\">/mo</span></div>\n        <ul class=\"space-y-4 mb-10 flex-grow\" data-kid=\"221\">\n          <li class=\"flex items-center gap-3 text-sm font-medium\" data-kid=\"222\"><i class=\"ti ti-circle-check-filled text-[var(--teal)]\" data-kid=\"223\"></i> 10 Active Projects</li>\n          <li class=\"flex items-center gap-3 text-sm font-medium\" data-kid=\"224\"><i class=\"ti ti-circle-check-filled text-[var(--teal)]\" data-kid=\"225\"></i> Basic Voice Capture</li>\n          <li class=\"flex items-center gap-3 text-sm font-medium\" data-kid=\"226\"><i class=\"ti ti-circle-check-filled text-[var(--teal)]\" data-kid=\"227\"></i> Desktop & Web App</li>\n          <li class=\"flex items-center gap-3 text-sm font-medium text-[var(--text-muted)] opacity-50\" data-kid=\"228\"><i class=\"ti ti-circle-x-filled\" data-kid=\"229\"></i> Advanced AI Engine</li>\n          <li class=\"flex items-center gap-3 text-sm font-medium text-[var(--text-muted)] opacity-50\" data-kid=\"230\"><i class=\"ti ti-circle-x-filled\" data-kid=\"231\"></i> Team Collaboration</li>\n        </ul>\n        <button class=\"w-full py-5 rounded-2xl border border-[var(--border)] font-bold hover:bg-[var(--bg-tertiary)] transition-colors\" data-kid=\"232\">Get Started Free</button>\n      </div>\n\n      \n      <div class=\"rounded-[40px] bg-[var(--bg-secondary)] border-[2px] border-[var(--purple)] p-10 flex flex-col relative reveal transition-delay-200 transform md:scale-105 shadow-[0_0_40px_rgba(139,101,200,0.2)] animate-[glow-pulse_4s_infinite]\" data-kid=\"233\">\n        <div class=\"absolute -top-4 left-1/2 -translate-x-1/2 bg-[var(--purple)] text-white text-[10px] font-bold px-4 py-1.5 rounded-full uppercase tracking-widest shadow-lg\" data-kid=\"234\">Most Popular</div>\n        <h3 class=\"text-xl font-bold mb-2\" data-kid=\"235\">Pro</h3>\n        <p class=\"text-sm text-[var(--text-muted)] mb-8\" data-kid=\"236\">For power users who need more.</p>\n        <div class=\"text-5xl font-extrabold mb-8 flex items-end gap-2\" data-kid=\"237\">\n          <span class=\"price-value\" data-monthly=\"199\" data-yearly=\"159\" data-kid=\"238\">₹199</span>\n          <span class=\"text-base font-normal text-[var(--text-muted)] mb-2\" data-kid=\"239\">/mo</span>\n        </div>\n        <ul class=\"space-y-4 mb-10 flex-grow\" data-kid=\"240\">\n          <li class=\"flex items-center gap-3 text-sm font-medium\" data-kid=\"241\"><i class=\"ti ti-circle-check-filled text-[var(--teal)]\" data-kid=\"242\"></i> Unlimited Projects</li>\n          <li class=\"flex items-center gap-3 text-sm font-medium\" data-kid=\"243\"><i class=\"ti ti-circle-check-filled text-[var(--teal)]\" data-kid=\"244\"></i> Full Neural AI Engine</li>\n          <li class=\"flex items-center gap-3 text-sm font-medium\" data-kid=\"245\"><i class=\"ti ti-circle-check-filled text-[var(--teal)]\" data-kid=\"246\"></i> Custom Focus Ambients</li>\n          <li class=\"flex items-center gap-3 text-sm font-medium\" data-kid=\"247\"><i class=\"ti ti-circle-check-filled text-[var(--teal)]\" data-kid=\"248\"></i> Cloud Sync Backup</li>\n          <li class=\"flex items-center gap-3 text-sm font-medium text-[var(--text-muted)] opacity-50\" data-kid=\"249\"><i class=\"ti ti-circle-x-filled\" data-kid=\"250\"></i> Multi-User Admin</li>\n        </ul>\n        <button class=\"w-full py-5 rounded-2xl bg-[var(--grad-cta)] text-white font-bold shadow-xl shadow-[var(--purple)]/30 hover:scale-[1.02] transition-all\" data-kid=\"251\">Upgrade to Pro</button>\n      </div>\n\n      \n      <div class=\"rounded-[40px] bg-[var(--bg-secondary)] border border-[var(--border)] p-10 flex flex-col reveal transition-delay-300\" data-kid=\"252\">\n        <h3 class=\"text-xl font-bold mb-2\" data-kid=\"253\">Team</h3>\n        <p class=\"text-sm text-[var(--text-muted)] mb-8\" data-kid=\"254\">For scaling teams and studios.</p>\n        <div class=\"text-5xl font-extrabold mb-8 flex items-end gap-2\" data-kid=\"255\">\n           <span class=\"price-value\" data-monthly=\"499\" data-yearly=\"399\" data-kid=\"256\">₹499</span>\n           <span class=\"text-base font-normal text-[var(--text-muted)] mb-2\" data-kid=\"257\">/user</span>\n        </div>\n        <ul class=\"space-y-4 mb-10 flex-grow\" data-kid=\"258\">\n          <li class=\"flex items-center gap-3 text-sm font-medium\" data-kid=\"259\"><i class=\"ti ti-circle-check-filled text-[var(--teal)]\" data-kid=\"260\"></i> Shared Workspaces</li>\n          <li class=\"flex items-center gap-3 text-sm font-medium\" data-kid=\"261\"><i class=\"ti ti-circle-check-filled text-[var(--teal)]\" data-kid=\"262\"></i> Team Analytics Dash</li>\n          <li class=\"flex items-center gap-3 text-sm font-medium\" data-kid=\"263\"><i class=\"ti ti-circle-check-filled text-[var(--teal)]\" data-kid=\"264\"></i> Priority 24/7 Support</li>\n          <li class=\"flex items-center gap-3 text-sm font-medium\" data-kid=\"265\"><i class=\"ti ti-circle-check-filled text-[var(--teal)]\" data-kid=\"266\"></i> Custom Integrations</li>\n          <li class=\"flex items-center gap-3 text-sm font-medium\" data-kid=\"267\"><i class=\"ti ti-circle-check-filled text-[var(--teal)]\" data-kid=\"268\"></i> SSO & Advanced Security</li>\n        </ul>\n        <button class=\"w-full py-5 rounded-2xl border border-[var(--border)] font-bold hover:bg-[var(--bg-tertiary)] transition-colors\" data-kid=\"269\">Contact Sales</button>\n      </div>\n    </div>\n  </div>\n</section>\n\n\n<section class=\"py-32 overflow-hidden bg-[var(--bg-secondary)]\" data-kid=\"270\">\n  <div class=\"text-center mb-16 reveal\" data-kid=\"271\">\n    <h2 class=\"text-3xl font-bold mb-4\" data-kid=\"272\">Loved by 100,000+ users.</h2>\n    <p class=\"text-[var(--text-muted)]\" data-kid=\"273\">Don't just take our word for it.</p>\n  </div>\n  \n  <div class=\"marquee relative\" data-kid=\"274\">\n    <div class=\"marquee-content flex gap-6 px-6\" data-kid=\"275\">\n      \n      <div class=\"shrink-0 w-[400px] p-10 rounded-[32px] bg-[var(--bg-tertiary)] border border-[var(--border)]\" data-kid=\"276\">\n        <div class=\"flex gap-1 text-[var(--orange)] mb-6\" data-kid=\"277\">\n          <i class=\"ti ti-star-filled\" data-kid=\"278\"></i><i class=\"ti ti-star-filled\" data-kid=\"279\"></i><i class=\"ti ti-star-filled\" data-kid=\"280\"></i><i class=\"ti ti-star-filled\" data-kid=\"281\"></i><i class=\"ti ti-star-filled\" data-kid=\"282\"></i>\n        </div>\n        <p class=\"text-[var(--text-secondary)] italic mb-8 leading-relaxed\" data-kid=\"283\">\"TaskMate has completely changed how I organize my work. The AI suggestions are spookily accurate! I finally feel in control of my calendar.\"</p>\n        <div class=\"flex items-center gap-4\" data-kid=\"284\">\n          <div class=\"w-12 h-12 rounded-full bg-gradient-to-br from-[var(--purple)] to-[var(--teal)] flex items-center justify-center font-bold text-white\" data-kid=\"285\">RS</div>\n          <div data-kid=\"286\">\n            <div class=\"font-bold text-[var(--text-primary)]\" data-kid=\"287\">Rahul Sharma</div>\n            <div class=\"text-xs text-[var(--text-muted)]\" data-kid=\"288\">Product Lead at TechFlow</div>\n          </div>\n        </div>\n      </div>\n      \n      <div class=\"shrink-0 w-[400px] p-10 rounded-[32px] bg-[var(--bg-tertiary)] border border-[var(--border)]\" data-kid=\"289\">\n        <div class=\"flex gap-1 text-[var(--orange)] mb-6\" data-kid=\"290\">\n          <i class=\"ti ti-star-filled\" data-kid=\"291\"></i><i class=\"ti ti-star-filled\" data-kid=\"292\"></i><i class=\"ti ti-star-filled\" data-kid=\"293\"></i><i class=\"ti ti-star-filled\" data-kid=\"294\"></i><i class=\"ti ti-star-filled\" data-kid=\"295\"></i>\n        </div>\n        <p class=\"text-[var(--text-secondary)] italic mb-8 leading-relaxed\" data-kid=\"296\">\"The voice to task feature is a game changer when I'm driving. I just dictate and TaskMate does the heavy lifting of sorting everything.\"</p>\n        <div class=\"flex items-center gap-4\" data-kid=\"297\">\n          <div class=\"w-12 h-12 rounded-full bg-gradient-to-br from-[var(--pink)] to-[var(--purple)] flex items-center justify-center font-bold text-white\" data-kid=\"298\">AK</div>\n          <div data-kid=\"299\">\n            <div class=\"font-bold text-[var(--text-primary)]\" data-kid=\"300\">Anjali Kapoor</div>\n            <div class=\"text-xs text-[var(--text-muted)]\" data-kid=\"301\">Freelance Designer</div>\n          </div>\n        </div>\n      </div>\n       <div class=\"shrink-0 w-[400px] p-10 rounded-[32px] bg-[var(--bg-tertiary)] border border-[var(--border)]\" data-kid=\"302\">\n        <div class=\"flex gap-1 text-[var(--orange)] mb-6\" data-kid=\"303\">\n          <i class=\"ti ti-star-filled\" data-kid=\"304\"></i><i class=\"ti ti-star-filled\" data-kid=\"305\"></i><i class=\"ti ti-star-filled\" data-kid=\"306\"></i><i class=\"ti ti-star-filled\" data-kid=\"307\"></i><i class=\"ti ti-star-filled\" data-kid=\"308\"></i>\n        </div>\n        <p class=\"text-[var(--text-secondary)] italic mb-8 leading-relaxed\" data-kid=\"309\">\"I've tried every to-do app out there. TaskMate is the only one that actually helps me focus rather than just adding more noise.\"</p>\n        <div class=\"flex items-center gap-4\" data-kid=\"310\">\n          <div class=\"w-12 h-12 rounded-full bg-gradient-to-br from-[var(--teal)] to-[var(--purple)] flex items-center justify-center font-bold text-white\" data-kid=\"311\">JM</div>\n          <div data-kid=\"312\">\n            <div class=\"font-bold text-[var(--text-primary)]\" data-kid=\"313\">James Miller</div>\n            <div class=\"text-xs text-[var(--text-muted)]\" data-kid=\"314\">Founder, StudioX</div>\n          </div>\n        </div>\n      </div>\n      \n       <div class=\"shrink-0 w-[400px] p-10 rounded-[32px] bg-[var(--bg-tertiary)] border border-[var(--border)]\" data-kid=\"315\">\n        <div class=\"flex gap-1 text-[var(--orange)] mb-6\" data-kid=\"316\">\n          <i class=\"ti ti-star-filled\" data-kid=\"317\"></i><i class=\"ti ti-star-filled\" data-kid=\"318\"></i><i class=\"ti ti-star-filled\" data-kid=\"319\"></i><i class=\"ti ti-star-filled\" data-kid=\"320\"></i><i class=\"ti ti-star-filled\" data-kid=\"321\"></i>\n        </div>\n        <p class=\"text-[var(--text-secondary)] italic mb-8 leading-relaxed\" data-kid=\"322\">\"TaskMate has completely changed how I organize my work. The AI suggestions are spookily accurate! I finally feel in control of my calendar.\"</p>\n        <div class=\"flex items-center gap-4\" data-kid=\"323\">\n          <div class=\"w-12 h-12 rounded-full bg-gradient-to-br from-[var(--purple)] to-[var(--teal)] flex items-center justify-center font-bold text-white\" data-kid=\"324\">RS</div>\n          <div data-kid=\"325\">\n            <div class=\"font-bold text-[var(--text-primary)]\" data-kid=\"326\">Rahul Sharma</div>\n            <div class=\"text-xs text-[var(--text-muted)]\" data-kid=\"327\">Product Lead at TechFlow</div>\n          </div>\n        </div>\n      </div>\n       <div class=\"shrink-0 w-[400px] p-10 rounded-[32px] bg-[var(--bg-tertiary)] border border-[var(--border)]\" data-kid=\"328\">\n        <div class=\"flex gap-1 text-[var(--orange)] mb-6\" data-kid=\"329\">\n          <i class=\"ti ti-star-filled\" data-kid=\"330\"></i><i class=\"ti ti-star-filled\" data-kid=\"331\"></i><i class=\"ti ti-star-filled\" data-kid=\"332\"></i><i class=\"ti ti-star-filled\" data-kid=\"333\"></i><i class=\"ti ti-star-filled\" data-kid=\"334\"></i>\n        </div>\n        <p class=\"text-[var(--text-secondary)] italic mb-8 leading-relaxed\" data-kid=\"335\">\"The voice to task feature is a game changer when I'm driving. I just dictate and TaskMate does the heavy lifting of sorting everything.\"</p>\n        <div class=\"flex items-center gap-4\" data-kid=\"336\">\n          <div class=\"w-12 h-12 rounded-full bg-gradient-to-br from-[var(--pink)] to-[var(--purple)] flex items-center justify-center font-bold text-white\" data-kid=\"337\">AK</div>\n          <div data-kid=\"338\">\n            <div class=\"font-bold text-[var(--text-primary)]\" data-kid=\"339\">Anjali Kapoor</div>\n            <div class=\"text-xs text-[var(--text-muted)]\" data-kid=\"340\">Freelance Designer</div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </div>\n</section>\n\n\n<section id=\"faq\" class=\"py-32 px-6\" data-kid=\"341\">\n  <div class=\"max-w-3xl mx-auto\" data-kid=\"342\">\n    <div class=\"text-center mb-16 reveal\" data-kid=\"343\">\n      <h2 class=\"text-4xl font-bold mb-4\" data-kid=\"344\">Got questions?</h2>\n      <p class=\"text-[var(--text-muted)]\" data-kid=\"345\">Everything you need to know about TaskMate.</p>\n    </div>\n\n    <div class=\"space-y-4\" data-kid=\"346\">\n      \n      <div class=\"faq-item p-6 rounded-3xl bg-[var(--bg-secondary)] border border-[var(--border)] reveal\" data-kid=\"347\">\n        <button class=\"w-full flex justify-between items-center text-left font-bold text-lg cursor-pointer\" data-kid=\"348\">\n          <span data-kid=\"349\">Is TaskMate AI really free?</span>\n          <i class=\"ti ti-plus transition-transform text-[var(--purple)]\" data-kid=\"350\"></i>\n        </button>\n        <div class=\"faq-answer text-[var(--text-secondary)] leading-relaxed\" data-kid=\"351\">\n          Yes! Our Basic plan is free forever and includes 10 active projects, basic voice capture, and access to all platforms. We believe productivity should be accessible to everyone.\n        </div>\n      </div>\n      \n      <div class=\"faq-item p-6 rounded-3xl bg-[var(--bg-secondary)] border border-[var(--border)] reveal\" data-kid=\"352\">\n        <button class=\"w-full flex justify-between items-center text-left font-bold text-lg cursor-pointer\" data-kid=\"353\">\n          <span data-kid=\"354\">Which platforms is it available on?</span>\n          <i class=\"ti ti-plus transition-transform text-[var(--purple)]\" data-kid=\"355\"></i>\n        </button>\n        <div class=\"faq-answer text-[var(--text-secondary)] leading-relaxed\" data-kid=\"356\">\n          TaskMate is currently available on Android, Web, and as a Desktop app for macOS and Windows. Our iOS app is coming in early 2025!\n        </div>\n      </div>\n      \n      <div class=\"faq-item p-6 rounded-3xl bg-[var(--bg-secondary)] border border-[var(--border)] reveal\" data-kid=\"357\">\n        <button class=\"w-full flex justify-between items-center text-left font-bold text-lg cursor-pointer\" data-kid=\"358\">\n          <span data-kid=\"359\">How does the AI suggestion engine work?</span>\n          <i class=\"ti ti-plus transition-transform text-[var(--purple)]\" data-kid=\"360\"></i>\n        </button>\n        <div class=\"faq-answer text-[var(--text-secondary)] leading-relaxed\" data-kid=\"361\">\n          We use proprietary neural networks that analyze your task completion history, current load, and energy cycles to suggest the best times for specific types of work. Your data is always encrypted and stays private.\n        </div>\n      </div>\n      \n      <div class=\"faq-item p-6 rounded-3xl bg-[var(--bg-secondary)] border border-[var(--border)] reveal\" data-kid=\"362\">\n        <button class=\"w-full flex justify-between items-center text-left font-bold text-lg cursor-pointer\" data-kid=\"363\">\n          <span data-kid=\"364\">Can I use TaskMate offline?</span>\n          <i class=\"ti ti-plus transition-transform text-[var(--purple)]\" data-kid=\"365\"></i>\n        </button>\n        <div class=\"faq-answer text-[var(--text-secondary)] leading-relaxed\" data-kid=\"366\">\n          Absolutely. TaskMate works fully offline and syncs your changes automatically once you're back online.\n        </div>\n      </div>\n      \n      <div class=\"faq-item p-6 rounded-3xl bg-[var(--bg-secondary)] border border-[var(--border)] reveal\" data-kid=\"367\">\n        <button class=\"w-full flex justify-between items-center text-left font-bold text-lg cursor-pointer\" data-kid=\"368\">\n          <span data-kid=\"369\">Is team collaboration available?</span>\n          <i class=\"ti ti-plus transition-transform text-[var(--purple)]\" data-kid=\"370\"></i>\n        </button>\n        <div class=\"faq-answer text-[var(--text-secondary)] leading-relaxed\" data-kid=\"371\">\n          Yes, our Team plan includes shared workspaces, project permissions, and team analytics to keep everyone in sync.\n        </div>\n      </div>\n    </div>\n  </div>\n</section>\n\n\n<section class=\"pt-32 px-6\" data-kid=\"372\">\n  <div class=\"max-w-7xl mx-auto rounded-t-[60px] bg-[var(--bg-secondary)] border-x border-t border-[var(--border)] p-20 text-center relative overflow-hidden reveal\" data-kid=\"373\">\n    <div class=\"absolute inset-0 bg-gradient-to-t from-[var(--purple)]/10 to-transparent pointer-events-none\" data-kid=\"374\"></div>\n    <div class=\"relative z-10\" data-kid=\"375\">\n      <h2 class=\"text-5xl md:text-7xl font-extrabold mb-8 tracking-tight\" data-kid=\"376\">Ready to plan smarter?</h2>\n      <p class=\"text-xl text-[var(--text-secondary)] mb-12 max-w-2xl mx-auto\" data-kid=\"377\">Join over 100,000+ users who have regained control of their schedule and lives with TaskMate AI.</p>\n      <div class=\"flex flex-wrap justify-center gap-6\" data-kid=\"378\">\n        <button class=\"px-10 py-5 rounded-full bg-white text-black font-extrabold flex items-center gap-3 hover:scale-105 transition-transform\" data-kid=\"379\">\n           <i class=\"ti ti-brand-google-play text-2xl\" data-kid=\"380\"></i> Get it on Play Store\n        </button>\n        <button class=\"px-10 py-5 rounded-full bg-black text-white border border-white/20 font-extrabold flex items-center gap-3 hover:scale-105 transition-transform\" data-kid=\"381\">\n          <i class=\"ti ti-brand-producthunt text-2xl\" data-kid=\"382\"></i> View on Product Hunt\n        </button>\n      </div>\n    </div>\n    \n    \n    <div class=\"absolute top-10 right-20 w-32 h-32 bg-[var(--pink)]/10 rounded-full blur-3xl\" data-kid=\"383\"></div>\n    <div class=\"absolute bottom-10 left-20 w-48 h-48 bg-[var(--teal)]/10 rounded-full blur-3xl\" data-kid=\"384\"></div>\n  </div>\n</section>\n\n\n<footer class=\"py-20 px-6 bg-[var(--bg-primary)] border-t border-[var(--border)]\" data-kid=\"385\">\n  <div class=\"max-w-7xl mx-auto grid grid-cols-2 md:grid-cols-4 gap-12 mb-20\" data-kid=\"386\">\n    <div class=\"col-span-2 md:col-span-1\" data-kid=\"387\">\n      <div class=\"flex items-center gap-2 mb-6\" data-kid=\"388\">\n        <svg class=\"w-8 h-8\" viewBox=\"0 0 40 40\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\" data-kid=\"389\">\n          <rect width=\"40\" height=\"40\" rx=\"10\" fill=\"url(#logoGradFooter)\" data-kid=\"390\"></rect>\n          <defs data-kid=\"391\">\n            <linearGradient id=\"logoGradFooter\" x1=\"0\" y1=\"40\" x2=\"40\" y2=\"0\" data-kid=\"392\">\n              <stop offset=\"0%\" stop-color=\"#F5A87B\" data-kid=\"393\"></stop>\n              <stop offset=\"30%\" stop-color=\"#F0607A\" data-kid=\"394\"></stop>\n              <stop offset=\"65%\" stop-color=\"#8B65C8\" data-kid=\"395\"></stop>\n              <stop offset=\"100%\" stop-color=\"#4ABFB8\" data-kid=\"396\"></stop>\n            </linearGradient>\n          </defs>\n          <circle cx=\"20\" cy=\"20\" r=\"11\" stroke=\"white\" stroke-width=\"2.5\" fill=\"none\" data-kid=\"397\"></circle>\n          <path d=\"M14 20.5L18 24.5L26 16\" stroke=\"white\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\" data-kid=\"398\"></path>\n        </svg>\n        <span class=\"text-xl font-bold\" data-kid=\"399\">TaskMate AI</span>\n      </div>\n      <p class=\"text-sm text-[var(--text-muted)] mb-6 leading-relaxed\" data-kid=\"400\">Building the future of spatial task intelligence. Plan smarter, live better.</p>\n      <div class=\"text-xs text-[var(--text-muted)] uppercase tracking-widest font-bold\" data-kid=\"401\">Made in Ahmedabad 🇮🇳</div>\n    </div>\n\n    <div data-kid=\"402\">\n      <h5 class=\"font-bold mb-6\" data-kid=\"403\">Product</h5>\n      <ul class=\"space-y-4 text-sm text-[var(--text-muted)]\" data-kid=\"404\">\n        <li data-kid=\"405\"><a href=\"#features\" class=\"hover:text-[var(--text-primary)] transition-colors\" data-kid=\"406\">Features</a></li>\n        <li data-kid=\"407\"><a href=\"#how-it-works\" class=\"hover:text-[var(--text-primary)] transition-colors\" data-kid=\"408\">How it works</a></li>\n        <li data-kid=\"409\"><a href=\"#pricing\" class=\"hover:text-[var(--text-primary)] transition-colors\" data-kid=\"410\">Pricing</a></li>\n        <li data-kid=\"411\"><a href=\"#\" class=\"hover:text-[var(--text-primary)] transition-colors\" data-kid=\"412\">Integrations</a></li>\n      </ul>\n    </div>\n\n    <div data-kid=\"413\">\n      <h5 class=\"font-bold mb-6\" data-kid=\"414\">Company</h5>\n      <ul class=\"space-y-4 text-sm text-[var(--text-muted)]\" data-kid=\"415\">\n        <li data-kid=\"416\"><a href=\"#\" class=\"hover:text-[var(--text-primary)] transition-colors\" data-kid=\"417\">About Us</a></li>\n        <li data-kid=\"418\"><a href=\"#\" class=\"hover:text-[var(--text-primary)] transition-colors\" data-kid=\"419\">Blog</a></li>\n        <li data-kid=\"420\"><a href=\"#\" class=\"hover:text-[var(--text-primary)] transition-colors\" data-kid=\"421\">Careers</a></li>\n        <li data-kid=\"422\"><a href=\"#\" class=\"hover:text-[var(--text-primary)] transition-colors\" data-kid=\"423\">Contact</a></li>\n      </ul>\n    </div>\n\n    <div data-kid=\"424\">\n      <h5 class=\"font-bold mb-6\" data-kid=\"425\">Social</h5>\n      <div class=\"flex gap-4\" data-kid=\"426\">\n        <a href=\"#\" class=\"w-10 h-10 rounded-full bg-[var(--bg-tertiary)] flex items-center justify-center hover:bg-[var(--purple)] transition-colors group\" data-kid=\"427\">\n          <i class=\"ti ti-brand-twitter text-lg group-hover:text-white\" data-kid=\"428\"></i>\n        </a>\n        <a href=\"#\" class=\"w-10 h-10 rounded-full bg-[var(--bg-tertiary)] flex items-center justify-center hover:bg-[var(--purple)] transition-colors group\" data-kid=\"429\">\n          <i class=\"ti ti-brand-github text-lg group-hover:text-white\" data-kid=\"430\"></i>\n        </a>\n        <a href=\"#\" class=\"w-10 h-10 rounded-full bg-[var(--bg-tertiary)] flex items-center justify-center hover:bg-[var(--purple)] transition-colors group\" data-kid=\"431\">\n          <i class=\"ti ti-brand-linkedin text-lg group-hover:text-white\" data-kid=\"432\"></i>\n        </a>\n        <a href=\"#\" class=\"w-10 h-10 rounded-full bg-[var(--bg-tertiary)] flex items-center justify-center hover:bg-[var(--purple)] transition-colors group\" data-kid=\"433\">\n          <i class=\"ti ti-brand-instagram text-lg group-hover:text-white\" data-kid=\"434\"></i>\n        </a>\n      </div>\n    </div>\n  </div>\n  \n  <div class=\"max-w-7xl mx-auto pt-10 border-t border-[var(--border)] flex flex-col md:flex-row justify-between items-center gap-6\" data-kid=\"435\">\n    <div class=\"text-sm text-[var(--text-muted)]\" data-kid=\"436\">© 2025 TaskMate AI. All rights reserved.</div>\n    <div class=\"flex gap-8 text-sm text-[var(--text-muted)]\" data-kid=\"437\">\n      <a href=\"#\" class=\"hover:text-[var(--text-primary)] transition-colors\" data-kid=\"438\">Privacy Policy</a>\n      <a href=\"#\" class=\"hover:text-[var(--text-primary)] transition-colors\" data-kid=\"439\">Terms of Service</a>\n      <a href=\"#\" class=\"hover:text-[var(--text-primary)] transition-colors\" data-kid=\"440\">Cookie Policy</a>\n    </div>\n  </div>\n</footer>\n\n<script data-kid=\"441\">\n  // Theme Toggle Logic\n  const html = document.documentElement;\n  const themeToggle = document.getElementById('theme-toggle');\n  const themeIcon = document.getElementById('theme-icon');\n\n  const updateTheme = (isDark) => {\n    html.dataset.theme = isDark ? 'dark' : 'light';\n    themeIcon.className = isDark ? 'ti ti-moon text-xl' : 'ti ti-sun text-xl';\n    localStorage.setItem('theme', html.dataset.theme);\n  };\n\n  // Check initial theme\n  const savedTheme = localStorage.getItem('theme') || 'dark';\n  updateTheme(savedTheme === 'dark');\n\n  themeToggle.addEventListener('click', () => {\n    updateTheme(html.dataset.theme !== 'dark');\n  });\n\n\n  // Mobile Menu Logic\n  const mobileMenuBtn = document.getElementById('mobile-menu-btn');\n  const mobileMenu = document.getElementById('mobile-menu');\n  let isMenuOpen = false;\n\n  mobileMenuBtn.addEventListener('click', () => {\n    isMenuOpen = !isMenuOpen;\n    mobileMenu.style.transform = isMenuOpen ? 'translateX(0)' : 'translateX(100%)';\n    mobileMenuBtn.innerHTML = isMenuOpen ? '<i class=\"ti ti-x text-2xl\"></i>' : '<i class=\"ti ti-menu-2 text-2xl\"></i>';\n  });\n\n  document.querySelectorAll('.mobile-nav-link').forEach(link => {\n    link.addEventListener('click', () => {\n      isMenuOpen = false;\n      mobileMenu.style.transform = 'translateX(100%)';\n      mobileMenuBtn.innerHTML = '<i class=\"ti ti-menu-2 text-2xl\"></i>';\n    });\n  });\n\n  // Instant Stats Count-up for Iframe compatibility\n  document.querySelectorAll('.stat-count').forEach(counter => {\n    animateCount(counter);\n  });\n\n  // Count-up Animation\n  function animateCount(el) {\n    const target = parseFloat(el.dataset.target);\n    const duration = 2000;\n    const decimal = parseInt(el.dataset.decimal || 0);\n    const start = 0;\n    let startTime = null;\n\n    function step(timestamp) {\n      if (!startTime) startTime = timestamp;\n      const progress = Math.min((timestamp - startTime) / duration, 1);\n      const ease = 1 - Math.pow(1 - progress, 3); // easeOutCubic\n      const current = ease * target;\n      \n      el.textContent = current.toFixed(decimal);\n      \n      if (progress < 1) {\n        requestAnimationFrame(step);\n      } else {\n        el.textContent = target.toFixed(decimal);\n      }\n    }\n    requestAnimationFrame(step);\n  }\n\n  // Particle Generation\n  const particleContainer = document.getElementById('particle-container');\n  const colors = ['#8B65C8', '#4ABFB8', '#F0607A'];\n  for (let i = 0; i < 12; i++) {\n    const particle = document.createElement('div');\n    particle.className = 'particle';\n    particle.style.left = Math.random() * 100 + '%';\n    particle.style.top = Math.random() * 100 + '%';\n    particle.style.backgroundColor = colors[Math.floor(Math.random() * colors.length)];\n    particle.style.animationDelay = (Math.random() * 5) + 's';\n    particle.style.animationDuration = (8 + Math.random() * 7) + 's';\n    particleContainer.appendChild(particle);\n  }\n\n  // How It Works Step Switcher\n  const stepBtns = document.querySelectorAll('.step-btn');\n  const stepPanels = document.querySelectorAll('.step-panel');\n\n  stepBtns.forEach((btn, index) => {\n    btn.addEventListener('click', () => {\n      // Update Buttons\n      stepBtns.forEach(b => b.classList.remove('active'));\n      btn.classList.add('active');\n\n      // Update Panels\n      stepPanels.forEach(p => {\n        p.style.opacity = '0';\n        p.style.transform = 'translateY(20px)';\n        p.style.pointerEvents = 'none';\n      });\n      const activePanel = document.getElementById(`panel-${index}`);\n      activePanel.style.opacity = '1';\n      activePanel.style.transform = 'translateY(0)';\n      activePanel.style.pointerEvents = 'auto';\n    });\n  });\n\n  // Pricing Toggle\n  const monthlyBtn = document.getElementById('monthly-pricing');\n  const yearlyBtn = document.getElementById('yearly-pricing');\n  const priceValues = document.querySelectorAll('.price-value');\n\n  monthlyBtn.addEventListener('click', () => {\n    monthlyBtn.classList.add('active');\n    yearlyBtn.classList.remove('active');\n    priceValues.forEach(el => {\n      el.textContent = '₹' + el.dataset.monthly;\n    });\n  });\n\n  yearlyBtn.addEventListener('click', () => {\n    yearlyBtn.classList.add('active');\n    monthlyBtn.classList.remove('active');\n    priceValues.forEach(el => {\n      el.textContent = '₹' + el.dataset.yearly;\n    });\n  });\n\n  // FAQ Accordion\n  document.querySelectorAll('.faq-item button').forEach(btn => {\n    btn.addEventListener('click', () => {\n      const parent = btn.parentElement;\n      const isActive = parent.classList.contains('active');\n      \n      // Close all others\n      document.querySelectorAll('.faq-item').forEach(item => item.classList.remove('active'));\n      \n      if (!isActive) {\n        parent.classList.add('active');\n      }\n    });\n  });\n\n</script>\n",
