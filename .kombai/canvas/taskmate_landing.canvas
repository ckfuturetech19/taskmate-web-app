      "html": "\n<div class=\"bg-[#0F0A1A] text-[#F0EEF8] font-sans selection:bg-[#8B65C8]/30\" data-kid=\"0\">\n  <style data-kid=\"1\">\n    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap');\n    @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n    :root {\n      --orange: #F5A87B;\n      --pink: #F0607A;\n      --purple: #8B65C8;\n      --teal: #4ABFB8;\n      --lavender: #C4C8E8;\n      --dark: #0F0A1A;\n      --dark2: #1A1228;\n      --dark3: #241B35;\n      --text: #F0EEF8;\n      --text2: #B8B0D4;\n      --text3: #7A7090;\n    }\n\n    /* Custom Scrollbar */\n    ::-webkit-scrollbar { width: 8px; }\n    ::-webkit-scrollbar-track { background: var(--dark); }\n    ::-webkit-scrollbar-thumb { background: var(--dark3); border-radius: 10px; }\n    ::-webkit-scrollbar-thumb:hover { background: var(--purple); }\n\n    .font-sans { font-family: 'Inter', sans-serif; }\n\n    /* Gradients */\n    .bg-primary-gradient { background: linear-gradient(135deg, #F5A87B, #F0607A, #8B65C8, #4ABFB8); }\n    .bg-cta-gradient { background: linear-gradient(135deg, #F0607A, #8B65C8); }\n    .text-gradient {\n      background: linear-gradient(135deg, #F5A87B, #F0607A, #8B65C8, #4ABFB8);\n      -webkit-background-clip: text;\n      -webkit-text-fill-color: transparent;\n      filter: drop-shadow(0 4px 8px rgba(0, 0, 0, 0.3));\n    }\n    .text-gradient-stat {\n      background: linear-gradient(135deg, #F5A87B, #F0607A);\n      -webkit-background-clip: text;\n      -webkit-text-fill-color: transparent;\n    }\n\n    /* Spatial UI Shadows & Borders */\n    .spatial-card {\n      background: var(--dark2);\n      border: 1px solid rgba(255, 255, 255, 0.08);\n      box-shadow: 0 20px 50px rgba(0, 0, 0, 0.5), inset 0 1px 1px rgba(255, 255, 255, 0.05);\n      border-radius: 24px;\n      transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);\n    }\n    .spatial-card:hover {\n      border-color: rgba(139, 101, 200, 0.3);\n      box-shadow: 0 30px 60px rgba(0, 0, 0, 0.6), 0 0 20px rgba(139, 101, 200, 0.1);\n      transform: translateY(-4px);\n    }\n\n    .glass-pill {\n      background: rgba(26, 18, 40, 0.8);\n      backdrop-filter: blur(20px);\n      border: 1px solid rgba(255, 255, 255, 0.1);\n      box-shadow: 0 10px 40px rgba(0, 0, 0, 0.4);\n    }\n\n    /* Animations */\n    @keyframes marquee {\n      0% { transform: translateX(0); }\n      100% { transform: translateX(-50%); }\n    }\n    .animate-marquee { animation: marquee 80s linear infinite; }\n\n    @keyframes float {\n      0%, 100% { transform: translateY(0) rotate(0); }\n      50% { transform: translateY(-15px) rotate(1deg); }\n    }\n    .floating { animation: float 6s ease-in-out infinite; }\n\n    @keyframes pulse-glow {\n      0%, 100% { box-shadow: 0 0 20px rgba(139, 101, 200, 0.2); }\n      50% { box-shadow: 0 0 40px rgba(139, 101, 200, 0.4); }\n    }\n    .glow-pulse { animation: pulse-glow 4s ease-in-out infinite; }\n\n    /* 3D Perspective */\n    .perspective-1200 { perspective: 1200px; }\n    .rotate-3d { transform: rotateY(-15deg) rotateX(10deg); }\n\n    /* Custom Height Utilities (avoiding vh) */\n    .section-h { min-height: 800px; }\n  </style>\n\n  \n  <nav class=\"absolute top-8 left-1/2 -translate-x-1/2 z-[100] w-fit\" data-kid=\"2\">\n    <div class=\"glass-pill px-6 py-3 rounded-full flex items-center gap-12\" data-kid=\"3\">\n      <div class=\"flex items-center gap-2.5\" data-kid=\"4\">\n        <img src=\"/api/local/images/assets/logo.png\" class=\"w-8 h-8 rounded-lg shadow-lg\" alt=\"TaskMate Logo\" decoding=\"async\" loading=\"lazy\" data-kid=\"5\">\n        <span class=\"font-extrabold text-lg tracking-tight\" data-kid=\"6\">TaskMate AI</span>\n      </div>\n      <div class=\"hidden lg:flex items-center gap-8 text-sm font-semibold text-[var(--text2)]\" data-kid=\"7\">\n        <a href=\"#features\" class=\"hover:text-[var(--teal)] transition-colors\" data-kid=\"8\">Features</a>\n        <a href=\"#how-it-works\" class=\"hover:text-[var(--purple)] transition-colors\" data-kid=\"9\">How it works</a>\n        <a href=\"#pricing\" class=\"hover:text-[var(--orange)] transition-colors\" data-kid=\"10\">Pricing</a>\n        <a href=\"#faq\" class=\"hover:text-[var(--pink)] transition-colors\" data-kid=\"11\">FAQ</a>\n      </div>\n      <div class=\"flex items-center gap-4\" data-kid=\"12\">\n        <button class=\"text-sm font-bold text-[var(--text2)] hover:text-white transition-colors cursor-pointer\" data-kid=\"13\">Sign in</button>\n        <button class=\"bg-cta-gradient px-6 py-2.5 rounded-full text-sm font-bold shadow-lg shadow-[#F0607A]/20 hover:scale-105 active:scale-95 transition-all cursor-pointer\" data-kid=\"14\">Download Free →</button>\n      </div>\n    </div>\n  </nav>\n\n  \n  <section class=\"relative section-h flex items-center pt-20 overflow-hidden\" data-kid=\"15\">\n    \n    <div class=\"absolute top-1/4 left-1/4 w-[600px] h-[600px] bg-[var(--purple)]/10 blur-[150px] -z-10 rounded-full\" data-kid=\"16\"></div>\n    <div class=\"absolute bottom-1/4 right-1/4 w-[500px] h-[500px] bg-[var(--teal)]/5 blur-[120px] -z-10 rounded-full\" data-kid=\"17\"></div>\n\n    <div class=\"max-w-[1280px] mx-auto px-8 grid lg:grid-cols-2 gap-16 items-center\" data-kid=\"18\">\n      <div class=\"space-y-10\" data-kid=\"19\">\n        <div class=\"inline-flex items-center gap-3 px-4 py-1.5 rounded-full bg-[var(--dark2)] border border-white/5 shadow-inner\" data-kid=\"20\">\n          <span class=\"w-2.5 h-2.5 rounded-full bg-[var(--teal)] animate-pulse shadow-[0_0_10px_#4ABFB8]\" data-kid=\"21\"></span>\n          <span class=\"text-[11px] font-bold text-[var(--teal)] uppercase tracking-[0.15em]\" data-kid=\"22\">AI-Powered Task Intelligence · v1.7.0</span>\n        </div>\n        \n        <div class=\"space-y-4\" data-kid=\"23\">\n          <h1 class=\"text-7xl lg:text-8xl font-extrabold leading-[1.05] tracking-tight\" data-kid=\"24\">\n            Plan smarter.<br data-kid=\"25\">\n            <span class=\"text-gradient\" data-kid=\"26\">Live better.</span>\n          </h1>\n          <p class=\"text-xl text-[var(--text2)] leading-relaxed max-w-xl\" data-kid=\"27\">\n            TaskMate AI turns your scattered to-dos into a focused, intelligent workflow. Voice input, smart reminders, and AI suggestions — all in one beautiful app.\n          </p>\n        </div>\n\n        <div class=\"flex flex-wrap items-center gap-6\" data-kid=\"28\">\n          <button class=\"bg-cta-gradient px-10 py-5 rounded-2xl text-xl font-bold shadow-2xl shadow-[#F0607A]/30 hover:scale-105 active:scale-95 transition-all cursor-pointer\" data-kid=\"29\">Get Started Free</button>\n          <button class=\"px-10 py-5 rounded-2xl text-xl font-bold border border-white/10 bg-white/5 hover:bg-white/10 transition-all cursor-pointer flex items-center gap-3\" data-kid=\"30\">\n            <i class=\"ti ti-player-play-filled text-2xl\" data-kid=\"31\"></i> Watch Demo\n          </button>\n        </div>\n\n        <div class=\"flex items-center gap-8 pt-6\" data-kid=\"32\">\n          <span class=\"text-xs font-bold uppercase tracking-[0.2em] text-[var(--text3)]\" data-kid=\"33\">Available on</span>\n          <div class=\"flex gap-6 text-[var(--text2)] text-2xl\" data-kid=\"34\">\n            <i class=\"ti ti-brand-android hover:text-[var(--teal)] transition-colors cursor-pointer\" data-kid=\"35\"></i>\n            <i class=\"ti ti-brand-apple opacity-30 cursor-not-allowed\" title=\"Coming Soon\" data-kid=\"36\"></i>\n            <i class=\"ti ti-world hover:text-[var(--purple)] transition-colors cursor-pointer\" data-kid=\"37\"></i>\n          </div>\n        </div>\n      </div>\n\n      \n      <div class=\"relative perspective-1200 flex justify-center items-center\" data-kid=\"38\">\n        <div class=\"rotate-3d spatial-card p-2 w-full max-w-[600px] overflow-hidden group\" data-kid=\"39\">\n          <img src=\"/api/local/