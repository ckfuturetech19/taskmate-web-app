a-kid=\"256\"></i></div>\n                            <div class=\"glass p-12 rounded-[2rem] border-red-500/10 grayscale opacity-40\" data-kid=\"257\"><i class=\"ti ti-brain text-6xl text-red-500\" data-kid=\"258\"></i></div>\n                            <div class=\"glass p-12 rounded-[2rem] border-red-500/10 grayscale opacity-40\" data-kid=\"259\"><i class=\"ti ti-bolt-off text-6xl text-red-500\" data-kid=\"260\"></i></div>\n                        </div>\n                    </div>\n                </div>\n\n                \n                <div id=\"after-view\" class=\"absolute inset-0 bg-[var(--obsidian)] flex items-center justify-center p-12\" style=\"clip-path: inset(100% 0 0 0);\" data-kid=\"261\">\n                    <img src=\"https://images.unsplash.com/photo-1510519138101-570d1dca3d66?auto=format&w=1600&q=80&fit=crop\" alt=\"Organized Desk\" class=\"absolute inset-0 w-full h-full object-cover opacity-20\" decoding=\"async\" loading=\"lazy\" data-kid=\"262\">\n                    <div class=\"relative z-10 max-w-6xl w-full text-center\" data-kid=\"263\">\n                        <h2 class=\"text-5xl md:text-8xl font-black text-white mb-16 tracking-tighter\" data-kid=\"264\">ZEN.</h2>\n                        <div class=\"flex flex-wrap justify-center gap-6\" data-kid=\"265\">\n                            <div class=\"glass-violet p-12 rounded-[2rem] border-[var(--violet)]/20 shadow-[0_0_50px_var(--violet-glow)]\" data-kid=\"266\"><i class=\"ti ti-sparkles text-6xl text-[var(--violet)]\" data-kid=\"267\"></i></div>\n                            <div class=\"glass-violet p-12 rounded-[2rem] border-[var(--violet)]/20 shadow-[0_0_50px_var(--violet-glow)]\" data-kid=\"268\"><i class=\"ti ti-circle-check text-6xl text-[var(--violet)]\" data-kid=\"269\"></i></div>\n                            <div class=\"glass-violet p-12 rounded-[2rem] border-[var(--violet)]/20 shadow-[0_0_50px_var(--violet-glow)]\" data-kid=\"270\"><i class=\"ti ti-trending-up text-6xl text-[var(--violet)]\" data-kid=\"271\"></i></div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    \n    <section id=\"features\" class=\"py-32 px-6\" data-kid=\"272\">\n        <div class=\"max-w-7xl mx-auto\" data-kid=\"273\">\n            <h2 class=\"font-heading text-5xl md:text-6xl font-bold text-center mb-24\" data-kid=\"274\">Powerfully <span class=\"text-[var(--violet)]\" data-kid=\"275\">Simple.</span></h2>\n            \n            <div class=\"grid grid-cols-1 md:grid-cols-3 gap-6 auto-rows-[250px]\" data-kid=\"276\">\n                <div class=\"md:col-span-2 glass p-8 rounded-[32px] flex flex-col justify-end group hover:neon-border transition-all\" data-kid=\"277\">\n                    <div class=\"mb-auto p-4 w-fit bg-white/5 rounded-2xl\" data-kid=\"278\"><i class=\"ti ti-brand-android text-4xl text-[var(--violet)]\" data-kid=\"279\"></i></div>\n                    <h3 class=\"text-2xl font-bold mb-2\" data-kid=\"280\">Multi-Platform Sync</h3>\n                    <p class=\"text-gray-400\" data-kid=\"281\">Seamlessly transition between Android, iOS, and Web without missing a beat.</p>\n                </div>\n                <div class=\"glass p-8 rounded-[32px] flex flex-col justify-end group hover:neon-border transition-all\" data-kid=\"282\">\n                    <div class=\"mb-auto p-4 w-fit bg-white/5 rounded-2xl\" data-kid=\"283\"><i class=\"ti ti-wifi-off text-4xl text-blue-400\" data-kid=\"284\"></i></div>\n                    <h3 class=\"text-2xl font-bold mb-2\" data-kid=\"285\">Offline Mode</h3>\n                    <p class=\"text-gray-400\" data-kid=\"286\">Your AI brain works even when you're disconnected.</p>\n                </div>\n                <div class=\"glass p-8 rounded-[32px] flex flex-col justify-end group hover:neon-border transition-all\" data-kid=\"287\">\n                    <div class=\"mb-auto p-4 w-fit bg-white/5 rounded-2xl\" data-kid=\"288\"><i class=\"ti ti-lock text-4xl text-red-400\" data-kid=\"289\"></i></div>\n                    <h3 class=\"text-2xl font-bold mb-2\" data-kid=\"290\">Zero-Knowledge</h3>\n                    <p class=\"text-gray-400\" data-kid=\"291\">Your data is encrypted. We can't see your tasks. Ever.</p>\n                </div>\n                <div class=\"md:col-span-2 glass p-8 rounded-[32px] flex flex-col justify-end group hover:neon-border transition-all\" data-kid=\"292\">\n                    <div class=\"mb-auto p-4 w-fit bg-white/5 rounded-2xl\" data-kid=\"293\"><i class=\"ti ti-users-group text-4xl text-emerald-400\" data-kid=\"294\"></i></div>\n                    <h3 class=\"text-2xl font-bold mb-2\" data-kid=\"295\">Team Collaboration</h3>\n                    <p class=\"text-gray-400\" data-kid=\"296\">AI that doesn't just manage your tasks, but coordinates your entire team's workflow.</p>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    \n    <section id=\"testimonials\" class=\"py-32 px-6 bg-[var(--charcoal)]/50\" data-kid=\"297\">\n        <div class=\"max-w-7xl mx-auto\" data-kid=\"298\">\n            <h2 class=\"font-heading text-5xl font-bold text-center mb-24\" data-kid=\"299\">Trusted by the <br data-kid=\"300\"> world's best teams.</h2>\n            \n            <div class=\"columns-1 sm:columns-2 md:columns-3 lg:columns-4 gap-6 space-y-6\" data-kid=\"301\">\n                <div class=\"testimonial-card break-inside-avoid glass p-6 rounded-2xl border-white/5\" data-kid=\"302\">\n                    <p class=\"text-gray-300 italic mb-6\" data-kid=\"303\">\"TaskMate changed how we ship software. It's like having a project manager who never sleeps.\"</p>\n                    <div class=\"flex items-center gap-3\" data-kid=\"304\">\n                        <img src=\"https://i.pravatar.cc/100?u=sarah\" alt=\"User\" class=\"w-10 h-10 rounded-full\" decoding=\"async\" loading=\"lazy\" data-kid=\"305\">\n                        <div data-kid=\"306\">\n                            <div class=\"font-bold text-sm\" data-kid=\"307\">Sarah Jenkins</div>\n                            <div class=\"text-xs text-gray-500\" data-kid=\"308\">CTO at TechFlow</div>\n                        </div>\n                    </div>\n                </div>\n                <div class=\"testimonial-card break-inside-avoid glass p-6 rounded-2xl border-white/5\" data-kid=\"309\">\n                    <p class=\"text-gray-300 italic mb-6\" data-kid=\"310\">\"The only productivity app that actually gives me time back instead of taking it.\"</p>\n                    <div class=\"flex items-center gap-3\" data-kid=\"311\">\n                        <img src=\"https://i.pravatar.cc/100?u=mark\" alt=\"User\" class=\"w-10 h-10 rounded-full\" decoding=\"async\" loading=\"lazy\" data-kid=\"312\">\n                        <div data-kid=\"313\">\n                            <div class=\"font-bold text-sm\" data-kid=\"314\">Mark Thompson</div>\n                            <div class=\"text-xs text-gray-500\" data-kid=\"315\">Creative Director</div>\n                        </div>\n                    </div>\n                </div>\n                <div class=\"testimonial-card break-inside-avoid glass p-6 rounded-2xl border-white/5\" data-kid=\"316\">\n                    <p class=\"text-gray-300 italic mb-6\" data-kid=\"317\">\"Stunning UI, but even better AI intelligence.\"</p>\n                    <div class=\"flex items-center gap-3\" data-kid=\"318\">\n                        <img src=\"https://i.pravatar.cc/100?u=alex\" alt=\"User\" class=\"w-10 h-10 rounded-full\" decoding=\"async\" loading=\"lazy\" data-kid=\"319\">\n                        <div data-kid=\"320\">\n                            <div class=\"font-bold text-sm\" data-kid=\"321\">Alex Rivera</div>\n                            <div class=\"text-xs text-gray-500\" data-kid=\"322\">Freelance Designer</div>\n                        </div>\n                    </div>\n                </div>\n                <div class=\"testimonial-card break-inside-avoid glass-violet p-8 rounded-3xl border-[var(--violet)]/20 shadow-xl\" data-kid=\"323\">\n                    <p class=\"text-xl text-white font-medium mb-8\" data-kid=\"324\">\"I've tried every app from Notion to Linear. TaskMate is on another level. The automation is flawless.\"</p>\n                    <div class=\"flex items-center gap-4\" data-kid=\"325\">\n                        <img src=\"https://i.pravatar.cc/100?u=david\" alt=\"User\" class=\"w-12 h-12 rounded-full\" decoding=\"async\" loading=\"lazy\" data-kid=\"326\">\n                        <div data-kid=\"327\">\n                            <div class=\"font-bold\" data-kid=\"328\">David Chen</div>\n                            <div class=\"text-sm text-gray-400\" data-kid=\"329\">Founder at Stealth AI</div>\n                        </div>\n                    </div>\n                </div>\n                <div class=\"testimonial-card break-inside-avoid glass p-6 rounded-2xl border-white/5\" data-kid=\"330\">\n                    <p class=\"text-gray-300 italic mb-6\" data-kid=\"331\">\"Finally, an AI tool that isn't just a wrapper for ChatGPT. This is purpose-built.\"</p>\n                    <div class=\"flex items-center gap-3\" data-kid=\"332\">\n                        <img src=\"https://i.pravatar.cc/100?u=emma\" alt=\"User\" class=\"w-10 h-10 rounded-full\" decoding=\"async\" loading=\"lazy\" data-kid=\"333\">\n                        <div data-kid=\"334\">\n                            <div class=\"font-bold text-sm\" data-kid=\"335\">Emma Watson</div>\n                            <div class=\"text-xs text-gray-500\" data-kid=\"336\">Product Manager</div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    \n    <section id=\"pricing\" class=\"py-32 px-6\" data-kid=\"337\">\n        <div class=\"max-w-6xl mx-auto\" data-kid=\"338\">\n            <div class=\"text-center mb-24\" data-kid=\"339\">\n                <h2 class=\"font-heading text-5xl font-bold mb-4\" data-kid=\"340\">Invest in your <span class=\"text-[var(--violet)]\" data-kid=\"341\">focus.</span></h2>\n                <p class=\"text-gray-400\" data-kid=\"342\">Free forever for individuals. Professional power for high-achievers.</p>\n            </div>\n\n            <div class=\"grid grid-cols-1 md:grid-cols-3 gap-8 items-stretch\" data-kid=\"343\">\n                \n                <div class=\"glass p-10 rounded-[40px] flex flex-col border-white/5\" data-kid=\"344\">\n                    <h3 class=\"text-xl font-bold mb-2\" data-kid=\"345\">Individual</h3>\n                    <div class=\"flex items-baseline gap-1 mb-8\" data-kid=\"346\">\n                        <span class=\"text-4xl font-bold\" data-kid=\"347\">$0</span>\n                        <span class=\"text-gray-500\" data-kid=\"348\">/mo</span>\n                    </div>\n                    <ul class=\"space-y-4 mb-12 flex-grow\" data-kid=\"349\">\n                        <li class=\"flex items-center gap-3\" data-kid=\"350\"><i class=\"ti ti-check text-emerald-400\" data-kid=\"351\"></i> Unlimited Tasks</li>\n                        <li class=\"flex items-center gap-3\" data-kid=\"352\"><i class=\"ti ti-check text-emerald-400\" data-kid=\"353\"></i> Basic AI Sorting</li>\n                        <li class=\"flex items-center gap-3\" data-kid=\"354\"><i class=\"ti ti-check text-emerald-400\" data-kid=\"355\"></i> Android/iOS Apps</li>\n                    </ul>\n                    <button class=\"w-full py-4 rounded-2xl border border-white/10 hover:bg-white/5 transition-colors font-bold\" data-kid=\"356\">Start Free</button>\n                </div>\n\n                \n                <div class=\"glass-violet p-10 rounded-[40px] flex flex-col border-[var(--violet)]/40 relative scale-105 shadow-[0_0_50px_rgba(138,43,226,0.2)]\" data-kid=\"357\">\n                    <div class=\"absolute -top-4 left-1/2 -translate-x-1/2 bg-[var(--violet)] text-white text-xs font-bold px-4 py-1 rounded-full uppercase tracking-widest\" data-kid=\"358\">Most Popular</div>\n                    <h3 class=\"text-xl font-bold mb-2\" data-kid=\"359\">Professional</h3>\n                    <div class=\"flex items-baseline gap-1 mb-8\" data-kid=\"360\">\n                        <span class=\"text-4xl font-bold\" data-kid=\"361\">$12</span>\n                        <span class=\"text-gray-500\" data-kid=\"362\">/mo</span>\n                    </div>\n                    <ul class=\"space-y-4 mb-12 flex-grow\" data-kid=\"363\">\n                        <li class=\"flex items-center gap-3\" data-kid=\"364\"><i class=\"ti ti-check text-[var(--violet)]\" data-kid=\"365\"></i> Full AI Autopilot</li>\n                        <li class=\"flex items-center gap-3\" data-kid=\"366\"><i class=\"ti ti-check text-[var(--violet)]\" data-kid=\"367\"></i> Calendar Optimization</li>\n                        <li class=\"flex items-center gap-3\" data-kid=\"368\"><i class=\"ti ti-check text-[var(--violet)]\" data-kid=\"369\"></i> Priority Support</li>\n                        <li class=\"flex items-center gap-3\" data-kid=\"370\"><i class=\"ti ti-check text-[var(--violet)]\" data-kid=\"371\"></i> Team Integration</li>\n                    </ul>\n                    <button class=\"w-full py-4 rounded-2xl bg-[var(--violet)] hover:bg-opacity-80 transition-all font-bold shadow-[0_10px_20px_rgba(138,43,226,0.3)]\" data-kid=\"372\">Go Pro</button>\n                </div>\n\n                \n                <div class=\"glass p-10 rounded-[40px] flex flex-col border-white/5\" data-kid=\"373\">\n                    <h3 class=\"text-xl font-bold mb-2\" data-kid=\"374\">Enterprise</h3>\n                    <div class=\"flex items-baseline gap-1 mb-8\" data-kid=\"375\">\n                        <span class=\"text-4xl font-bold\" data-kid=\"376\">Custom</span>\n                    </div>\n                    <ul class=\"space-y-4 mb-12 flex-grow\" data-kid=\"377\">\n                        <li class=\"flex items-center gap-3\" data-kid=\"378\"><i class=\"ti ti-check text-blue-400\" data-kid=\"379\"></i> SSO & Advanced Security</li>\n                        <li class=\"flex items-center gap-3\" data-kid=\"380\"><i class=\"ti ti-check text-blue-400\" data-kid=\"381\"></i> Dedicated Manager</li>\n                        <li class=\"flex items-center gap-3\" data-kid=\"382\"><i class=\"ti ti-check text-blue-400\" data-kid=\"383\"></i> Custom AI Models</li>\n                        <li class=\"flex items-center gap-3\" data-kid=\"384\"><i class=\"ti ti-check text-blue-400\" data-kid=\"385\"></i> API Access</li>\n                    </ul>\n                    <button class=\"w-full py-4 rounded-2xl border border-white/10 hover:bg-white/5 transition-colors font-bold\" data-kid=\"386\">Contact Sales</button>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    \n    <section id=\"final-cta\" class=\"relative min-h-screen px-6 text-center overflow-hidden flex flex-col justify-end pb-32\" data-kid=\"387\">\n        <div class=\"absolute inset-0 z-0\" data-kid=\"388\">\n            <div class=\"absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-[var(--violet)] rounded-full aurora-blur opacity-20\" data-kid=\"389\"></div>\n        </div>\n        \n        <div id=\"cta-sheet\" class=\"relative z-10 max-w-6xl mx-auto glass rounded-t-[100px] p-24 border-b-0 border-white/10 shadow-[0_-50px_100px_rgba(138,43,226,0.1)]\" data-kid=\"390\">\n            <h2 class=\"font-heading text-6xl md:text-[10rem] font-bold mb-12 leading-none\" data-kid=\"391\">Ready for <br data-kid=\"392\"> <span class=\"text-[var(--violet)]\" data-kid=\"393\">Clarity?</span></h2>\n            <p class=\"text-xl md:text-2xl text-gray-400 mb-20 max-w-2xl mx-auto\" data-kid=\"394\">Join 50,000+ others who have reclaimed their time and energy.</p>\n            \n            <div id=\"bottom-cta-btn\" class=\"inline-block\" data-kid=\"395\">\n                <button class=\"group relative px-16 py-8 bg-[var(--violet)] rounded-3xl font-bold text-3xl shadow-[0_0_80px_rgba(138,43,226,0.5)] transition-shadow\" data-kid=\"396\">\n                    <span class=\"relative z-10\" data-kid=\"397\">Start Your Journey</span>\n                </button>\n            </div>\n        </div>\n    </section>\n\n    \n    <footer class=\"py-12 px-6 border-t border-white/5 bg-[var(--obsidian)]\" data-kid=\"398\">\n        <div class=\"max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-center gap-8\" data-kid=\"399\">\n            <div class=\"flex items-center gap-3\" data-kid=\"400\">\n                <i class=\"ti ti-sparkles text-2xl text-[var(--violet)]\" data-kid=\"401\"></i>\n                <span class=\"font-heading font-bold text-xl tracking-tight\" data-kid=\"402\">TaskMate AI</span>\n            </div>\n            \n            <nav class=\"flex gap-8 text-sm text-gray-500 font-medium\" data-kid=\"403\">\n                <a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"404\">Product</a>\n                <a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"405\">Privacy</a>\n                <a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"406\">Terms</a>\n                <a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"407\">Contact</a>\n            </nav>\n            \n            <div class=\"text-sm text-gray-600\" data-kid=\"408\">\n                &copy; 2026 TaskMate AI. Made for the future.\n            </div>\n        </div>\n    </footer>\n</div>\n\n<script data-kid=\"409\">\n    document.addEventListener('DOMContentLoaded', () => {\n        gsap.registerPlugin(ScrollTrigger);\n\n        // 1. Hero Reveal Animation\n        const heroTimeline = gsap.timeline();\n        const heroTitle = new SplitType('#hero-title', { types: 'chars' });\n        \n        heroTimeline\n            .from('#hero-logo', { scale: 0, opacity: 0, duration: 1.2, ease: \"back.out(1.7)\" })\n            .from(heroTitle.chars, { opacity: 0, y: 100, stagger: 0.03, duration: 1.2, ease: \"power4.out\" }, \"-=0.5\")\n            .from('#hero-subtitle', { opacity: 0, y: 30, duration: 1, ease: \"power3.out\" }, \"-=0.7\")\n            .from('#hero-ctas button', { opacity: 0, y: 30, stagger: 0.2, duration: 1, ease: \"power3.out\" }, \"-=0.7\")\n            .from('#hero-stats div', { opacity: 0, y: 20, stagger: 0.1, duration: 0.8 }, \"-=0.5\");\n\n        // 2. Chaos Section (Pinned Zoom Out)\n        gsap.to('#chaos-content', {\n            scale: 0.3,\n            opacity: 0,\n            scrollTrigger: {\n                trigger: '#chaos-section',\n                start: 'top top',\n                end: 'bottom top',\n                scrub: 1.5,\n                pin: true\n            }\n        });\n\n        gsap.from('.chaos-item', {\n            x: (i) => (i % 2 === 0 ? -600 : 600),\n            y: (i) => (i < 4 ? -600 : 600),\n            opacity: 0,\n            scale: 3,\n            stagger: 0.05,\n            scrollTrigger: {\n                trigger: '#chaos-section',\n                start: 'top 90%',\n                end: 'top 20%',\n                scrub: 2\n            }\n        });\n\n        // Dashboard Tilt Effect\n        const dashboard = document.getElementById('dashboard-mockup');\n        window.addEventListener('mousemove', (e) => {\n            const { clientX, clientY } = e;\n            const { innerWidth, innerHeight } = window;\n            const xPercent = (clientX / innerWidth - 0.5) * 15;\n            const yPercent = (clientY / innerHeight - 0.5) * -15;\n            \n            gsap.to(dashboard, {\n                rotateY: xPercent,\n                rotateX: yPercent,\n                duration: 1.2,\n                ease: 'power2.out'\n            });\n\n            // Cursor Glow\n            gsap.to('#cursor-glow', {\n                x: clientX,\n                y: clientY,\n                duration: 0.2\n            });\n        });\n\n        // Magnetic Buttons\n        const btns = document.querySelectorAll('button');\n        btns.forEach(btn => {\n            btn.addEventListener('mousemove', (e) => {\n                const rect = btn.getBoundingClientRect();\n                const x = e.clientX - rect.left - rect.width / 2;\n                const y = e.clientY - rect.top - rect.height / 2;\n                gsap.to(btn, {\n                    x: x * 0.4,\n                    y: y * 0.4,\n                    duration: 0.4\n                });\n            });\n            btn.addEventListener('mouseleave', () => {\n                gsap.to(btn, {\n                    x: 0,\n                    y: 0,\n                    duration: 0.6,\n                    ease: \"elastic.out(1, 0.4)\"\n                });\n            });\n        });\n\n        // 3. AI Understands (Peephole)\n        const understandTl = gsap.timeline({\n            scrollTrigger: {\n                trigger: '#understand-section',\n                start: 'top top',\n                end: '+=150%',\n                pin: true,\n                scrub: 1\n            }\n        });\n\n        understandTl\n            .to('#peephole-overlay', {\n                background: 'radial-gradient(circle 1000px at center, transparent 0%, var(--obsidian) 100%)',\n                ease: 'none'\n            })\n            .to('#ai-core', {\n                scale: 1.5,\n                boxShadow: '0 0 200px rgba(138,43,226,0.8)',\n                duration: 1\n            }, 0)\n            .to('#ai-text', {\n                opacity: 1,\n                y: 0,\n                duration: 1\n            }, 0.5);\n\n        // 4. AI Organizes (Ladder)\n        gsap.from('.ladder-item', {\n            opacity: 0,\n            y: 100,\n            stagger: 0.3,\n            scrollTrigger: {\n                trigger: '#organize-section',\n                start: 'top 60%',\n                end: 'bottom 80%',\n                scrub: 1\n            }\n        });\n\n        gsap.to('#organize-progress', {\n            width: '100%',\n            scrollTrigger: {\n                trigger: '#organize-section',\n                start: 'top center',\n                end: 'bottom center',\n                scrub: true,\n                onUpdate: (self) => {\n                    const progress = self.progress;\n                    const status = document.getElementById('organize-status');\n                    if (progress < 0.3) status.innerText = \"Organizing...\";\n                    else if (progress < 0.6) status.innerText = \"Prioritizing...\";\n                    else if (progress < 0.9) status.innerText = \"Scheduling...\";\n                    else status.innerText = \"Optimized.\";\n                }\n            }\n        });\n\n        // 5. AI Assistant (Chat Reveal)\n        gsap.to('#ai-response', {\n            opacity: 1,\n            x: 0,\n            scrollTrigger: {\n                trigger: '#assistant-section',\n                start: 'top center',\n                end: 'top 20%',\n                toggleActions: 'play none none reverse'\n            }\n        });\n\n        // 6. Transformation (Before/After)\n        gsap.to('#after-view', {\n            clipPath: 'inset(0% 0 0 0)',\n            scrollTrigger: {\n                trigger: '#transformation-section',\n                start: 'top top',\n                end: 'bottom top',\n                scrub: true,\n                pin: true\n            }\n        });\n\n        // 7. General Entrance Reveals\n        gsap.from('#features .glass', {\n            opacity: 0,\n            y: 50,\n            stagger: 0.1,\n            scrollTrigger: {\n                trigger: '#features',\n                start: 'top 70%'\n            }\n        });\n\n        gsap.from('.testimonial-card', {\n            opacity: 0,\n            scale: 0.9,\n            stagger: 0.1,\n            scrollTrigger: {\n                trigger: '#testimonials',\n                start: 'top 70%'\n            }\n        });\n        \n        // Final CTA Bottom Sheet Reveal\n        gsap.from('#cta-sheet', {\n            y: 400,\n            opacity: 0,\n            scrollTrigger: {\n                trigger: '#final-cta',\n                start: 'top bottom',\n                end: 'bottom bottom',\n                scrub: 1\n            }\n        });\n\n        gsap.from('#bottom-cta-btn', {\n            scale: 0.8,\n            opacity: 0,\n            duration: 1.5,\n            ease: \"back.out(2)\",\n            scrollTrigger: {\n                trigger: '#cta-sheet',\n                start: 'top 60%'\n            }\n        });\n    });\n</script>\n",
      "comments": [],
      "created": "2026-06-13T06:31:49.582058+00:00",
      "modified": "2026-06-13T06:31:49.582058+00:00",
      "id": "var_95247a80b8bc"
    }
