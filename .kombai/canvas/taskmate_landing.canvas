ansparent pointer-events-none\" data-kid=\"91\"></div>\n          <div class=\"relative z-10\" data-kid=\"92\">\n            <div class=\"w-20 h-20 rounded-3xl bg-[var(--purple)]/10 border border-[var(--purple)]/20 flex items-center justify-center mb-10 shadow-[0_0_30px_rgba(139,101,200,0.2)]\" data-kid=\"93\">\n              <i class=\"ti ti-sparkles text-[var(--purple)] text-5xl\" data-kid=\"94\"></i>\n            </div>\n            <h3 class=\"text-4xl font-extrabold mb-8 tracking-tight\" data-kid=\"95\">AI Smart Suggestions</h3>\n            <p class=\"text-[var(--text2)] text-xl leading-relaxed max-w-md\" data-kid=\"96\">\n              TaskMate AI learns your daily habits and surfaces forgotten tasks exactly when you're most likely to tackle them. It's like having a personal assistant who knows your brain.\n            </p>\n          </div>\n          \n          <div class=\"absolute -bottom-16 -right-16 opacity-10 group-hover:opacity-30 transition-all duration-700 pointer-events-none rotate-12 group-hover:rotate-0\" data-kid=\"97\">\n            <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/delapouite/sparkles.svg\" class=\"w-[400px] h-[400px] invert\" alt=\"Sparkles\" decoding=\"async\" loading=\"lazy\" data-kid=\"98\">\n          </div>\n        </div>\n\n        \n        <div class=\"spatial-card p-8 group hover:border-[var(--pink)]/30 transition-colors\" data-kid=\"99\">\n          <div class=\"w-12 h-12 rounded-xl bg-[var(--pink)]/10 border border-[var(--pink)]/20 flex items-center justify-center mb-6\" data-kid=\"100\">\n            <i class=\"ti ti-microphone text-[var(--pink)] text-2xl\" data-kid=\"101\"></i>\n          </div>\n          <h3 class=\"text-xl font-bold mb-3\" data-kid=\"102\">Voice to Task</h3>\n          <p class=\"text-[var(--text2)] text-sm leading-relaxed\" data-kid=\"103\">Convert fleeting thoughts to structured tasks with industry-leading transcription accuracy.</p>\n        </div>\n\n        \n        <div class=\"spatial-card p-8 group hover:border-[var(--teal)]/30 transition-colors\" data-kid=\"104\">\n          <div class=\"w-12 h-12 rounded-xl bg-[var(--teal)]/10 border border-[var(--teal)]/20 flex items-center justify-center mb-6\" data-kid=\"105\">\n            <i class=\"ti ti-bell-ringing text-[var(--teal)] text-2xl\" data-kid=\"106\"></i>\n          </div>\n          <h3 class=\"text-xl font-bold mb-3\" data-kid=\"107\">Smart Reminders</h3>\n          <p class=\"text-[var(--text2)] text-sm leading-relaxed\" data-kid=\"108\">Context-aware notifications that fire based on location, priority, and previous patterns.</p>\n        </div>\n\n        \n        <div class=\"md:col-span-2 spatial-card p-8 flex items-center gap-8 group hover:border-[var(--orange)]/30 transition-colors\" data-kid=\"109\">\n          <div class=\"w-20 h-20 shrink-0 rounded-2xl bg-[var(--orange)]/10 border border-[var(--orange)]/20 flex items-center justify-center\" data-kid=\"110\">\n            <i class=\"ti ti-calendar-event text-[var(--orange)] text-4xl\" data-kid=\"111\"></i>\n          </div>\n          <div data-kid=\"112\">\n            <h3 class=\"text-2xl font-bold mb-2\" data-kid=\"113\">Bi-Directional Calendar Sync</h3>\n            <p class=\"text-[var(--text2)] text-base\" data-kid=\"114\">Your G-Cal events show up in TaskMate, and your tasks can block time on your calendar. Stay perfectly synced.</p>\n          </div>\n        </div>\n\n        \n        <div class=\"spatial-card p-8 group hover:border-[var(--purple)]/30 transition-colors\" data-kid=\"115\">\n          <div class=\"w-12 h-12 rounded-xl bg-[var(--purple)]/10 border border-[var(--purple)]/20 flex items-center justify-center mb-6\" data-kid=\"116\">\n            <i class=\"ti ti-target text-[var(--purple)] text-2xl\" data-kid=\"117\"></i>\n          </div>\n          <h3 class=\"text-xl font-bold mb-3\" data-kid=\"118\">Deep Focus</h3>\n          <p class=\"text-[var(--text2)] text-sm leading-relaxed\" data-kid=\"119\">Three customizable Pomodoro modes with immersive soundscapes to get into flow.</p>\n        </div>\n\n        \n        <div class=\"spatial-card p-8 group hover:border-[var(--teal)]/30 transition-colors\" data-kid=\"120\">\n          <div class=\"w-12 h-12 rounded-xl bg-[var(--teal)]/10 border border-[var(--teal)]/20 flex items-center justify-center mb-6\" data-kid=\"121\">\n            <i class=\"ti ti-layout-grid text-[var(--teal)] text-2xl\" data-kid=\"122\"></i>\n          </div>\n          <h3 class=\"text-xl font-bold mb-3\" data-kid=\"123\">Dynamic Widgets</h3>\n          <p class=\"text-[var(--text2)] text-sm leading-relaxed\" data-kid=\"124\">High-performance Android widgets that keep your top tasks front and center always.</p>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section id=\"how-it-works\" class=\"py-32 px-8 bg-[var(--dark2)]/20\" data-kid=\"125\">\n    <div class=\"max-w-[1100px] mx-auto grid lg:grid-cols-2 gap-24 items-center\" data-kid=\"126\">\n      <div class=\"space-y-12\" data-kid=\"127\">\n        <div class=\"space-y-4\" data-kid=\"128\">\n          <span class=\"text-[12px] font-bold text-[var(--teal)] uppercase tracking-[0.3em]\" data-kid=\"129\">Workflow</span>\n          <h2 class=\"text-5xl font-bold leading-tight\" data-kid=\"130\">Plan in seconds, execute all day</h2>\n        </div>\n\n        <div class=\"space-y-6\" data-kid=\"131\">\n          \n          <div class=\"spatial-card p-6 border-[var(--purple)] bg-[var(--dark3)] group cursor-pointer\" data-kid=\"132\">\n            <div class=\"flex gap-6\" data-kid=\"133\">\n              <div class=\"w-12 h-12 rounded-full bg-cta-gradient flex items-center justify-center text-xl font-extrabold text-white shrink-0 shadow-lg shadow-[#F0607A]/20\" data-kid=\"134\">1</div>\n              <div data-kid=\"135\">\n                <h3 class=\"text-xl font-bold mb-2\" data-kid=\"136\">Capture your thoughts</h3>\n                <p class=\"text-[var(--text2)]\" data-kid=\"137\">Voice or type. TaskMate auto-categorizes tasks by project and priority using LLM technology.</p>\n              </div>\n            </div>\n          </div>\n          \n          <div class=\"spatial-card p-6 border-white/5 hover:border-white/10 transition-all cursor-pointer opacity-60 hover:opacity-100\" data-kid=\"138\">\n            <div class=\"flex gap-6\" data-kid=\"139\">\n              <div class=\"w-12 h-12 rounded-full bg-white/10 flex items-center justify-center text-xl font-extrabold text-white shrink-0\" data-kid=\"140\">2</div>\n              <div data-kid=\"141\">\n                <h3 class=\"text-xl font-bold mb-2\" data-kid=\"142\">AI Optimizes Schedule</h3>\n                <p class=\"text-[var(--text2)]\" data-kid=\"143\">Our engine suggests the best time slots based on your energy levels and existing deadlines.</p>\n              </div>\n            </div>\n          </div>\n          \n          <div class=\"spatial-card p-6 border-white/5 hover:border-white/10 transition-all cursor-pointer opacity-60 hover:opacity-100\" data-kid=\"144\">\n            <div class=\"flex gap-6\" data-kid=\"145\">\n              <div class=\"w-12 h-12 rounded-full bg-white/10 flex items-center justify-center text-xl font-extrabold text-white shrink-0\" data-kid=\"146\">3</div>\n              <div data-kid=\"147\">\n                <h3 class=\"text-xl font-bold mb-2\" data-kid=\"148\">Focus and Finish</h3>\n                <p class=\"text-[var(--text2)]\" data-kid=\"149\">Trigger Focus Mode to block distractions and watch your productivity streaks grow.</p>\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n\n      \n      <div class=\"relative flex justify-center items-center h-[500px]\" data-kid=\"150\">\n        \n        <div class=\"spatial-card w-full h-full bg-[var(--dark3)] p-12 flex flex-col justify-center items-center gap-12 border-[var(--purple)]/20 shadow-2xl relative overflow-hidden\" data-kid=\"151\">\n          <div class=\"flex items-center gap-2 h-24\" data-kid=\"152\">\n            <style data-kid=\"153\">\n              .bar { width: 6px; border-radius: 99px; background: linear-gradient(to top, #F0607A, #8B65C8); animation: wave 1.5s ease-in-out infinite; }\n              @keyframes wave { 0%, 100% { height: 20px; } 50% { height: 80px; } }\n            </style>\n            <div class=\"bar\" style=\"animation-delay: 0.1s;\" data-kid=\"154\"></div>\n            <div class=\"bar\" style=\"animation-delay: 0.3s;\" data-kid=\"155\"></div>\n            <div class=\"bar\" style=\"animation-delay: 0.2s;\" data-kid=\"156\"></div>\n            <div class=\"bar\" style=\"animation-delay: 0.5s;\" data-kid=\"157\"></div>\n            <div class=\"bar\" style=\"animation-delay: 0.4s;\" data-kid=\"158\"></div>\n            <div class=\"bar\" style=\"animation-delay: 0.7s;\" data-kid=\"159\"></div>\n            <div class=\"bar\" style=\"animation-delay: 0.6s;\" data-kid=\"160\"></div>\n            <div class=\"bar\" style=\"animation-delay: 0.8s;\" data-kid=\"161\"></div>\n            <div class=\"bar\" style=\"animation-delay: 0.9s;\" data-kid=\"162\"></div>\n            <div class=\"bar\" style=\"animation-delay: 0.1s;\" data-kid=\"163\"></div>\n          </div>\n          \n          <div class=\"text-center space-y-6\" data-kid=\"164\">\n             <p class=\"text-2xl font-medium text-[var(--text)] italic leading-relaxed\" data-kid=\"165\">\"Add a meeting with Arjun tomorrow at 3pm regarding the design finalization...\"</p>\n             <div class=\"inline-flex items-center gap-3 px-4 py-2 rounded-full bg-[var(--teal)]/10 border border-[var(--teal)]/20 text-[var(--teal)] font-bold text-xs uppercase tracking-widest\" data-kid=\"166\">\n               <span class=\"w-2 h-2 rounded-full bg-[var(--teal)] animate-pulse\" data-kid=\"167\"></span>\n               AI Transcribing task...\n             </div>\n          </div>\n\n          \n          <div class=\"absolute inset-0 border-[60px] border-white/2 rounded-full scale-150 pointer-events-none\" data-kid=\"168\"></div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section id=\"pricing\" class=\"py-32 px-8\" data-kid=\"169\">\n    <div class=\"max-w-[1100px] mx-auto\" data-kid=\"170\">\n      <div class=\"text-center mb-24 space-y-4\" data-kid=\"171\">\n        <span class=\"text-[12px] font-bold text-[var(--teal)] uppercase tracking-[0.3em]\" data-kid=\"172\">Pricing</span>\n        <h2 class=\"text-5xl font-bold\" data-kid=\"173\">Simple, transparent pricing</h2>\n      </div>\n\n      <div class=\"grid md:grid-cols-3 gap-8 items-stretch\" data-kid=\"174\">\n        \n        <div class=\"spatial-card p-10 flex flex-col hover:border-white/20 transition-all\" data-kid=\"175\">\n          <div class=\"mb-10\" data-kid=\"176\">\n            <h3 class=\"text-xl font-bold text-[var(--text2)] mb-4\" data-kid=\"177\">Basic</h3>\n            <div class=\"text-5xl font-extrabold mb-2\" data-kid=\"178\">₹0</div>\n            <p class=\"text-[var(--text3)] font-medium\" data-kid=\"179\">Free forever, no strings attached.</p>\n          </div>\n          <ul class=\"space-y-5 mb-12 flex-grow\" data-kid=\"180\">\n            <li class=\"flex items-center gap-3 text-sm font-medium\" data-kid=\"181\"><i class=\"ti ti-circle-check-filled text-[var(--teal)] text-lg\" data-kid=\"182\"></i> Unlimited Tasks</li>\n            <li class=\"flex items-center gap-3 text-sm font-medium\" data-kid=\"183\"><i class=\"ti ti-circle-check-filled text-[var(--teal)] text-lg\" data-kid=\"184\"></i> Basic Voice Input</li>\n            <li class=\"flex items-center gap-3 text-sm font-medium\" data-kid=\"185\"><i class=\"ti ti-circle-check-filled text-[var(--teal)] text-lg\" data-kid=\"186\"></i> Smart Reminders</li>\n            <li class=\"flex items-center gap-3 text-sm font-medium opacity-30\" data-kid=\"187\"><i class=\"ti ti-circle-x-filled text-lg\" data-kid=\"188\"></i> AI Suggestions</li>\n            <li class=\"flex items-center gap-3 text-sm font-medium opacity-30\" data-kid=\"189\"><i class=\"ti ti-circle-x-filled text-lg\" data-kid=\"190\"></i> Team Workspaces</li>\n          </ul>\n          <button class=\"w-full py-4 rounded-xl border border-white/10 font-bold hover:bg-white/5 transition-all cursor-pointer\" data-kid=\"191\">Start Free</button>\n        </div>\n\n        \n        <div class=\"spatial-card p-10 flex flex-col bg-[var(--dark3)] border-[var(--purple)]/60 glow-pulse scale-105 relative z-10 shadow-[0_30px_100px_rgba(139,101,200,0.2)] border-t-[var(--purple)]\" data-kid=\"192\">\n          <div class=\"absolute -top-4 left-1/2 -translate-x-1/2 px-6 py-2 rounded-full bg-gradient-to-r from-[#8B65C8] to-[#F0607A] text-white text-[11px] font-black uppercase tracking-[0.25em] shadow-[0_10px_30px_rgba(139,101,200,0.5)] whitespace-nowrap\" data-kid=\"193\">Most Popular</div>\n          <div class=\"mb-10\" data-kid=\"194\">\n            <h3 class=\"text-xl font-bold text-[var(--purple)] mb-4\" data-kid=\"195\">Pro</h3>\n            <div class=\"text-5xl font-extrabold mb-2\" data-kid=\"196\">₹199<span class=\"text-xl font-medium text-[var(--text3)]\" data-kid=\"197\">/mo</span></div>\n            <p class=\"text-[var(--text2)] font-medium\" data-kid=\"198\">Power users and goal achievers.</p>\n          </div>\n          <ul class=\"space-y-5 mb-12 flex-grow\" data-kid=\"199\">\n            <li class=\"flex items-center gap-3 text-sm font-medium\" data-kid=\"200\"><i class=\"ti ti-circle-check-filled text-[var(--teal)] text-lg\" data-kid=\"201\"></i> Everything in Basic</li>\n            <li class=\"flex items-center gap-3 text-sm font-medium\" data-kid=\"202\"><i class=\"ti ti-circle-check-filled text-[var(--teal)] text-lg\" data-kid=\"203\"></i> AI Smart Suggestions</li>\n            <li class=\"flex items-center gap-3 text-sm font-medium\" data-kid=\"204\"><i class=\"ti ti-circle-check-filled text-[var(--teal)] text-lg\" data-kid=\"205\"></i> Focus Mode Pro</li>\n            <li class=\"flex items-center gap-3 text-sm font-medium\" data-kid=\"206\"><i class=\"ti ti-circle-check-filled text-[var(--teal)] text-lg\" data-kid=\"207\"></i> Detailed Analytics</li>\n            <li class=\"flex items-center gap-3 text-sm font-medium\" data-kid=\"208\"><i class=\"ti ti-circle-check-filled text-[var(--teal)] text-lg\" data-kid=\"209\"></i> Calendar Sync Pro</li>\n          </ul>\n          <button class=\"w-full py-5 rounded-xl bg-cta-gradient font-bold shadow-xl shadow-[#F0607A]/20 hover:scale-105 active:scale-95 transition-all cursor-pointer\" data-kid=\"210\">Get Pro →</button>\n        </div>\n\n        \n        <div class=\"spatial-card p-10 flex flex-col hover:border-white/20 transition-all\" data-kid=\"211\">\n          <div class=\"mb-10\" data-kid=\"212\">\n            <h3 class=\"text-xl font-bold text-[var(--orange)] mb-4\" data-kid=\"213\">Team</h3>\n            <div class=\"text-5xl font-extrabold mb-2\" data-kid=\"214\">₹499<span class=\"text-xl font-medium text-[var(--text3)]\" data-kid=\"215\">/user</span></div>\n            <p class=\"text-[var(--text3)] font-medium\" data-kid=\"216\">For high-performing squads.</p>\n          </div>\n          <ul class=\"space-y-5 mb-12 flex-grow\" data-kid=\"217\">\n            <li class=\"flex items-center gap-3 text-sm font-medium\" data-kid=\"218\"><i class=\"ti ti-circle-check-filled text-[var(--teal)] text-lg\" data-kid=\"219\"></i> Everything in Pro</li>\n            <li class=\"flex items-center gap-3 text-sm font-medium\" data-kid=\"220\"><i class=\"ti ti-circle-check-filled text-[var(--teal)] text-lg\" data-kid=\"221\"></i> Shared Workspaces</li>\n            <li class=\"flex items-center gap-3 text-sm font-medium\" data-kid=\"222\"><i class=\"ti ti-circle-check-filled text-[var(--teal)] text-lg\" data-kid=\"223\"></i> Admin Controls</li>\n            <li class=\"flex items-center gap-3 text-sm font-medium\" data-kid=\"224\"><i class=\"ti ti-circle-check-filled text-[var(--teal)] text-lg\" data-kid=\"225\"></i> Team Analytics</li>\n            <li class=\"flex items-center gap-3 text-sm font-medium\" data-kid=\"226\"><i class=\"ti ti-circle-check-filled text-[var(--teal)] text-lg\" data-kid=\"227\"></i> API Access</li>\n          </ul>\n          <button class=\"w-full py-4 rounded-xl border border-white/10 font-bold hover:bg-white/5 transition-all cursor-pointer\" data-kid=\"228\">Contact Sales</button>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"py-32 px-8 overflow-hidden\" data-kid=\"229\">\n    <div class=\"max-w-[1100px] mx-auto\" data-kid=\"230\">\n      <div class=\"text-center mb-24\" data-kid=\"231\">\n         <h2 class=\"text-5xl font-bold\" data-kid=\"232\">Loved by 1,200+ achievers</h2>\n      </div>\n\n      <div class=\"relative max-w-2xl mx-auto h-[520px]\" data-kid=\"233\">\n        \n        \n        <div class=\"absolute inset-0 spatial-card p-10 flex flex-col scale-[0.85] translate-y-16 opacity-30 z-0 grayscale blur-[1px]\" data-kid=\"234\">\n          <div class=\"flex items-center gap-4 mb-8\" data-kid=\"235\">\n            <div class=\"w-14 h-14 rounded-full bg-gradient-to-br from-[var(--teal)] to-[var(--purple)]\" data-kid=\"236\"></div>\n            <div data-kid=\"237\">\n              <div class=\"font-bold text-xl\" data-kid=\"238\">Rahul Mehta</div>\n              <div class=\"text-sm text-[var(--text3)]\" data-kid=\"239\">Product Lead, Bangalore</div>\n            </div>\n          </div>\n          <p class=\"text-xl text-[var(--text2)] italic leading-relaxed\" data-kid=\"240\">\"The AI suggestions are scarily accurate. It knows when I'm procrastinating.\"</p>\n        </div>\n        \n        <div class=\"absolute inset-0 spatial-card p-10 flex flex-col scale-[0.93] translate-y-8 opacity-70 z-10 blur-[0.5px]\" data-kid=\"241\">\n          <div class=\"flex items-center gap-4 mb-8\" data-kid=\"242\">\n            <div class=\"w-14 h-14 rounded-full bg-gradient-to-br from-[var(--orange)] to-[var(--pink)]\" data-kid=\"243\"></div>\n            <div data-kid=\"244\">\n              <div class=\"font-bold text-xl\" data-kid=\"245\">Sneha Rao</div>\n              <div class=\"text-sm text-[var(--text3)]\" data-kid=\"246\">UX Architect, Mumbai</div>\n            </div>\n          </div>\n          <p class=\"text-xl text-[var(--text2)] italic leading-relaxed\" data-kid=\"247\">\"Finally, a task manager that doesn't feel like a chore to use. The UI is stunning.\"</p>\n        </div>\n        \n        <div class=\"absolute inset-0 spatial-card p-10 flex flex-col z-20 shadow-2xl border-[var(--purple)]/30 group\" data-kid=\"248\">\n          <div class=\"flex items-center justify-between mb-8\" data-kid=\"249\">\n            <div class=\"flex items-center gap-4\" data-kid=\"250\">\n              <div class=\"w-16 h-16 rounded-full bg-gradient-to-br from-[var(--pink)] to-[var(--purple)] flex items-center justify-center text-white font-black text-xl\" data-kid=\"251\">AV</div>\n              <div data-kid=\"252\">\n                <div class=\"font-bold text-2xl\" data-kid=\"253\">Ankit Verma</div>\n                <div class=\"text-sm text-[var(--text3)]\" data-kid=\"254\">Freelance Developer, Ahmedabad</div>\n              </div>\n            </div>\n            <div class=\"flex gap-1 text-[var(--orange)]\" data-kid=\"255\">\n              <i class=\"ti ti-star-filled\" data-kid=\"256\"></i><i class=\"ti ti-star-filled\" data-kid=\"257\"></i><i class=\"ti ti-star-filled\" data-kid=\"258\"></i><i class=\"ti ti-star-filled\" data-kid=\"259\"></i><i class=\"ti ti-star-filled\" data-kid=\"260\"></i>\n            </div>\n          </div>\n          <p class=\"text-2xl text-[var(--text)] italic leading-relaxed font-medium\" data-kid=\"261\">\n            \"TaskMate AI has completely changed my daily routine. The voice input is a game-changer for capturing ideas on the go. Focus Mode timer is the only thing that keeps me productive during late-night coding sessions.\"\n          </p>\n          <div class=\"mt-auto flex justify-end\" data-kid=\"262\">\n            <i class=\"ti ti-quote text-6xl text-white/5 group-hover:text-[var(--purple)]/20 transition-colors\" data-kid=\"263\"></i>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section id=\"faq\" class=\"py-32 px-8 bg-[var(--dark2)]/10\" data-kid=\"264\">\n    <div class=\"max-w-[1100px] mx-auto\" data-kid=\"265\">\n      <div class=\"grid lg:grid-cols-5 gap-20\" data-kid=\"266\">\n        <div class=\"lg:col-span-2 space-y-10\" data-kid=\"267\">\n          <div class=\"space-y-4\" data-kid=\"268\">\n            <span class=\"text-[12px] font-bold text-[var(--teal)] uppercase tracking-[0.3em]\" data-kid=\"269\">Help Center</span>\n            <h2 class=\"text-5xl font-bold\" data-kid=\"270\">Common Questions</h2>\n          </div>\n          <div class=\"space-y-3\" data-kid=\"271\">\n            <button class=\"w-full text-left px-8 py-5 rounded-2xl bg-[var(--purple)]/10 border border-[var(--purple)]/30 font-extrabold text-white text-lg transition-all cursor-pointer shadow-lg shadow-[var(--purple)]/5\" data-kid=\"272\">Is TaskMate AI really free?</button>\n            <button class=\"w-full text-left px-8 py-5 rounded-2xl hover:bg-white/5 font-bold text-[var(--text2)] hover:text-white text-lg transition-all cursor-pointer\" data-kid=\"273\">Which platforms are supported?</button>\n            <button class=\"w-full text-left px-8 py-5 rounded-2xl hover:bg-white/5 font-bold text-[var(--text2)] hover:text-white text-lg transition-all cursor-pointer\" data-kid=\"274\">How secure is my voice data?</button>\n            <button class=\"w-full text-left px-8 py-5 rounded-2xl hover:bg-white/5 font-bold text-[var(--text2)] hover:text-white text-lg transition-all cursor-pointer\" data-kid=\"275\">Can I use TaskMate offline?</button>\n            <button class=\"w-full text-left px-8 py-5 rounded-2xl hover:bg-white/5 font-bold text-[var(--text2)] hover:text-white text-lg transition-all cursor-pointer\" data-kid=\"276\">Team collaboration features?</button>\n          </div>\n        </div>\n\n        <div class=\"lg:col-span-3\" data-kid=\"277\">\n          <div class=\"spatial-card p-12 bg-[var(--dark2)] min-h-[400px] flex flex-col justify-center\" data-kid=\"278\">\n            <h3 class=\"text-3xl font-bold mb-8\" data-kid=\"279\">Is TaskMate AI really free?</h3>\n            <div class=\"space-y-6 text-[var(--text2)] text-lg leading-relaxed\" data-kid=\"280\">\n              <p data-kid=\"281\">Yes! Our core productivity tools—including unlimited task creation, basic voice transcription, and smart reminders—are 100% free forever. No credit card required to start.</p>\n              <p data-kid=\"282\">We generate revenue through our Pro plan, which offers advanced AI capabilities and deep focus analytics for those who want to push their productivity to the absolute limit.</p>\n              <ul class=\"space-y-3 pt-4\" data-kid=\"283\">\n                <li class=\"flex items-center gap-3\" data-kid=\"284\"><i class=\"ti ti-check text-[var(--teal)]\" data-kid=\"285\"></i> No hidden fees</li>\n                <li class=\"flex items-center gap-3\" data-kid=\"286\"><i class=\"ti ti-check text-[var(--teal)]\" data-kid=\"287\"></i> No ads, ever</li>\n                <li class=\"flex items-center gap-3\" data-kid=\"288\"><i class=\"ti ti-check text-[var(--teal)]\" data-kid=\"289\"></i> Your data stays yours</li>\n              </ul>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"pt-40 pb-0 px-8\" data-kid=\"290\">\n    <div class=\"max-w-[1200px] mx-auto\" data-kid=\"291\">\n      <div class=\"spatial-card bg-gradient-to-b from-[var(--dark3)] to-[var(--dark2)] p-20 text-center relative overflow-hidden rounded-t-[60px] border-b-0 shadow-[0_-30px_120px_rgba(139,101,200,0.25)] border-white/10\" data-kid=\"292\">\n        \n        <div class=\"absolute top-0 left-1/2 -translate-x-1/2 w-full h-full bg-primary-gradient opacity-[0.08] blur-[100px]\" data-kid=\"293\"></div>\n        \n        <div class=\"relative z-10 space-y-12\" data-kid=\"294\">\n          <h2 class=\"text-6xl md:text-7xl font-extrabold tracking-tight\" data-kid=\"295\">Ready to plan smarter?</h2>\n          <p class=\"text-2xl text-[var(--text2)] max-w-2xl mx-auto leading-relaxed\" data-kid=\"296\">Join 1,200+ achievers who have reclaimed their time and focus with TaskMate AI. Download the free app today.</p>\n          \n          <div class=\"flex flex-col sm:flex-row justify-center gap-6\" data-kid=\"297\">\n            <button class=\"bg-cta-gradient px-12 py-6 rounded-2xl text-2xl font-black shadow-2xl shadow-[#F0607A]/40 hover:scale-105 active:scale-95 transition-all cursor-pointer\" data-kid=\"298\">Download Free on Android</button>\n            <button class=\"px-12 py-6 rounded-2xl border border-white/10 bg-white/5 text-2xl font-bold hover:bg-white/10 transition-all cursor-pointer flex items-center justify-center gap-4\" data-kid=\"299\">\n              <i class=\"ti ti-brand-producthunt text-3xl text-[#FF6154]\" data-kid=\"300\"></i> View on Product Hunt\n            </button>\n          </div>\n          \n          <div class=\"pt-12 text-[var(--text3)] text-sm font-bold uppercase tracking-[0.3em]\" data-kid=\"301\">No Credit Card · No Ads · Pure Focus</div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <footer class=\"bg-[#0A0711] border-t border-white/5 py-24 px-8 relative z-20\" data-kid=\"302\">\n    <div class=\"max-w-[1200px] mx-auto grid md:grid-cols-4 gap-16\" data-kid=\"303\">\n      <div class=\"space-y-8\" data-kid=\"304\">\n        <div class=\"flex items-center gap-3\" data-kid=\"305\">\n          <img src=\"/api/local/images/assets/logo.png\" class=\"w-10 h-10 rounded-xl\" alt=\"Logo\" decoding=\"async\" loading=\"lazy\" data-kid=\"306\">\n          <span class=\"font-extrabold text-2xl tracking-tight\" data-kid=\"307\">TaskMate AI</span>\n        </div>\n        <p class=\"text-[var(--text3)] text-base leading-relaxed\" data-kid=\"308\">\n          The next generation of personal productivity. AI-powered, human-centered, and built for achievers.\n        </p>\n        <div class=\"text-sm text-[var(--text3)]\" data-kid=\"309\">\n          Made with ♥ in Ahmedabad 🇮🇳<br data-kid=\"310\">\n          By CK Future Tech\n        </div>\n      </div>\n\n      <div class=\"space-y-6\" data-kid=\"311\">\n        <h4 class=\"font-bold text-lg\" data-kid=\"312\">Product</h4>\n        <ul class=\"space-y-4 text-[var(--text2)]\" data-kid=\"313\">\n          <li data-kid=\"314\"><a href=\"#\" class=\"hover:text-[var(--teal)] transition-colors\" data-kid=\"315\">Features</a></li>\n          <li data-kid=\"316\"><a href=\"#\" class=\"hover:text-[var(--teal)] transition-colors\" data-kid=\"317\">How it works</a></li>\n          <li data-kid=\"318\"><a href=\"#\" class=\"hover:text-[var(--teal)] transition-colors\" data-kid=\"319\">Pricing</a></li>\n          <li data-kid=\"320\"><a href=\"#\" class=\"hover:text-[var(--teal)] transition-colors\" data-kid=\"321\">Roadmap</a></li>\n        </ul>\n      </div>\n\n      <div class=\"space-y-6\" data-kid=\"322\">\n        <h4 class=\"font-bold text-lg\" data-kid=\"323\">Company</h4>\n        <ul class=\"space-y-4 text-[var(--text2)]\" data-kid=\"324\">\n          <li data-kid=\"325\"><a href=\"#\" class=\"hover:text-[var(--purple)] transition-colors\" data-kid=\"326\">About Us</a></li>\n          <li data-kid=\"327\"><a href=\"#\" class=\"hover:text-[var(--purple)] transition-colors\" data-kid=\"328\">Careers</a></li>\n          <li data-kid=\"329\"><a href=\"#\" class=\"hover:text-[var(--purple)] transition-colors\" data-kid=\"330\">Blog</a></li>\n          <li data-kid=\"331\"><a href=\"#\" class=\"hover:text-[var(--purple)] transition-colors\" data-kid=\"332\">Contact</a></li>\n        </ul>\n      </div>\n\n      <div class=\"space-y-6\" data-kid=\"333\">\n        <h4 class=\"font-bold text-lg\" data-kid=\"334\">Legal</h4>\n        <ul class=\"space-y-4 text-[var(--text2)]\" data-kid=\"335\">\n          <li data-kid=\"336\"><a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"337\">Privacy Policy</a></li>\n          <li data-kid=\"338\"><a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"339\">Terms of Service</a></li>\n          <li data-kid=\"340\"><a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"341\">Cookie Policy</a></li>\n        </ul>\n      </div>\n    </div>\n\n    <div class=\"max-w-[1200px] mx-auto mt-20 pt-10 border-t border-white/5 flex flex-col md:flex-row justify-between items-center gap-6 text-sm text-[var(--text3)]\" data-kid=\"342\">\n      <div data-kid=\"343\">© 2024 TaskMate AI. All rights reserved.</div>\n      <div class=\"flex gap-8\" data-kid=\"344\">\n        <a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"345\"><i class=\"ti ti-brand-twitter text-xl\" data-kid=\"346\"></i></a>\n        <a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"347\"><i class=\"ti ti-brand-linkedin text-xl\" data-kid=\"348\"></i></a>\n        <a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"349\"><i class=\"ti ti-brand-instagram text-xl\" data-kid=\"350\"></i></a>\n        <a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"351\"><i class=\"ti ti-brand-github text-xl\" data-kid=\"352\"></i></a>\n      </div>\n    </div>\n  </footer>\n</div>\n",
