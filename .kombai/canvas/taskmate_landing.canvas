      },
      "html": "\n<style data-kid=\"0\">\n    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap');\n    @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n    :root {\n        /* Dark mode defaults */\n        --bg-primary: #0F0A1A;\n        --bg-secondary: #1A1228;\n        --bg-tertiary: #241B35;\n        --bg-card: rgba(26,18,40,0.8);\n        --bg-glass: rgba(26,18,40,0.5);\n        --text-primary: #F0EEF8;\n        --text-secondary: #B8B0D4;\n        --text-muted: #7A7090;\n        --border: rgba(255,255,255,0.07);\n        --border-hover: rgba(139,101,200,0.35);\n        --nav-bg: rgba(15,10,26,0.85);\n        --card-shadow: 0 20px 60px rgba(0,0,0,0.5);\n        --glow-purple: rgba(139,101,200,0.15);\n        --glow-teal: rgba(74,191,184,0.10);\n        --glow-pink: rgba(240,96,122,0.10);\n        --scrollbar-thumb: #241B35;\n        --scrollbar-thumb-hover: #8B65C8;\n\n        /* Always same */\n        --orange: #F5A87B;\n        --pink: #F0607A;\n        --purple: #8B65C8;\n        --teal: #4ABFB8;\n        --grad-primary: linear-gradient(135deg, #F5A87B, #F0607A, #8B65C8, #4ABFB8);\n        --grad-cta: linear-gradient(135deg, #F0607A, #8B65C8);\n    }\n\n    [data-theme=\"light\"] {\n        --bg-primary: #F8F5FF;\n        --bg-secondary: #FFFFFF;\n        --bg-tertiary: #F0EBF8;\n        --bg-card: rgba(255,255,255,0.9);\n        --bg-glass: rgba(248,245,255,0.8);\n        --text-primary: #1A0F2E;\n        --text-secondary: #4A3F6B;\n        --text-muted: #8A7FAA;\n        --border: rgba(139,101,200,0.10);\n        --border-hover: rgba(139,101,200,0.40);\n        --nav-bg: rgba(248,245,255,0.90);\n        --card-shadow: 0 8px 32px rgba(139,101,200,0.12);\n        --glow-purple: rgba(139,101,200,0.07);\n        --glow-teal: rgba(74,191,184,0.07);\n        --glow-pink: rgba(240,96,122,0.07);\n        --scrollbar-thumb: #C4B8E8;\n        --scrollbar-thumb-hover: #8B65C8;\n    }\n\n    body {\n        font-family: 'Inter', sans-serif;\n        background-color: var(--bg-primary);\n        color: var(--text-primary);\n        overflow-x: hidden;\n    }\n\n    /* Global transitions for theme swap */\n    *, *::before, *::after {\n        transition: background-color 0.3s ease, border-color 0.3s ease, color 0.3s ease, box-shadow 0.3s ease;\n    }\n\n    .grad-text {\n        background: var(--grad-primary);\n        -webkit-background-clip: text;\n        -webkit-text-fill-color: transparent;\n        background-clip: text;\n    }\n\n    /* Scroll animations removed for iframe compatibility */\n    .reveal {\n        opacity: 1;\n        transform: none;\n    }\n\n    /* Custom Scrollbar */\n    ::-webkit-scrollbar { width: 6px; }\n    ::-webkit-scrollbar-track { background: var(--bg-primary); }\n    ::-webkit-scrollbar-thumb { background: var(--scrollbar-thumb); border-radius: 10px; }\n    ::-webkit-scrollbar-thumb:hover { background: var(--scrollbar-thumb-hover); }\n\n    /* Hero Aurora */\n    .aurora-container {\n        position: absolute;\n        inset: 0;\n        overflow: hidden;\n        pointer-events: none;\n        z-index: 0;\n    }\n    .aurora-blob {\n        position: absolute;\n        width: 900px;\n        height: 900px;\n        filter: blur(140px);\n        border-radius: 50%;\n        animation: aurora-rotate 60s infinite linear;\n        opacity: 0.15;\n    }\n    @keyframes aurora-rotate {\n        0% { transform: translate(-50%, -50%) rotate(0deg) scale(1); }\n        50% { transform: translate(-50%, -50%) rotate(180deg) scale(1.1); }\n        100% { transform: translate(-50%, -50%) rotate(360deg) scale(1); }\n    }\n\n    /* Particles */\n    .particle {\n        position: absolute;\n        border-radius: 50%;\n        animation: particle-float 15s infinite ease-in-out;\n    }\n    @keyframes particle-float {\n        0%, 100% { transform: translate(0, 0); opacity: 0.2; }\n        33% { transform: translate(30px, -50px); opacity: 0.5; }\n        66% { transform: translate(-20px, 40px); opacity: 0.2; }\n    }\n\n    /* Navigation - Absolute for iframe compatibility */\n    #navbar {\n        background: var(--nav-bg);\n        backdrop-filter: blur(12px);\n        border-bottom: 1px solid var(--border);\n    }\n\n    /* Mockup 3D Tilt */\n    .mockup-container {\n        perspective: 1500px;\n    }\n    .mockup-inner {\n        transform: rotateX(6deg) rotateY(-4deg);\n        transition: transform 0.6s cubic-bezier(0.2, 0.8, 0.2, 1);\n    }\n    .mockup-container:hover .mockup-inner {\n        transform: rotateX(0deg) rotateY(0deg);\n    }\n\n    /* Floating elements */\n    .floating-chip {\n        animation: chip-float 5s infinite ease-in-out;\n    }\n    @keyframes chip-float {\n        0%, 100% { transform: translateY(0); }\n        50% { transform: translateY(-12px); }\n    }\n\n    /* Testimonials Marquee */\n    .marquee-container {\n        mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);\n    }\n    .marquee-track {\n        display: flex;\n        gap: 24px;\n        animation: scroll 40s linear infinite;\n        width: max-content;\n    }\n    .marquee-track:hover {\n        animation-play-state: paused;\n    }\n    @keyframes scroll {\n        0% { transform: translateX(0); }\n        100% { transform: translateX(calc(-50% - 12px)); }\n    }\n\n    /* How it works */\n    .step-btn {\n        transition: all 0.4s cubic-bezier(0.2, 0.8, 0.2, 1);\n    }\n    .step-btn.active {\n        background: var(--bg-secondary);\n        border-color: var(--purple);\n        box-shadow: 0 10px 40px -10px var(--glow-purple), inset 0 0 20px rgba(139, 101, 200, 0.05);\n        transform: translateX(8px);\n    }\n    .step-btn.active h3 { color: var(--purple); }\n\n    .panel-content {\n        transition: opacity 0.4s ease, transform 0.4s ease;\n    }\n    .panel-content.hidden {\n        display: none;\n        opacity: 0;\n        transform: translateY(10px);\n    }\n\n    .wave-bar {\n        width: 4px;\n        background: var(--purple);\n        border-radius: 2px;\n        animation: voice-wave 1.2s infinite ease-in-out;\n    }\n    @keyframes voice-wave {\n        0%, 100% { height: 8px; }\n        50% { height: var(--peak, 40px); }\n    }\n\n    /* FAQ */\n    .faq-item.active .faq-content {\n        max-height: 200px;\n        opacity: 1;\n        margin-top: 1rem;\n    }\n    .faq-item.active .ti-plus {\n        transform: rotate(45deg);\n    }\n\n    /* Pricing Pro Glow */\n    .pro-card.glow-pulse {\n        animation: pricing-glow 4s infinite ease-in-out;\n    }\n    @keyframes pricing-glow {\n        0%, 100% { box-shadow: 0 0 20px rgba(139,101,200,0.2), var(--card-shadow); }\n        50% { box-shadow: 0 0 40px rgba(139,101,200,0.4), var(--card-shadow); }\n    }\n\n    /* Mobile menu */\n    #mobile-menu {\n        transform: translateY(-100%);\n        transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);\n    }\n    #mobile-menu.open {\n        transform: translateY(0);\n    }\n</style>\n\n<div class=\"relative overflow-hidden\" data-kid=\"1\">\n    \n    <div class=\"aurora-container\" data-kid=\"2\">\n        <div class=\"aurora-blob bg-[var(--purple)] top-[10%] left-[20%]\" data-kid=\"3\"></div>\n        <div class=\"aurora-blob bg-[var(--teal)] top-[50%] left-[80%]\" style=\"animation-delay: -20s;\" data-kid=\"4\"></div>\n        <div class=\"aurora-blob bg-[var(--pink)] top-[80%] left-[30%]\" style=\"animation-delay: -40s;\" data-kid=\"5\"></div>\n        \n        \n        <div class=\"particle w-1 h-1 bg-[var(--purple)] top-[15%] left-[10%]\" data-kid=\"6\"></div>\n        <div class=\"particle w-1.5 h-1.5 bg-[var(--teal)] top-[35%] left-[85%]\" style=\"animation-delay: -2s;\" data-kid=\"7\"></div>\n        <div class=\"particle w-1 h-1 bg-[var(--pink)] top-[65%] left-[40%]\" style=\"animation-delay: -5s;\" data-kid=\"8\"></div>\n        <div class=\"particle w-2 h-2 bg-[var(--purple)] top-[80%] left-[15%]\" style=\"animation-delay: -8s;\" data-kid=\"9\"></div>\n        <div class=\"particle w-1 h-1 bg-[var(--teal)] top-[20%] left-[70%]\" style=\"animation-delay: -3s;\" data-kid=\"10\"></div>\n        <div class=\"particle w-1 h-1 bg-[var(--orange)] top-[50%] left-[5%]\" style=\"animation-delay: -12s;\" data-kid=\"11\"></div>\n    </div>\n\n    \n    <nav id=\"navbar\" class=\"absolute top-0 left-0 right-0 z-50 transition-all duration-300 py-4 px-6 lg:px-12 flex items-center justify-between\" data-kid=\"12\">\n        <div class=\"flex items-center gap-2\" data-kid=\"13\">\n            <svg class=\"w-10 h-10\" viewBox=\"0 0 40 40\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\" data-kid=\"14\">\n                <rect width=\"40\" height=\"40\" rx=\"10\" fill=\"url(#logoGrad)\" data-kid=\"15\"></rect>\n                <defs data-kid=\"16\">\n                    <linearGradient id=\"logoGrad\" x1=\"0\" y1=\"40\" x2=\"40\" y2=\"0\" data-kid=\"17\">\n                        <stop offset=\"0%\" stop-color=\"#F5A87B\" data-kid=\"18\"></stop>\n                        <stop offset=\"30%\" stop-color=\"#F0607A\" data-kid=\"19\"></stop>\n                        <stop offset=\"65%\" stop-color=\"#8B65C8\" data-kid=\"20\"></stop>\n                        <stop offset=\"100%\" stop-color=\"#4ABFB8\" data-kid=\"21\"></stop>\n                    </linearGradient>\n                </defs>\n                <circle cx=\"20\" cy=\"20\" r=\"11\" stroke=\"white\" stroke-width=\"2.5\" fill=\"none\" data-kid=\"22\"></circle>\n                <path d=\"M14 20.5L18 24.5L26 16\" stroke=\"white\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\" data-kid=\"23\"></path>\n            </svg>\n            <span class=\"text-xl font-bold tracking-tight\" data-kid=\"24\">TaskMate AI</span>\n        </div>\n\n        \n        <div class=\"hidden md:flex items-center gap-8\" data-kid=\"25\">\n            <a href=\"#features\" class=\"text-sm font-medium hover:text-[var(--purple)] transition-colors\" data-kid=\"26\">Features</a>\n            <a href=\"#how-it-works\" class=\"text-sm font-medium hover:text-[var(--purple)] transition-colors\" data-kid=\"27\">How it works</a>\n            <a href=\"#pricing\" class=\"text-sm font-medium hover:text-[var(--purple)] transition-colors\" data-kid=\"28\">Pricing</a>\n            <a href=\"#faq\" class=\"text-sm font-medium hover:text-[var(--purple)] transition-colors\" data-kid=\"29\">FAQ</a>\n        </div>\n\n        <div class=\"flex items-center gap-4\" data-kid=\"30\">\n            <button id=\"theme-toggle\" class=\"p-2 rounded-xl bg-white/5 border border-white/10 hover:bg-white/10 transition-colors text-xl\" data-kid=\"31\">\n                <i class=\"ti ti-moon-stars\" id=\"theme-icon\" data-kid=\"32\"></i>\n            </button>\n            <button class=\"hidden md:block text-sm font-bold hover:text-[var(--purple)] transition-colors\" data-kid=\"33\">Sign in</button>\n            <button class=\"px-6 py-2.5 bg-[var(--grad-cta)] text-white text-sm font-bold rounded-full shadow-lg hover:scale-105 transition-transform\" data-kid=\"34\">Download Free →</button>\n            <button id=\"mobile-toggle\" class=\"md:hidden p-2 text-2xl\" data-kid=\"35\">\n                <i class=\"ti ti-menu-2\" data-kid=\"36\"></i>\n            </button>\n        </div>\n    </nav>\n\n    \n    <div id=\"mobile-menu\" class=\"fixed inset-0 z-40 bg-[var(--bg-primary)] p-8 pt-24 md:hidden flex flex-col gap-6\" data-kid=\"37\">\n        <a href=\"#features\" class=\"text-2xl font-bold\" data-kid=\"38\">Features</a>\n        <a href=\"#how-it-works\" class=\"text-2xl font-bold\" data-kid=\"39\">How it works</a>\n        <a href=\"#pricing\" class=\"text-2xl font-bold\" data-kid=\"40\">Pricing</a>\n        <a href=\"#faq\" class=\"text-2xl font-bold\" data-kid=\"41\">FAQ</a>\n        <hr class=\"border-white/10\" data-kid=\"42\">\n        <button class=\"w-full py-4 rounded-2xl bg-white/5 font-bold\" data-kid=\"43\">Sign in</button>\n    </div>\n\n    \n    <section class=\"min-h-[900px] flex items-center pt-20 pb-20 relative z-10\" data-kid=\"44\">\n        <div class=\"container mx-auto px-6 text-center\" data-kid=\"45\">\n            <div class=\"inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/5 border border-white/10 mb-8 backdrop-blur-sm\" data-kid=\"46\">\n                <span class=\"w-2 h-2 rounded-full bg-[var(--teal)] animate-pulse shadow-[0_0_8px_var(--teal)]\" data-kid=\"47\"></span>\n                <span class=\"text-xs font-semibold uppercase tracking-widest opacity-80\" data-kid=\"48\">AI-Powered Task Intelligence · v1.7.0</span>\n            </div>\n\n            <h1 class=\"text-5xl md:text-8xl font-black mb-6 leading-[1.05] tracking-tighter\" data-kid=\"49\">\n                Plan smarter.<br data-kid=\"50\">\n                <span class=\"grad-text italic\" data-kid=\"51\">Live better.</span>\n            </h1>\n\n            <p class=\"max-w-2xl mx-auto text-lg md:text-xl text-[var(--text-secondary)] mb-10 leading-relaxed\" data-kid=\"52\">\n                Harness the power of AI to organize your life. From voice-captured thoughts to auto-scheduled days, TaskMate AI is your ultimate productivity partner.\n            </p>\n\n            <div class=\"flex flex-col sm:flex-row items-center justify-center gap-5 mb-16\" data-kid=\"53\">\n                <button class=\"px-10 py-5 bg-[var(--grad-cta)] text-white font-extrabold rounded-2xl shadow-[0_20px_40px_-10px_rgba(240,96,122,0.4)] hover:scale-105 transition-transform text-lg\" data-kid=\"54\">\n                    Get Started Free\n                </button>\n                <button class=\"px-10 py-5 border border-white/10 bg-white/5 backdrop-blur-md font-extrabold rounded-2xl hover:bg-white/10 transition-colors flex items-center gap-3 text-lg\" data-kid=\"55\">\n                    <i class=\"ti ti-player-play-filled\" data-kid=\"56\"></i> Watch Demo\n                </button>\n            </div>\n\n            <div class=\"flex flex-wrap items-center justify-center gap-8 mb-20 opacity-70\" data-kid=\"57\">\n                <div class=\"flex items-center gap-2 text-xs font-bold uppercase tracking-widest\" data-kid=\"58\"><i class=\"ti ti-brand-android text-xl text-[var(--teal)]\" data-kid=\"59\"></i> Android Live</div>\n                <div class=\"flex items-center gap-2 text-xs font-bold uppercase tracking-widest opacity-40\" data-kid=\"60\"><i class=\"ti ti-brand-apple text-xl\" data-kid=\"61\"></i> iOS Soon</div>\n                <div class=\"flex items-center gap-2 text-xs font-bold uppercase tracking-widest\" data-kid=\"62\"><i class=\"ti ti-browser text-xl text-[var(--purple)]\" data-kid=\"63\"></i> Web App</div>\n            </div>\n\n            \n            <div class=\"reveal mockup-container max-w-6xl mx-auto px-4\" style=\"transition-delay: 500ms\" data-kid=\"64\">\n                <div class=\"mockup-inner relative rounded-3xl border border-white/10 bg-[var(--bg-secondary)] shadow-2xl p-2 overflow-hidden aspect-[16/10]\" data-kid=\"65\">\n                    <div class=\"w-full h-full bg-[#0b0e14] rounded-2xl overflow-hidden relative\" data-kid=\"66\">\n                         \n                        <div class=\"absolute top-4 left-6 flex gap-2 z-20\" data-kid=\"67\">\n                            <div class=\"w-3 h-3 rounded-full bg-[#FF5F56]\" data-kid=\"68\"></div>\n                            <div class=\"w-3 h-3 rounded-full bg-[#FFBD2E]\" data-kid=\"69\"></div>\n                            <div class=\"w-3 h-3 rounded-full bg-[#27C93F]\" data-kid=\"70\"></div>\n                        </div>\n                        <img src=\"/api/local/images/assets/dashboardDark.png\" alt=\"TaskMate Dashboard\" class=\"w-full h-full object-cover\" decoding=\"async\" loading=\"lazy\" data-kid=\"71\">\n                        \n                        \n                        <div class=\"absolute top-[15%] left-[-2%] z-30 floating-chip hidden lg:block\" data-kid=\"72\">\n                            <div class=\"bg-white/10 backdrop-blur-xl border border-white/20 p-4 rounded-2xl shadow-2xl flex items-center gap-4\" data-kid=\"73\">\n                                <div class=\"w-12 h-12 rounded-xl bg-[var(--purple)] flex items-center justify-center text-white text-2xl shadow-lg\" data-kid=\"74\">\n                                    <i class=\"ti ti-microphone\" data-kid=\"75\"></i>\n                                </div>\n                                <div class=\"text-left\" data-kid=\"76\">\n                                    <p class=\"text-[10px] font-bold uppercase tracking-widest text-[var(--purple)]\" data-kid=\"77\">Voice Capturing</p>\n                                    <p class=\"text-sm font-semibold\" data-kid=\"78\">\"Schedule sync with devs...\"</p>\n                                </div>\n                            </div>\n                        </div>\n\n                        <div class=\"absolute bottom-[20%] right-[-2%] z-30 floating-chip hidden lg:block\" style=\"animation-delay: -2s;\" data-kid=\"79\">\n                            <div class=\"bg-white/10 backdrop-blur-xl border border-white/20 p-4 rounded-2xl shadow-2xl flex items-center gap-4\" data-kid=\"80\">\n                                <div class=\"w-12 h-12 rounded-xl bg-[var(--teal)] flex items-center justify-center text-white text-2xl shadow-lg\" data-kid=\"81\">\n                                    <i class=\"ti ti-target\" data-kid=\"82\"></i>\n                                </div>\n                                <div class=\"text-left\" data-kid=\"83\">\n                                    <p class=\"text-[10px] font-bold uppercase tracking-widest text-[var(--teal)]\" data-kid=\"84\">Deep Work Active</p>\n                                    <p class=\"text-sm font-semibold\" data-kid=\"85\">Focus Timer: 42:15</p>\n                                </div>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    \n    <section class=\"reveal border-y border-[var(--border)] bg-[var(--bg-secondary)] py-12\" data-kid=\"86\">\n        <div class=\"container mx-auto px-6\" data-kid=\"87\">\n            <div class=\"grid grid-cols-2 md:grid-cols-4 gap-8 text-center py-4\" id=\"stats-section\" data-kid=\"88\">\n                <div data-kid=\"89\">\n                    <div class=\"text-4xl md:text-5xl font-black grad-text mb-2\" data-kid=\"90\"><span class=\"stat-number\" data-target=\"1200\" data-kid=\"91\">1000</span>+</div>\n                    <div class=\"text-sm font-bold uppercase tracking-widest text-[var(--text-muted)]\" data-kid=\"92\">Active Users</div>\n                </div>\n                <div data-kid=\"93\">\n                    <div class=\"text-4xl md:text-5xl font-black grad-text mb-2\" data-kid=\"94\"><span class=\"stat-number\" data-target=\"4.8\" data-decimal=\"1\" data-kid=\"95\">0</span>★</div>\n                    <div class=\"text-sm font-bold uppercase tracking-widest text-[var(--text-muted)]\" data-kid=\"96\">User Rating</div>\n                </div>\n                <div data-kid=\"97\">\n                    <div class=\"text-4xl md:text-5xl font-black grad-text mb-2\" data-kid=\"98\"><span class=\"stat-number\" data-target=\"6\" data-kid=\"99\">0</span></div>\n                    <div class=\"text-sm font-bold uppercase tracking-widest text-[var(--text-muted)]\" data-kid=\"100\">Languages</div>\n                </div>\n                <div data-kid=\"101\">\n                    <div class=\"text-4xl md:text-5xl font-black grad-text mb-2\" data-kid=\"102\">₹<span class=\"stat-number\" data-target=\"0\" data-kid=\"103\">0</span></div>\n                    <div class=\"text-sm font-bold uppercase tracking-widest text-[var(--text-muted)]\" data-kid=\"104\">Started Free</div>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    \n    <section id=\"features\" class=\"py-32 bg-[var(--bg-primary)]\" data-kid=\"105\">\n        <div class=\"container mx-auto px-6\" data-kid=\"106\">\n            <div class=\"text-center mb-20 reveal\" data-kid=\"107\">\n                <h2 class=\"text-4xl md:text-5xl font-extrabold mb-6\" data-kid=\"108\">Built for elite performance</h2>\n                <p class=\"text-[var(--text-secondary)] max-w-2xl mx-auto text-lg\" data-kid=\"109\">TaskMate AI isn't just a list; it's a cognitive extension that understands your workflow.</p>\n            </div>\n\n            <div class=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-[1px] bg-[var(--border)] border border-[var(--border)] rounded-[2.5rem] overflow-hidden shadow-2xl\" data-kid=\"110\">\n                \n                <div class=\"reveal bg-[var(--bg-secondary)] p-10 hover:bg-[var(--bg-tertiary)] transition-all duration-500 group cursor-default border border-transparent hover:border-[var(--border-hover)] shadow-xs hover:shadow-2xl\" data-kid=\"111\">\n                    <div class=\"w-14 h-14 rounded-2xl bg-[var(--purple)]/20 flex items-center justify-center text-[var(--purple)] text-3xl mb-8 group-hover:scale-110 transition-transform\" data-kid=\"112\">\n                        <i class=\"ti ti-microphone\" data-kid=\"113\"></i>\n                    </div>\n                    <h3 class=\"text-2xl font-bold mb-4\" data-kid=\"114\">Voice to Task</h3>\n                    <p class=\"text-[var(--text-secondary)] leading-relaxed\" data-kid=\"115\">Turn ephemeral thoughts into actionable items just by speaking. High-fidelity transcriptions with context awareness.</p>\n                </div>\n                \n                <div class=\"reveal bg-[var(--bg-secondary)] p-10 hover:bg-[var(--bg-tertiary)] transition-colors group cursor-default\" style=\"transition-delay: 100ms\" data-kid=\"116\">\n                    <div class=\"w-14 h-14 rounded-2xl bg-[var(--pink)]/20 flex items-center justify-center text-[var(--pink)] text-3xl mb-8 group-hover:scale-110 transition-transform\" data-kid=\"117\">\n                        <i class=\"ti ti-sparkles\" data-kid=\"118\"></i>\n                    </div>\n                    <h3 class=\"text-2xl font-bold mb-4\" data-kid=\"119\">AI Smart Suggestions</h3>\n                    <p class=\"text-[var(--text-secondary)] leading-relaxed\" data-kid=\"120\">Let AI handle the prioritization. TaskMate suggests what to do next based on your deadlines and energy levels.</p>\n                </div>\n                \n                <div class=\"reveal bg-[var(--bg-secondary)] p-10 hover:bg-[var(--bg-tertiary)] transition-colors group cursor-default\" style=\"transition-delay: 200ms\" data-kid=\"121\">\n                    <div class=\"w-14 h-14 rounded-2xl bg-[var(--teal)]/20 flex items-center justify-center text-[var(--teal)] text-3xl mb-8 group-hover:scale-110 transition-transform\" data-kid=\"122\">\n                        <i class=\"ti ti-bell-ringing\" data-kid=\"123\"></i>\n                    </div>\n                    <h3 class=\"text-2xl font-bold mb-4\" data-kid=\"124\">Smart Reminders</h3>\n                    <p class=\"text-[var(--text-secondary)] leading-relaxed\" data-kid=\"125\">Reminders that adapt. If you're busy, TaskMate intelligently reschedules minor alerts to avoid flow disruption.</p>\n                </div>\n                \n                <div class=\"reveal bg-[var(--bg-secondary)] p-10 hover:bg-[var(--bg-tertiary)] transition-colors group cursor-default\" style=\"transition-delay: 300ms\" data-kid=\"126\">\n                    <div class=\"w-14 h-14 rounded-2xl bg-[var(--orange)]/20 flex items-center justify-center text-[var(--orange)] text-3xl mb-8 group-hover:scale-110 transition-transform\" data-kid=\"127\">\n                        <i class=\"ti ti-calendar-event\" data-kid=\"128\"></i>\n                    </div>\n           