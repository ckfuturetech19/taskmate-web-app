le)] animate-[voice-wave_1.2s_0.3s_infinite]\" style=\"--peak: 90px;\" data-kid=\"171\"></div>\n                                <div class=\"w-1.5 rounded-full bg-[var(--purple)] animate-[voice-wave_1.2s_0.4s_infinite]\" style=\"--peak: 60px;\" data-kid=\"172\"></div>\n                                <div class=\"w-1.5 rounded-full bg-[var(--purple)] animate-[voice-wave_1.2s_0.5s_infinite]\" style=\"--peak: 70px;\" data-kid=\"173\"></div>\n                                <div class=\"w-1.5 rounded-full bg-[var(--purple)] animate-[voice-wave_1.2s_0.6s_infinite]\" style=\"--peak: 30px;\" data-kid=\"174\"></div>\n                            </div>\n                            <div class=\"w-full bg-[var(--bg-tertiary)] p-6 rounded-2xl border border-[var(--border)] animate-fade-up\" data-kid=\"175\">\n                                <div class=\"flex items-center gap-2 mb-3\" data-kid=\"176\">\n                                    <div class=\"w-2 h-2 rounded-full bg-red-500 animate-pulse\" data-kid=\"177\"></div>\n                                    <span class=\"text-[10px] text-[var(--text-muted)] font-bold uppercase tracking-widest\" data-kid=\"178\">Listening...</span>\n                                </div>\n                                <p class=\"text-[var(--text-primary)] italic text-lg\" data-kid=\"179\">\"Remind me to prep for the investor pitch at 9 AM tomorrow...\"</p>\n                            </div>\n                        </div>\n                        \n                        <div id=\"preview-1\" class=\"preview-panel hidden w-full space-y-6\" data-kid=\"180\">\n                            <div class=\"flex justify-between items-center\" data-kid=\"181\">\n                                <h5 class=\"font-bold text-[var(--text-primary)]\" data-kid=\"182\">AI Optimized Schedule</h5>\n                                <span class=\"px-2 py-0.5 rounded-md bg-[var(--pink)]/10 text-[var(--pink)] text-[10px] font-bold\" data-kid=\"183\">✦ AI DRAFT</span>